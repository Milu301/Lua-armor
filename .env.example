# ============================================================
# LUARMOR PANEL v3 — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── PostgreSQL ───────────────────────────────────────────────
# Railway internal URL (use this on Railway):
DATABASE_URL=postgresql://postgres:yUFbQuikhgfdcsTyAbOiZBFFkLauPPoj@postgres.railway.internal:5432/railway
# Local dev example:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/luarmor

# ── Session ──────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_this_to_a_very_long_random_string_at_least_32_chars

# ── Panel Branding ───────────────────────────────────────────
PANEL_NAME=LuarmorHub
PANEL_LOGO=https://cdn.discordapp.com/icons/1398423987817807934/a_6f62815e5aee24b4964bd4113626e3fe.webp?size=64
DISCORD_URL=https://discord.gg/tHrR89y7kn

# ── Admin Account (auto-created on first boot) ───────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
ADMIN_LUARMOR_KEY=admin-placeholder-key

# ── Projects / Tiers ─────────────────────────────────────────
# Add up to 10 projects. Each one maps to a Luarmor project.
# The panel auto-detects which project a user's key belongs to.

# Project 1 — Basic / Free tier
PROJECT_1_NAME=Basic
PROJECT_1_LUARMOR_ID=your_luarmor_project_id_here
PROJECT_1_LUARMOR_KEY=your_luarmor_api_key_here
PROJECT_1_COLOR=#8b5cf6
PROJECT_1_GRADIENT=linear-gradient(135deg,#8b5cf6,#6366f1)
PROJECT_1_ICON=⚡
PROJECT_1_LIMIT=2
PROJECT_1_DESC=Standard access with 2 daily resets.

# Project 2 — Premium
PROJECT_2_NAME=Premium
PROJECT_2_LUARMOR_ID=your_premium_project_id_here
PROJECT_2_LUARMOR_KEY=your_premium_api_key_here
PROJECT_2_COLOR=#f59e0b
PROJECT_2_GRADIENT=linear-gradient(135deg,#f59e0b,#fbbf24)
PROJECT_2_ICON=⭐
PROJECT_2_LIMIT=5
PROJECT_2_DESC=Premium access with 5 daily resets.

# Project 3 — Gold
PROJECT_3_NAME=Gold
PROJECT_3_LUARMOR_ID=your_gold_project_id_here
PROJECT_3_LUARMOR_KEY=your_gold_api_key_here
PROJECT_3_COLOR=#eab308
PROJECT_3_GRADIENT=linear-gradient(135deg,#eab308,#facc15)
PROJECT_3_ICON=🏆
PROJECT_3_LIMIT=10
PROJECT_3_DESC=Gold tier with unlimited resets.

# Project 4 — (add more as needed, up to PROJECT_10_*)
# PROJECT_4_NAME=...
# PROJECT_4_LUARMOR_ID=...
# PROJECT_4_LUARMOR_KEY=...
# PROJECT_4_COLOR=#ef4444
# PROJECT_4_GRADIENT=linear-gradient(135deg,#ef4444,#f87171)
# PROJECT_4_ICON=💎
# PROJECT_4_LIMIT=999
# PROJECT_4_DESC=Elite diamond access.
