# ============================================================
# LUARMOR PANEL v2 — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.

# Port — Railway assigns this automatically, do NOT change
PORT=3000

# Your Luarmor API Key (from https://luarmor.net/profile)
LUARMOR_API_KEY=your_api_key_here

# Your Luarmor Project ID (from https://luarmor.net/projects)
LUARMOR_PROJECT_ID=your_project_id_here

# Session secret — use a long random string (32+ chars)
SESSION_SECRET=change_this_to_something_very_secret_and_long_1234567890

# Daily HWID reset limit per user (default: 3)
DAILY_RESET_LIMIT=3

# Panel display name
PANEL_NAME=AuroraHud

# Hex accent color without # (default: 8b5cf6 = purple)
ACCENT_COLOR=8b5cf6

# Set to "production" on Railway for secure cookies
NODE_ENV=production
