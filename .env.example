# ============================================================
# LUARMOR PANEL — Variables de Entorno
# ============================================================
# Copia este archivo como .env y rellena los valores

# Puerto (Railway lo asigna automáticamente — no cambies esto)
PORT=3000

# Luarmor API Key (de https://luarmor.net/profile)
LUARMOR_API_KEY=tu_api_key_aqui

# Luarmor Project ID (de https://luarmor.net/projects)
LUARMOR_PROJECT_ID=tu_project_id_aqui

# Secreto de sesión — pon algo largo y aleatorio
SESSION_SECRET=cambia_esto_por_algo_muy_secreto_y_largo_1234567890

# Límite diario de resets de HWID (default: 3)
DAILY_RESET_LIMIT=3

# Nombre del panel (se muestra en el header)
PANEL_NAME=Mi Script Hub

# Color de acento hex (sin el #, default: 8b5cf6 = morado)
ACCENT_COLOR=8b5cf6
