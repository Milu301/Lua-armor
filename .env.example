
# ============================================================
# AURORASAFE PANEL — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── PostgreSQL ───────────────────────────────────────────────
# Railway internal URL (use this on Railway):
DATABASE_URL=postgresql://postgres:password@postgres.railway.internal:5432/railway
# Local dev example:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/aurorasafe

# ── Session ──────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_this_to_a_very_long_random_string_at_least_32_chars

# ── AuroraSafe API ───────────────────────────────────────────
# Your AuroraSafe backend URL and API key (from Settings > API Keys)
AURORASAFE_API_URL=http://localhost:3001
AURORASAFE_API_KEY=lck_your_api_key_here

# ── Panel Branding ───────────────────────────────────────────
PANEL_NAME=AuroraSafe Hub
PANEL_LOGO=https://cdn.discordapp.com/icons/1398423987817807934/a_6f62815e5aee24b4964bd4113626e3fe.webp?size=64
DISCORD_URL=https://discord.gg/tHrR89y7kn

# ── Admin Account (auto-created on first boot) ───────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# ── Scripts / Tiers ─────────────────────────────────────────
# Add up to 10 scripts. Each maps to an AuroraSafe script UUID.
# Get the script ID from AuroraSafe admin panel > Scripts > click on a script.

# Script 1 — Basic / Free tier
SCRIPT_1_NAME=Basic
SCRIPT_1_ID=your_script_uuid_here
SCRIPT_1_COLOR=#8b5cf6
SCRIPT_1_GRADIENT=linear-gradient(135deg,#8b5cf6,#6366f1)
SCRIPT_1_ICON=⚡
SCRIPT_1_LIMIT=2
SCRIPT_1_DESC=Standard access with 2 daily resets.

# Script 2 — Premium
SCRIPT_2_NAME=Premium
SCRIPT_2_ID=your_premium_script_uuid_here
SCRIPT_2_COLOR=#f59e0b
SCRIPT_2_GRADIENT=linear-gradient(135deg,#f59e0b,#fbbf24)
SCRIPT_2_ICON=⭐
SCRIPT_2_LIMIT=5
SCRIPT_2_DESC=Premium access with 5 daily resets.

# Script 3 — Gold
SCRIPT_3_NAME=Gold
SCRIPT_3_ID=your_gold_script_uuid_here
SCRIPT_3_COLOR=#eab308
SCRIPT_3_GRADIENT=linear-gradient(135deg,#eab308,#facc15)
SCRIPT_3_ICON=🏆
SCRIPT_3_LIMIT=10
SCRIPT_3_DESC=Gold tier with unlimited resets.

# ── Discord OAuth ─────────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://your-railway-url.up.railway.app/auth/discord/callback

# ── Bold Payments ─────────────────────────────────────────
# Get these from: bold.co → Integraciones → Llaves de integración
BOLD_IDENTITY_KEY=your_bold_identity_key
BOLD_SECRET_KEY=your_bold_secret_key
# USD → COP conversion rate (Bold charges in COP; users see USD prices).
USD_TO_COP_RATE=3100
# Webhook URL to set in Bold dashboard → Integraciones → Webhooks:
# https://YOUR_RAILWAY_URL/api/payment/webhook
