(function() {
  const targets = [
    { id: 'ov-users',  val: <%= stats.totalUsers %> },
    { id: 'ov-active', val: <%= stats.activeToday %> },
    { id: 'ov-resets', val: <%= Number(stats.totalResets) %> },
  ];
