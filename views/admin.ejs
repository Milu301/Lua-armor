<%- include('partials/head', { title: 'Admin Panel — ' + panelName }) %>

<style>
.tab-bar { display:flex; gap:2px; padding:0 1.75rem; background:var(--bg-card); border-bottom:1px solid var(--border); position:sticky; top:53px; z-index:40; overflow-x:auto; scrollbar-width:none; }
.tab-bar::-webkit-scrollbar { display:none; }
.tab-btn { padding:0.75rem 1rem; font-size:0.8rem; font-weight:600; color:var(--text-2); background:none; border:none; cursor:pointer; border-bottom:2px solid transparent; transition:color 0.15s, border-color 0.15s; font-family:inherit; display:flex; align-items:center; gap:0.4rem; white-space:nowrap; flex-shrink:0; }
.tab-btn:hover { color:var(--text); }
.tab-btn.active { color:var(--accent); border-bottom-color:var(--accent); }
.tab-panel { display:none; animation:fadeIn 0.15s ease; }
.tab-panel.active { display:block; }
.modal-overlay { display:none; position:fixed; inset:0; z-index:1000; background:rgba(0,0,0,0.75); backdrop-filter:blur(8px); align-items:center; justify-content:center; padding:1.5rem; }
.modal-overlay.open { display:flex; animation:fadeIn 0.2s ease; }
.modal-box { background:var(--bg-card); border:1px solid var(--border-acc); border-radius:var(--rl); padding:1.75rem; width:100%; max-width:520px; box-shadow:var(--shadow-lg); animation:slideUp 0.2s ease; max-height:90vh; overflow-y:auto; }
.modal-box h2 { font-size:1rem; font-weight:700; margin-bottom:1.25rem; }
.modal-close { float:right; background:none; border:none; cursor:pointer; color:var(--text-3); font-size:1.4rem; line-height:1; padding:2px 6px; border-radius:6px; margin-top:-4px; transition:background 0.12s,color 0.12s; }
.modal-close:hover { background:var(--bg-raised); color:var(--text); }
.field-grid { display:grid; grid-template-columns:1fr 1fr; gap:0.75rem; }
.form-row { margin-bottom:0.75rem; }
@media(max-width:900px){
  .stat-grid[style*="repeat(5"] { grid-template-columns:repeat(3,1fr) !important; }
}
</style>

<div class="layout">
  <%- include('partials/sidebar', { page: 'admin' }) %>

  <div class="main">
    <!-- Topbar -->
    <div class="topbar">
      <div class="topbar-left">
        <div class="pulse-dot" style="background:var(--accent);box-shadow:0 0 0 2px rgba(139,92,246,0.2);"></div>
        <div class="topbar-title">Admin Panel</div>
        <span class="badge badge-purple" style="font-size:0.65rem;">ADMIN</span>
      </div>
      <div class="topbar-right">
        <span class="t-xs dimmed" id="stats-live"></span>
        <span id="topbar-clock" style="font-family:'JetBrains Mono',monospace;font-size:0.72rem;color:var(--text-3);background:var(--bg-raised);border:1px solid var(--border-md);border-radius:7px;padding:3px 10px;"></span>
        <a href="/dashboard" class="btn btn-sm btn-ghost">
          <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          Dashboard
        </a>
      </div>
    </div>

    <!-- Tab bar -->
    <div class="tab-bar">
      <button class="tab-btn active" onclick="switchTab('overview',this)">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1.5" stroke-width="2"/><rect x="14" y="3" width="7" height="7" rx="1.5" stroke-width="2"/><rect x="3" y="14" width="7" height="7" rx="1.5" stroke-width="2"/><rect x="14" y="14" width="7" height="7" rx="1.5" stroke-width="2"/></svg>
        Overview
      </button>
      <button class="tab-btn" onclick="switchTab('projects',this)">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
        Projects
      </button>
      <button class="tab-btn" onclick="switchTab('users',this)">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/></svg>
        Users
        <span class="sb-badge" id="users-count-badge"><%= users.length %></span>
      </button>
      <button class="tab-btn" onclick="switchTab('live',this);refreshAdminLive();">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3" stroke-width="2"/><path stroke-linecap="round" stroke-width="2" d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14M15.54 8.46a5 5 0 010 7.07M8.46 8.46a5 5 0 000 7.07"/></svg>
        Live
        <span class="sb-badge" id="live-count-badge" style="background:var(--green);display:none;">0</span>
      </button>
      <button class="tab-btn" onclick="switchTab('announcements',this)">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/></svg>
        Announcements
      </button>
      <button class="tab-btn" onclick="switchTab('chat',this)">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
        Chat
        <span class="sb-badge" style="background:rgba(6,182,212,0.15);color:#22d3ee;border-color:rgba(6,182,212,0.25);">MOD</span>
      </button>
      <button class="tab-btn" onclick="switchTab('bugs',this)">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
        Bug Reports
        <% if (Number(stats.openBugs) > 0) { %>
        <span class="sb-badge" style="background:rgba(245,158,11,0.15);border-color:rgba(245,158,11,0.3);color:#fbbf24;"><%= stats.openBugs %></span>
        <% } %>
      </button>
      <button class="tab-btn" onclick="switchTab('settings',this)">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Settings
      </button>
      <button class="tab-btn" onclick="switchTab('payments',this);loadPaymentsTab();">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
        Payments
        <span class="sb-badge" style="background:rgba(139,92,246,0.12);border-color:rgba(139,92,246,0.25);color:#a78bfa;">BOLD</span>
      </button>
      <button class="tab-btn" onclick="switchTab('promos',this);loadPromosTab();">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
        Promo Codes
      </button>
      <button class="tab-btn" onclick="switchTab('tutorials',this);loadTutorialsTab();">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Tutorials
      </button>
    </div>

    <!-- ═══════ TAB: OVERVIEW ═══════ -->
    <div class="tab-panel active" id="tab-overview">
      <div class="content" style="max-width:1100px;">
        <div class="stat-grid" style="grid-template-columns:repeat(6,1fr);margin-bottom:1.5rem; animation: slideUp 0.6s ease;">
          <div class="stat" style="border-top:2px solid var(--accent); background: var(--bg-raised); transition: transform 0.3s; box-shadow: 0 4px 20px rgba(0,0,0,0.2);" onmouseover="this.style.transform='translateY(-5px)';" onmouseout="this.style.transform='translateY(0)';">
            <div class="stat-label">Total Users</div>
            <div class="stat-val c-purple" id="ov-users" style="text-shadow: 0 0 10px rgba(139,92,246,0.3);"><%= stats.totalUsers %></div>
            <div class="stat-sub">registered accounts</div>
          </div>
          <div class="stat" style="border-top:2px solid var(--green); background: var(--bg-raised); transition: transform 0.3s; box-shadow: 0 4px 20px rgba(0,0,0,0.2);" onmouseover="this.style.transform='translateY(-5px)';" onmouseout="this.style.transform='translateY(0)';">
            <div class="stat-label">Active Today</div>
            <div class="stat-val c-green" id="ov-active" style="text-shadow: 0 0 10px rgba(34,197,94,0.3);"><%= stats.activeToday %></div>
            <div class="stat-sub">users reset today</div>
          </div>
          <div class="stat" style="border-top:2px solid #3b82f6; background: var(--bg-raised); transition: transform 0.3s; box-shadow: 0 4px 20px rgba(0,0,0,0.2);" onmouseover="this.style.transform='translateY(-5px)';" onmouseout="this.style.transform='translateY(0)';">
            <div class="stat-label">Total Resets</div>
            <div class="stat-val c-blue" id="ov-resets" style="text-shadow: 0 0 10px rgba(59,130,246,0.3);"><%= Number(stats.totalResets).toLocaleString() %></div>
            <div class="stat-sub">all time</div>
          </div>
          <div class="stat" style="border-top:2px solid var(--yellow); background: var(--bg-raised); transition: transform 0.3s; box-shadow: 0 4px 20px rgba(0,0,0,0.2);" onmouseover="this.style.transform='translateY(-5px)';" onmouseout="this.style.transform='translateY(0)';">
            <div class="stat-label">Projects</div>
            <div class="stat-val c-yellow" style="text-shadow: 0 0 10px rgba(245,158,11,0.3);"><%= projects.length %></div>
            <div class="stat-sub">tiers configured</div>
          </div>
          <div class="stat" style="border-top:2px solid var(--cyan);cursor:pointer; background: var(--bg-raised); transition: transform 0.3s; box-shadow: 0 4px 20px rgba(0,0,0,0.2);" onmouseover="this.style.transform='translateY(-5px)';" onmouseout="this.style.transform='translateY(0)';" onclick="switchTab('chat',document.querySelector('[onclick*=\'chat\']'));refreshChatMod();" title="View chat">
            <div class="stat-label">Chat Messages</div>
            <div class="stat-val c-cyan" id="ov-chat" style="text-shadow: 0 0 10px rgba(6,182,212,0.3);"><%= stats.chatMessages || 0 %></div>
            <div class="stat-sub">total messages</div>
          </div>
          <div class="stat" style="border-top:2px solid var(--green);cursor:pointer; background: var(--bg-raised); transition: transform 0.3s; box-shadow: 0 4px 20px rgba(0,0,0,0.2);" onmouseover="this.style.transform='translateY(-5px)';" onmouseout="this.style.transform='translateY(0)';" onclick="switchTab('live',document.querySelector('[onclick*=\'live\']'));refreshAdminLive();" title="View live sessions">
            <div class="stat-label">Live Now</div>
            <div class="stat-val c-green" id="ov-live" style="text-shadow: 0 0 10px rgba(34,197,94,0.3);">—</div>
            <div class="stat-sub">accounts online</div>
          </div>
        </div>

        <!-- Recent users -->
        <div class="card" style="animation: slideUp 0.8s ease; box-shadow: 0 10px 30px rgba(0,0,0,0.3);">
          <div class="card-head">
            <div class="card-icon ci-green">👥</div>
            <div><div class="card-title">Recent Registrations</div><div class="card-desc">Last 10 signups</div></div>
          </div>
          <div class="admin-table-wrap">
            <table class="admin-table">
              <thead><tr><th>Username</th><th>Project</th><th>Joined</th><th>Last Login</th><th>Status</th></tr></thead>
              <tbody>
                <% users.slice(0,10).forEach(u => { %>
                <tr>
                  <td><span style="font-weight:600;"><%= u.username %></span></td>
                  <td><% if (u.project_name) { %><span class="badge badge-purple" style="font-size:0.65rem;"><%= u.project_icon %> <%= u.project_name %></span><% } else { %><span class="dimmed t-xs">—</span><% } %></td>
                  <td><span class="t-xs dimmed"><%= new Date(u.created_at).toLocaleDateString('en',{day:'numeric',month:'short',year:'2-digit'}) %></span></td>
                  <td><span class="t-xs dimmed"><%= u.last_login ? new Date(u.last_login).toLocaleDateString('en',{day:'numeric',month:'short'}) : '—' %></span></td>
                  <td><span class="badge <%= u.is_active ? 'badge-green' : 'badge-red' %>" style="font-size:0.65rem;"><%= u.is_active ? 'Active' : 'Banned' %></span></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════ TAB: PROJECTS ═══════ -->
    <div class="tab-panel" id="tab-projects">
      <div class="content" style="max-width:1100px;">
        <div class="card">
          <div class="card-head">
            <div class="card-icon ci-purple">🗂️</div>
            <div><div class="card-title">Projects / Tiers</div><div class="card-desc">Each project maps to a Luarmor project. Users are auto-assigned on registration.</div></div>
            <button class="btn btn-primary btn-sm" style="margin-left:auto;" onclick="openProjectModal()">
              <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
              Add Project
            </button>
          </div>

          <div id="projects-list" style="display:flex;flex-direction:column;gap:0.625rem;">
            <% projects.forEach(p => { %>
            <div class="admin-project-row" id="prow-<%= p.id %>">
              <div class="admin-proj-icon" style="background:<%= p.gradient %>"><%= p.icon %></div>
              <div style="flex:1;min-width:0;">
                <div style="font-size:0.85rem;font-weight:700;display:flex;align-items:center;gap:0.5rem;">
                  <%= p.name %>
                  <% if (!p.is_active) { %><span class="badge badge-red" style="font-size:0.6rem;">Disabled</span><% } %>
                </div>
                <div class="t-xs dimmed" style="margin-top:2px;"><%= p.user_count %> users · <%= p.daily_reset_limit %> resets/day · <span class="mono"><%= p.slug %></span></div>
              </div>
              <div class="t-xs mono dimmed" style="flex-shrink:0;max-width:140px;overflow:hidden;text-overflow:ellipsis;" title="<%= p.luarmor_project_id %>"><%= p.luarmor_project_id %></div>
              <div style="display:flex;gap:0.4rem;flex-shrink:0;">
                <button class="btn btn-sm btn-secondary" onclick='openProjectModal(<%= p.id %>)'>Edit</button>
                <button class="btn btn-sm" style="background:var(--red-dim);border:1px solid var(--red-border);color:#f87171;" onclick="disableProject(<%= p.id %>, '<%= p.name %>')">Disable</button>
                <button class="btn btn-sm" style="background:var(--red-dim);border:1px solid var(--red-border);color:#f87171;" onclick="deleteProject(<%= p.id %>, '<%= p.name %>')" title="Delete Project">🗑️</button>
              </div>
            </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════ TAB: USERS ═══════ -->
    <div class="tab-panel" id="tab-users">
      <div class="content" style="max-width:1100px;">
        <div class="card">
          <div class="card-head">
            <div class="card-icon ci-green">👥</div>
            <div><div class="card-title">User Management</div><div class="card-desc">Edit, ban, delete users and manage their keys</div></div>
            <div style="margin-left:auto;display:flex;gap:0.5rem;align-items:center;">
              <input type="text" class="input" id="user-search" placeholder="Search username, key, Discord…" style="width:220px;font-size:0.78rem;" oninput="searchUsers()" />
            </div>
          </div>

          <div class="admin-table-wrap">
            <table class="admin-table" id="users-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Username</th>
                  <th>Luarmor Key</th>
                  <th>Project</th>
                  <th>Discord</th>
                  <th>Role</th>
                  <th>Resets</th>
                  <th>Joined</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="users-tbody">
                <% users.forEach(u => { %>
                <tr id="urow-<%= u.id %>" data-search="<%= (u.username + ' ' + u.key_prefix + ' ' + u.discord_id).toLowerCase() %>">
                  <td class="dimmed t-xs"><%= u.id %></td>
                  <td><div style="font-weight:600;font-size:0.82rem;"><%= u.username %></div></td>
                  <td>
                    <div class="chip" style="font-size:0.68rem;max-width:140px;" onclick="copyUserKey(<%= u.id %>, this)" title="Click to copy full key">
                      <svg width="10" height="10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" stroke-width="2"/><path stroke-width="2" d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                      <%= u.key_prefix %>
                    </div>
                  </td>
                  <td>
                    <% if (u.project_name) { %>
                    <span class="badge badge-purple" style="font-size:0.65rem;"><%= u.project_icon %> <%= u.project_name %></span>
                    <% } else { %><span class="dimmed t-xs">None</span><% } %>
                  </td>
                  <td><span class="mono t-xs dimmed"><%= u.discord_id || '—' %></span></td>
                  <td>
                    <% if (u.role === 'admin') { %><span class="badge badge-purple" style="font-size:0.65rem;">Admin</span>
                    <% } else if (u.role === 'mod') { %><span class="badge badge-blue" style="font-size:0.65rem;">Mod</span>
                    <% } else { %><span class="badge badge-gray" style="font-size:0.65rem;">User</span><% } %>
                  </td>
                  <td><span class="t-sm"><%= u.total_resets %></span></td>
                  <td><span class="t-xs dimmed"><%= new Date(u.created_at).toLocaleDateString('en',{day:'numeric',month:'short',year:'2-digit'}) %></span></td>
                  <td>
                    <span id="ustatus-<%= u.id %>" class="badge <%= u.is_active ? 'badge-green' : 'badge-red' %>" style="font-size:0.65rem;">
                      <%= u.is_active ? 'Active' : 'Banned' %>
                    </span>
                  </td>
                  <td>
                    <div style="display:flex;gap:0.3rem;">
                      <button class="btn btn-sm btn-secondary" style="padding:3px 7px;font-size:0.7rem;" onclick='openUserModal(<%= u.id %>)' title="Edit">✏️</button>
                      <button class="btn btn-sm" id="ubtn-<%= u.id %>" style="padding:3px 7px;font-size:0.7rem;background:<%= u.is_active ? 'var(--red-dim)' : 'var(--green-dim)' %>;border:1px solid <%= u.is_active ? 'var(--red-border)' : 'var(--green-border)' %>;color:<%= u.is_active ? '#f87171' : '#4ade80' %>;" onclick="toggleUser(<%= u.id %>, this)" title="<%= u.is_active ? 'Ban' : 'Unban' %>"><%= u.is_active ? '🚫' : '✅' %></button>
                      <button class="btn btn-sm" style="padding:3px 7px;font-size:0.7rem;background:var(--red-dim);border:1px solid var(--red-border);color:#f87171;" onclick="deleteUser(<%= u.id %>, '<%= u.username %>')" title="Delete">🗑️</button>
                    </div>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════ TAB: LIVE SESSIONS ═══════ -->
    <div class="tab-panel" id="tab-live">
      <div class="content" style="max-width:1100px;">
        <div class="card">
          <div class="card-head">
            <div class="card-icon" style="background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.22);color:var(--green);">
              <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3" stroke-width="2"/><path stroke-linecap="round" stroke-width="2" d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14M15.54 8.46a5 5 0 010 7.07M8.46 8.46a5 5 0 000 7.07"/></svg>
            </div>
            <div>
              <div class="card-title">Live Sessions</div>
              <div class="card-desc">All users currently executing — refreshes every 8 seconds</div>
            </div>
            <div id="admin-live-badge" style="margin-left:auto;">
              <span class="badge badge-gray" style="font-size:0.72rem;">● Loading...</span>
            </div>
          </div>
          <div id="admin-live-list">
            <div class="live-sessions-empty" style="padding:2.5rem;">
              <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:var(--text-3);margin-bottom:0.5rem;"><circle cx="12" cy="12" r="10" stroke-width="1.5"/><path stroke-linecap="round" stroke-width="1.5" d="M12 8v4m0 4h.01"/></svg>
              <div style="font-size:0.82rem;color:var(--text-3);">Loading live sessions...</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════ TAB: ANNOUNCEMENTS ═══════ -->
    <div class="tab-panel" id="tab-announcements">
      <div class="content" style="max-width:800px;">
        <div class="admin-ann-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">

          <!-- Post new -->
          <div class="card" style="margin-bottom:0; animation: slideUp 0.6s ease; box-shadow: 0 10px 30px rgba(0,0,0,0.3);">
            <div class="card-head">
              <div class="card-icon ci-blue">📢</div>
              <div><div class="card-title">Post Announcement</div><div class="card-desc">Visible to all users on dashboard</div></div>
            </div>
            <div id="ann-result"></div>
            <div class="form-row"><label class="label">Title</label><input type="text" class="input" id="ann-title" placeholder="e.g. Update v2.5 released" maxlength="128"/></div>
            <div class="form-row"><label class="label">Content</label><textarea class="input" id="ann-content" rows="3" placeholder="Describe the update…" maxlength="2000" style="resize:vertical;"></textarea></div>
            <div style="display:flex;gap:0.5rem;margin-bottom:0.75rem;align-items:center;">
              <select class="input" id="ann-type" style="flex:1;"><option value="info">Info</option><option value="success">Success</option><option value="warning">Warning</option><option value="danger">Danger</option></select>
              <label style="display:flex;align-items:center;gap:0.4rem;font-size:0.78rem;color:var(--text-2);flex-shrink:0;cursor:pointer;"><input type="checkbox" id="ann-pinned" style="accent-color:var(--accent);"/> Pinned</label>
            </div>
            <button class="btn btn-primary btn-full" onclick="postAnnouncement()">Post Announcement</button>
          </div>

          <!-- Active -->
          <div class="card" style="margin-bottom:0; animation: slideUp 0.8s ease; box-shadow: 0 10px 30px rgba(0,0,0,0.3);">
            <div class="card-head">
              <div class="card-icon ci-yellow">📋</div>
              <div><div class="card-title">Active Announcements</div></div>
            </div>
            <% if (!announcements.length) { %>
            <div class="empty-state">No announcements yet.</div>
            <% } else { %>
            <div style="display:flex;flex-direction:column;gap:0.5rem;" id="ann-list">
              <% announcements.forEach(a => { %>
              <div class="admin-ann-row announce-<%= a.type %>" id="ann-<%= a.id %>">
                <div style="flex:1;min-width:0;">
                  <div style="font-size:0.8rem;font-weight:600;display:flex;align-items:center;gap:0.35rem;">
                    <% if (a.pinned) { %><span class="badge badge-purple" style="font-size:0.58rem;">PIN</span><% } %>
                    <span class="badge badge-gray" style="font-size:0.58rem;"><%= a.type %></span>
                    <%= a.title %>
                  </div>
                  <div class="t-xs dimmed" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:2px;"><%= a.content %></div>
                </div>
                <button class="btn btn-sm" style="background:var(--red-dim);border:1px solid var(--red-border);color:#f87171;padding:3px 7px;flex-shrink:0;" onclick="deleteAnn(<%= a.id %>)">🗑️</button>
              </div>
              <% }) %>
            </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════ TAB: CHAT MODERATION ═══════ -->
    <div class="tab-panel" id="tab-chat">
      <div class="content" style="max-width:800px;">
        <div class="card">
          <div class="card-head">
            <div class="card-icon" style="background:rgba(6,182,212,0.1);border:1px solid rgba(6,182,212,0.2);">💬</div>
            <div>
              <div class="card-title">Chat Moderation</div>
              <div class="card-desc">View and delete global chat messages. Real-time via Socket.io.</div>
            </div>
            <button class="btn btn-sm btn-ghost" style="margin-left:auto;" onclick="refreshChatMod()">
              <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
              Refresh
            </button>
          </div>
          <div id="chat-mod-list" style="max-height:60vh;overflow-y:auto;">
            <% if (chatMessages && chatMessages.length > 0) { %>
              <% chatMessages.forEach(function(m) { %>
              <div class="chat-mod-msg" id="adminmsg-<%= m.id %>">
                <div class="chat-mod-avatar"><%= m.username.slice(0,2).toUpperCase() %></div>
                <div class="chat-mod-body">
                  <div class="chat-mod-meta">
                    <span class="chat-mod-name" style="<%= m.role === 'admin' ? 'color:#f87171;' : m.role === 'mod' ? 'color:#fbbf24;' : '' %>"><%= m.username %></span>
                    <% if (m.role === 'admin') { %><span class="chat-role-tag chat-role-admin">admin</span><% } %>
                    <% if (m.role === 'mod')   { %><span class="chat-role-tag chat-role-mod">mod</span><% } %>
                    <span style="color:var(--text-3)"><%= new Date(m.created_at).toLocaleString('en',{day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'}) %></span>
                  </div>
                  <% if (m.image_url) { %>
                    <img src="<%= m.image_url %>" class="chat-mod-img" alt="img" />
                  <% } else { %>
                    <div class="chat-mod-content"><%= m.content %></div>
                  <% } %>
                </div>
                <button class="chat-mod-del" onclick="adminDeleteMsg(<%= m.id %>,this)" title="Delete message">
                  <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                </button>
              </div>
              <% }) %>
            <% } else { %>
              <div style="text-align:center;padding:2rem;color:var(--text-3);font-size:0.82rem;">No chat messages yet.</div>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════ TAB: BUG REPORTS ═══════ -->
    <div class="tab-panel" id="tab-bugs">
      <div class="content">
        <div class="card" style="padding:0;overflow:hidden;">
          <div style="padding:0.875rem 1.125rem;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:0.5rem;">
            <div class="card-title" style="font-size:0.82rem;">
              <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
              Bug Reports
            </div>
          </div>

          <% if (bugReports.length === 0) { %>
          <div style="padding:2.5rem;text-align:center;color:var(--text-3);font-size:0.82rem;">No bug reports yet.</div>
          <% } else { %>
          <% bugReports.forEach(function(r) { %>
          <div class="admin-bug-row" id="bug-<%= r.id %>">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
              <div style="flex:1;min-width:0;">
                <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.25rem;flex-wrap:wrap;">
                  <span style="font-weight:600;font-size:0.82rem;"><%= r.title %></span>
                  <span class="bug-status-badge bug-status-<%= r.status %>">
                    <%= r.status === 'open' ? 'Open' : r.status === 'in_progress' ? 'In Progress' : r.status === 'resolved' ? 'Resolved' : "Won't Fix" %>
                  </span>
                </div>
                <div style="font-size:0.78rem;color:var(--text-2);margin-bottom:0.35rem;white-space:pre-wrap;word-break:break-word;"><%= r.description %></div>
                <div style="font-size:0.68rem;color:var(--text-3);">By <strong><%= r.username %></strong> · <%= new Date(r.created_at).toLocaleDateString('en', {day:'2-digit',month:'short',year:'numeric'}) %></div>
              </div>
              <div style="display:flex;flex-direction:column;gap:0.4rem;min-width:160px;">
                <select class="input" style="font-size:0.75rem;padding:0.35rem 0.6rem;" onchange="updateBug(<%= r.id %>, {status:this.value})">
                  <option value="open"        <%= r.status==='open'        ? 'selected':'' %>>Open</option>
                  <option value="in_progress" <%= r.status==='in_progress' ? 'selected':'' %>>In Progress</option>
                  <option value="resolved"    <%= r.status==='resolved'    ? 'selected':'' %>>Resolved</option>
                  <option value="wontfix"     <%= r.status==='wontfix'     ? 'selected':'' %>>Won't Fix</option>
                </select>
                <input type="text" class="input" style="font-size:0.75rem;padding:0.35rem 0.6rem;" placeholder="Add staff note…"
                  value="<%= r.admin_note %>"
                  onchange="updateBug(<%= r.id %>, {admin_note:this.value})" />
              </div>
            </div>
          </div>
          <% }); %>
          <% } %>
        </div>
      </div>
    </div>

    <!-- ═══════ TAB: SETTINGS ═══════ -->
    <div class="tab-panel" id="tab-settings">
      <div class="content" style="max-width:640px;">
        <div class="card">
          <div class="card-head">
            <div class="card-icon ci-purple">⚙️</div>
            <div><div class="card-title">Panel Settings</div><div class="card-desc">Changes apply immediately without redeploying</div></div>
          </div>
          <div id="settings-result"></div>

          <div class="form-row">
            <label class="label">Panel Name</label>
            <input type="text" class="input" id="s-panel-name" value="<%= settings.panel_name || panelName %>" maxlength="64" placeholder="LuarmorHub"/>
          </div>

          <div class="form-row">
            <label class="label">Panel Logo URL</label>
            <div style="display:flex;gap:0.5rem;align-items:center;">
              <input type="text" class="input" id="s-panel-logo" value="<%= settings.panel_logo || panelLogo %>" placeholder="https://…" oninput="previewLogo(this.value)"/>
              <img id="logo-preview" src="<%= settings.panel_logo || panelLogo %>" style="width:36px;height:36px;border-radius:8px;object-fit:cover;border:1px solid var(--border-md);flex-shrink:0;" onerror="this.style.display='none'" />
            </div>
            <div class="input-hint">Direct image URL (Discord CDN, Imgur, etc.)</div>
          </div>

          <div class="form-row">
            <label class="label">Discord Server URL</label>
            <input type="text" class="input" id="s-discord-url" value="<%= settings.discord_url || discordUrl %>" placeholder="https://discord.gg/…"/>
          </div>

          <button class="btn btn-primary" onclick="saveSettings()" style="margin-top:0.5rem;">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Save Settings
          </button>
        </div>
      </div>
    </div>

    <!-- ═══════ TAB: PAYMENTS ═══════ -->
    <div class="tab-panel" id="tab-payments">
      <div class="content" style="max-width:1100px;">

        <!-- Stats row -->
        <div class="stat-grid" style="grid-template-columns:repeat(4,1fr);margin-bottom:1.25rem;" id="pay-stats-row">
          <div class="stat" style="border-top:2px solid var(--green);">
            <div class="stat-label">Total Revenue</div>
            <div class="stat-val c-green" id="pay-revenue">—</div>
            <div class="stat-sub">USD · all time</div>
          </div>
          <div class="stat" style="border-top:2px solid var(--accent);">
            <div class="stat-label">Orders</div>
            <div class="stat-val c-purple" id="pay-total">—</div>
            <div class="stat-sub">total orders</div>
          </div>
          <div class="stat" style="border-top:2px solid #3b82f6;">
            <div class="stat-label">Approved</div>
            <div class="stat-val c-blue" id="pay-approved">—</div>
            <div class="stat-sub">paid orders</div>
          </div>
          <div class="stat" style="border-top:2px solid var(--yellow);">
            <div class="stat-label">Active Plans</div>
            <div class="stat-val c-yellow" id="pay-plans-count">—</div>
            <div class="stat-sub">on sale</div>
          </div>
        </div>

        <!-- Plans management -->
        <div class="card" style="margin-bottom:1.25rem;">
          <div class="card-head">
            <div class="card-icon" style="background:rgba(139,92,246,0.1);border:1px solid rgba(139,92,246,0.22);">💳</div>
            <div>
              <div class="card-title">Payment Plans</div>
              <div class="card-desc">Manage the plans users can buy at /plans. Each plan auto-delivers a Luarmor key on payment.</div>
            </div>
            <button class="btn btn-primary btn-sm" style="margin-left:auto;" onclick="openPlanModal()">
              <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
              New Plan
            </button>
          </div>
          <div id="admin-plans-list" style="min-height:60px;">
            <div class="empty-state" style="padding:2rem;">Loading plans…</div>
          </div>
        </div>

        <!-- Orders table -->
        <div class="card">
          <div class="card-head">
            <div class="card-icon ci-green">📋</div>
            <div>
              <div class="card-title">Payment Orders</div>
              <div class="card-desc">All transactions processed through Bold. Keys are auto-generated when approved.</div>
            </div>
            <button class="btn btn-sm btn-ghost" style="margin-left:auto;" onclick="loadPaymentsTab()">
              <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
              Refresh
            </button>
          </div>
          <div class="admin-table-wrap">
            <table class="admin-table" id="orders-table">
              <thead><tr>
                <th>Order Ref</th>
                <th>User</th>
                <th>Plan</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Date</th>
                <th>Bold TX</th>
              </tr></thead>
              <tbody id="orders-tbody">
                <tr><td colspan="7" style="text-align:center;color:var(--text-3);padding:2rem;">Loading…</td></tr>
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </div>

    <!-- ═══════ TAB: PROMO CODES ═══════ -->
    <div class="tab-panel" id="tab-promos">
      <div class="content" style="max-width:1100px;">
        <div class="card" style="margin-bottom:1.25rem;">
          <div class="card-head">
            <div class="card-icon" style="background:rgba(236,72,153,0.1);border:1px solid rgba(236,72,153,0.22);color:#ec4899;">🏷️</div>
            <div>
              <div class="card-title">Promo Codes</div>
              <div class="card-desc">Create discount codes for your users.</div>
            </div>
            <button class="btn btn-primary btn-sm" style="margin-left:auto; background: #ec4899;" onclick="openPromoModal()">
              <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
              New Code
            </button>
          </div>
          <div class="admin-table-wrap">
            <table class="admin-table" id="promos-table">
              <thead><tr>
                <th>Code</th>
                <th>Discount</th>
                <th>Uses</th>
                <th>Status</th>
                <th>Created</th>
                <th>Actions</th>
              </tr></thead>
              <tbody id="promos-tbody">
                <tr><td colspan="6" style="text-align:center;color:var(--text-3);padding:2rem;">Loading…</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════ TAB: TUTORIALS ═══════ -->
    <div class="tab-panel" id="tab-tutorials">
      <div class="content" style="max-width:1200px;">
        <div class="card" style="margin-bottom:1.25rem;">
          <div class="card-head">
            <div class="card-icon" style="background:rgba(99,102,241,0.1);border:1px solid rgba(99,102,241,0.25);color:#818cf8;">🎬</div>
            <div>
              <div class="card-title">Tutorials</div>
              <div class="card-desc">Upload video tutorials visible to all users on the public page.</div>
            </div>
            <button class="btn btn-primary btn-sm" style="margin-left:auto;background:#6366f1;" onclick="openTutorialModal()">
              <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
              Upload Video
            </button>
          </div>
          <!-- Upload progress -->
          <div id="tut-upload-progress" style="display:none;padding:0 1.5rem 1rem;">
            <div style="background:rgba(0,0,0,0.3);border-radius:8px;overflow:hidden;height:6px;">
              <div id="tut-progress-bar" style="height:100%;background:linear-gradient(90deg,#6366f1,#8b5cf6);width:0%;transition:width 0.3s;"></div>
            </div>
            <div id="tut-progress-label" style="font-size:0.75rem;color:var(--text-3);margin-top:0.4rem;">Uploading…</div>
          </div>
          <!-- Tutorials Grid -->
          <div id="tut-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.25rem;padding:1.5rem;">
            <div style="grid-column:1/-1;text-align:center;color:var(--text-3);padding:2rem;">Loading…</div>
          </div>
        </div>
      </div>
    </div>

  </div><!-- /main -->
</div><!-- /layout -->

<!-- ═══ PROJECT MODAL ═══ -->
<div class="modal-overlay" id="project-modal">
  <div class="modal-box">
    <button class="modal-close" onclick="closeModal('project-modal')">×</button>
    <h2 id="pm-title">Add Project</h2>
    <input type="hidden" id="pm-id" value="" />
    <div id="pm-result"></div>

    <div class="field-grid">
      <div class="form-row"><label class="label">Project Name *</label><input type="text" class="input" id="pm-name" placeholder="Premium" maxlength="64"/></div>
      <div class="form-row"><label class="label">Icon (emoji)</label><input type="text" class="input" id="pm-icon" placeholder="⭐" maxlength="8" style="font-size:1.2rem;"/></div>
    </div>
    <div class="form-row"><label class="label">Luarmor Project ID *</label><input type="text" class="input mono" id="pm-pid" placeholder="your_project_id" /></div>
    <div class="form-row"><label class="label">Luarmor API Key *</label><input type="text" class="input mono" id="pm-pkey" placeholder="your_api_key" /></div>
    <div class="field-grid">
      <div class="form-row"><label class="label">Daily Reset Limit</label><input type="number" class="input" id="pm-limit" value="3" min="1" max="999"/></div>
      <div class="form-row"><label class="label">Accent Color</label><input type="color" class="input" id="pm-color" value="#8b5cf6" style="height:40px;padding:4px;" oninput="updateGradientPreview()"/></div>
    </div>
    <div class="form-row"><label class="label">Gradient CSS <span class="dimmed">(auto-filled from color)</span></label><input type="text" class="input mono" id="pm-gradient" placeholder="linear-gradient(135deg,#8b5cf6,#6366f1)"/></div>
    <div class="form-row"><label class="label">Description</label><input type="text" class="input" id="pm-desc" placeholder="Short description shown on register page" maxlength="200"/></div>
    <div class="form-row">
      <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;font-size:0.82rem;margin-top:0.5rem;">
        <input type="checkbox" id="pm-free" style="accent-color:var(--cyan);width:16px;height:16px;"/>
        Free Tier Project (Users without a Luarmor key will be assigned here)
      </label>
    </div>
    <div style="display:flex;gap:0.5rem;margin-top:0.5rem;">
      <button class="btn btn-primary" onclick="saveProject()">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        Save Project
      </button>
      <button class="btn btn-ghost" onclick="closeModal('project-modal')">Cancel</button>
    </div>
  </div>
</div>

<!-- ═══ USER EDIT MODAL ═══ -->
<div class="modal-overlay" id="user-modal">
  <div class="modal-box">
    <button class="modal-close" onclick="closeModal('user-modal')">×</button>
    <h2>Edit User — <span id="um-name" style="color:var(--accent);"></span></h2>
    <input type="hidden" id="um-id" />
    <div id="um-result"></div>

    <div class="form-row">
      <label class="label">Full Luarmor Key</label>
      <div class="chip w-full" id="um-key" style="word-break:break-all;user-select:all;cursor:text;justify-content:flex-start;font-size:0.72rem;padding:0.5rem 0.75rem;" onclick="copyText(document.getElementById('um-key').dataset.key)"></div>
    </div>

    <div class="field-grid">
      <div class="form-row">
        <label class="label">Username</label>
        <input type="text" class="input" id="um-username" maxlength="32"/>
      </div>
      <div class="form-row">
        <label class="label">Role</label>
        <select class="input" id="um-role">
          <option value="user">User</option>
          <option value="mod">Mod</option>
          <option value="admin">Admin</option>
        </select>
      </div>
    </div>

    <div class="form-row">
      <label class="label">Project</label>
      <select class="input" id="um-project">
        <option value="">None</option>
        <% projects.forEach(p => { %>
        <option value="<%= p.id %>"><%= p.icon %> <%= p.name %></option>
        <% }) %>
      </select>
    </div>

    <div class="field-grid">
      <div class="form-row">
        <label class="label">Discord ID</label>
        <input type="text" class="input mono" id="um-discord" placeholder="123456789012345678" maxlength="20"/>
      </div>
      <div class="form-row">
        <label class="label">Note</label>
        <input type="text" class="input" id="um-note" placeholder="Custom note" maxlength="100"/>
