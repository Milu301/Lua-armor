/* ─── Subtle Particle Canvas for Admin ─── */
(function() {
  const canvas = document.createElement('canvas');
  canvas.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:-1;opacity:0.3;';
  document.body.insertBefore(canvas, document.body.firstChild);
  const ctx = canvas.getContext('2d');
  let W, H;
  function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
  resize();
  window.addEventListener('resize', resize, { passive: true });
  const COLS = ['rgba(147,51,234,', 'rgba(99,102,241,', 'rgba(255,255,255,'];
  const pts = Array.from({ length: 40 }, () => ({
    x: Math.random() * 1920, y: Math.random() * 1080,
    r: 0.3 + Math.random() * 1.2,
    vx: (Math.random() - 0.5) * 0.2, vy: -0.06 - Math.random() * 0.15,
    a: 0.05 + Math.random() * 0.22, c: COLS[Math.floor(Math.random() * COLS.length)]
  }));
  (function loop() {
    ctx.clearRect(0, 0, W, H);
    pts.forEach(p => {
      p.x += p.vx; p.y += p.vy;
      if (p.y < -4 || p.x < -4 || p.x > W + 4) { p.x = Math.random() * W; p.y = H + 4; }
      ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = p.c + p.a + ')'; ctx.fill();
    });
    requestAnimationFrame(loop);
  })();
})();

/* ── TUTORIALS ── */
function openTutorialModal() {
  document.getElementById('tut-title').value = '';
  document.getElementById('tut-desc').value = '';
  document.getElementById('tut-sort').value = '0';
  document.getElementById('tut-file').value = '';
  document.getElementById('tut-dropzone-label').textContent = 'Click or drag video here';
  document.getElementById('tut-modal-result').innerHTML = '';
  openModal('tutorial-modal');
}

function onTutFileSelect(input) {
  const file = input.files[0];
  if (file) {
    const mb = (file.size / 1024 / 1024).toFixed(1);
    document.getElementById('tut-dropzone-label').textContent = `✅ ${file.name} (${mb} MB)`;
    document.getElementById('tut-dropzone').style.borderColor = 'rgba(99,102,241,0.8)';
  }
}

async function submitTutorial() {
  const title = document.getElementById('tut-title').value.trim();
  const desc  = document.getElementById('tut-desc').value.trim();
  const sort  = document.getElementById('tut-sort').value;
  const file  = document.getElementById('tut-file').files[0];
  const result = document.getElementById('tut-modal-result');

  if (!title) return toast('Title is required.', 'warn');
  if (!file)  return toast('Please select a video file.', 'warn');

  const btn = document.getElementById('tut-submit-btn');
  btn.disabled = true;
  btn.innerHTML = '<i class="ph-bold ph-spinner ph-spin"></i> Uploading…';

  const progressWrap = document.getElementById('tut-upload-progress');
  const progressBar  = document.getElementById('tut-progress-bar');
  const progressLabel= document.getElementById('tut-progress-label');

  const formData = new FormData();
  formData.append('title', title);
  formData.append('description', desc);
  formData.append('sort_order', sort);
  formData.append('video', file);

  const xhr = new XMLHttpRequest();
  xhr.open('POST', '/api/admin/tutorials');

  xhr.upload.onprogress = (e) => {
    if (e.lengthComputable) {
      const pct = Math.round((e.loaded / e.total) * 100);
      progressBar.style.width = pct + '%';
      progressLabel.textContent = `Uploading… ${pct}%`;
      progressWrap.style.display = 'block';
    }
  };

  xhr.onload = () => {
    progressWrap.style.display = 'none';
    btn.disabled = false;
    btn.innerHTML = '<svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg> Upload';
    try {
      const data = JSON.parse(xhr.responseText);
      if (data.success) {
        toast('Tutorial uploaded!', 'ok');
        closeModal('tutorial-modal');
        loadTutorialsTab();
      } else {
        result.innerHTML = `<div class="alert alert-danger" style="margin-bottom:1rem;font-size:0.8rem;">${data.message}</div>`;
      }
    } catch (e) {
      result.innerHTML = `<div class="alert alert-danger" style="margin-bottom:1rem;font-size:0.8rem;">Unexpected error.</div>`;
    }
  };

  xhr.onerror = () => {
    progressWrap.style.display = 'none';
    btn.disabled = false;
    btn.innerHTML = '… Upload';
    result.innerHTML = `<div class="alert alert-danger" style="margin-bottom:1rem;font-size:0.8rem;">Network error. Try again.</div>`;
  };

  xhr.send(formData);
}

async function loadTutorialsTab() {
  const grid = document.getElementById('tut-grid');
  grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;color:var(--text-3);padding:2rem;">Loading…</div>';
  try {
    const res  = await fetch('/api/admin/tutorials');
    const data = await res.json();
    if (!data.success) {
      grid.innerHTML = `<div style="grid-column:1/-1;text-align:center;color:#f87171;padding:2rem;">${data.message || 'Error'}</div>`;
      return;
    }
    if (!data.tutorials.length) {
      grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;color:var(--text-3);padding:3rem;"><div style="font-size:2.5rem;margin-bottom:0.5rem;">🎬</div>No tutorials yet. Upload your first video!</div>';
      return;
    }
    grid.innerHTML = data.tutorials.map(t => `
      <div style="background:rgba(0,0,0,0.3);border:1px solid rgba(255,255,255,0.07);border-radius:14px;overflow:hidden;">
        <div style="position:relative;aspect-ratio:16/9;background:#000;">
          <video src="${t.video_url}" style="width:100%;height:100%;object-fit:cover;" preload="metadata" muted></video>
          <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.4);">
            <div style="width:44px;height:44px;border-radius:50%;background:rgba(255,255,255,0.9);display:flex;align-items:center;justify-content:center;">
              <svg width="18" height="18" fill="#6366f1" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </div>
          </div>
          <div style="position:absolute;top:8px;right:8px;">
            <span style="background:${t.is_active ? 'rgba(34,197,94,0.2)' : 'rgba(239,68,68,0.2)'};border:1px solid ${t.is_active ? 'rgba(34,197,94,0.4)' : 'rgba(239,68,68,0.4)'};color:${t.is_active ? '#4ade80' : '#f87171'};font-size:0.65rem;padding:2px 8px;border-radius:20px;font-weight:700;">${t.is_active ? 'LIVE' : 'HIDDEN'}</span>
          </div>
        </div>
        <div style="padding:1rem;">
          <div style="font-weight:700;font-size:0.95rem;margin-bottom:0.3rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${t.title}</div>
          ${t.description ? `<div style="font-size:0.78rem;color:var(--text-3);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:0.8rem;">${t.description}</div>` : '<div style="margin-bottom:0.8rem;"></div>'}
          <div style="display:flex;gap:0.4rem;">
            <button class="btn btn-sm" style="flex:1;padding:4px;font-size:0.7rem;background:${t.is_active ? 'rgba(239,68,68,0.1)' : 'rgba(34,197,94,0.1)'};border:1px solid ${t.is_active ? 'rgba(239,68,68,0.3)' : 'rgba(34,197,94,0.3)'};color:${t.is_active ? '#f87171' : '#4ade80'};" onclick="toggleTutorial(${t.id})">${t.is_active ? '🙈 Hide' : '👁 Show'}</button>
            <button class="btn btn-sm" style="flex:1;padding:4px;font-size:0.7rem;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#f87171;" onclick="deleteTutorial(${t.id}, '${t.title.replace(/'/g,"\\\\'").replace(/"/g, "&quot;")}')">🗑 Delete</button>
          </div>
        </div>
      </div>
    `).join('');
  } catch (err) {
    grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;color:#f87171;padding:2rem;">Network error.</div>';
  }
}

async function toggleTutorial(id) {
  const res  = await fetch(`/api/admin/tutorials/${id}`, { method: 'PATCH', headers: {'Content-Type':'application/json'}, body: JSON.stringify({}) });
  const data = await res.json();
  // get current state from DOM and flip it
  if (data.success || true) { loadTutorialsTab(); toast('Updated', 'ok'); }
}

async function deleteTutorial(id, titleStr) {
  if (!confirm(`Delete tutorial "${titleStr}"? The video file will also be deleted.`)) return;
  const res  = await fetch(`/api/admin/tutorials/${id}`, { method: 'DELETE' });
  const data = await res.json();
  if (data.success) { toast('Tutorial deleted', 'ok'); loadTutorialsTab(); }
  else toast(data.message, 'err');
}

/* ── PROMO CODES ── */
async function loadPromosTab() {
  const tbody = document.getElementById('promos-tbody');
  tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;color:var(--text-3);padding:2rem;">Loading…</td></tr>';
  try {
    const res = await fetch('/api/admin/promo-codes');
    const data = await res.json();
    if (!data.success) {
      tbody.innerHTML = `<tr><td colspan="6" style="text-align:center;color:#f87171;padding:2rem;">${data.message || 'Error'}</td></tr>`;
      return;
    }
    if (!data.codes.length) {
      tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;color:var(--text-3);padding:2rem;">No promo codes found.</td></tr>';
      return;
    }
    let html = '';
    data.codes.forEach(c => {
      const usesStr = c.max_uses > 0 ? `${c.current_uses} / ${c.max_uses}` : `${c.current_uses} / ∞`;
      const dateStr = new Date(c.created_at).toLocaleDateString();
      const statusBadge = c.is_active 
        ? '<span class="badge badge-green" style="font-size:0.65rem;">Active</span>' 
        : '<span class="badge badge-red" style="font-size:0.65rem;">Disabled</span>';
      
      html += `<tr>
        <td style="font-weight:700;font-family:'JetBrains Mono',monospace;">${c.code}</td>
        <td style="color:var(--green);font-weight:600;">${c.discount_percent}%</td>
        <td>${usesStr}</td>
        <td><span id="promo-status-${c.id}">${statusBadge}</span></td>
        <td style="color:var(--text-3);font-size:0.8rem;">${dateStr}</td>
        <td>
          <div style="display:flex;gap:0.3rem;">
            <button class="btn btn-sm" style="padding:3px 7px;font-size:0.7rem;background:${c.is_active ? 'var(--red-dim)' : 'var(--green-dim)'};border:1px solid ${c.is_active ? 'var(--red-border)' : 'var(--green-border)'};color:${c.is_active ? '#f87171' : '#4ade80'};" onclick="togglePromo(${c.id}, this)" title="${c.is_active ? 'Disable' : 'Enable'}">${c.is_active ? '🚫' : '✅'}</button>
            <button class="btn btn-sm" style="padding:3px 7px;font-size:0.7rem;background:var(--red-dim);border:1px solid var(--red-border);color:#f87171;" onclick="deletePromo(${c.id}, '${c.code}')" title="Delete">🗑️</button>
          </div>
        </td>
      </tr>`;
    });
    tbody.innerHTML = html;
  } catch (err) {
    tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;color:#f87171;padding:2rem;">Network Error.</td></tr>';
  }
}

function openPromoModal() {
  document.getElementById('promo-code').value = '';
  document.getElementById('promo-percent').value = '';
  document.getElementById('promo-max').value = '0';
  document.getElementById('promo-result').innerHTML = '';
  openModal('promo-modal');
}

async function savePromo() {
  const code = document.getElementById('promo-code').value.trim().toUpperCase();
  const percent = document.getElementById('promo-percent').value;
  const max = document.getElementById('promo-max').value;
  
  if (!code || !percent) return toast('Fill out code and percent.', 'err');
  
  const res = await fetch('/api/admin/promo-codes', {
    method: 'POST', headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({ code, discount_percent: percent, max_uses: max })
  });
  const data = await res.json();
  if (data.success) {
    toast('Promo code created!', 'ok');
    closeModal('promo-modal');
    loadPromosTab();
  } else {
    document.getElementById('promo-result').innerHTML = `<div class="alert alert-danger" style="margin-bottom:1rem;font-size:0.8rem;">${data.message}</div>`;
  }
}

async function togglePromo(id, btn) {
  btn.disabled = true;
  const res = await fetch(`/api/admin/promo-codes/${id}/toggle`, { method: 'PATCH' });
  const data = await res.json();
  if (data.success) {
    toast('Code toggled', 'ok');
    loadPromosTab();
  } else {
    toast(data.message, 'err');
    btn.disabled = false;
  }
}

async function deletePromo(id, codeStr) {
  if (!confirm(`Delete promo code ${codeStr}?`)) return;
  const res = await fetch(`/api/admin/promo-codes/${id}`, { method: 'DELETE' });
  const data = await res.json();
  if (data.success) {
    toast('Code deleted', 'ok');
    loadPromosTab();
  } else {
    toast(data.message, 'err');
  }
}

/* ── Chat Moderation (admin) ── */
const adminSocket = io({ transports: ['websocket','polling'] });

adminSocket.on('chat_message', (msg) => {
  const list = document.getElementById('chat-mod-list');
  if (!list) return;
  const empty = list.querySelector('[style*="No chat messages"]');
  if (empty) empty.remove();
  const el = buildAdminMsgEl(msg);
  list.appendChild(el);
  list.scrollTop = list.scrollHeight;
});

adminSocket.on('chat_delete', ({ id }) => {
  const el = document.getElementById('adminmsg-' + id);
  if (el) { el.style.opacity = '0'; el.style.transition = 'opacity 0.3s'; setTimeout(() => el.remove(), 320); }
});

function escHtmlA(str) {
  if (!str) return '';
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function buildAdminMsgEl(msg) {
  const div = document.createElement('div');
  div.className = 'chat-mod-msg';
  div.id = 'adminmsg-' + msg.id;
  const time = new Date(msg.created_at).toLocaleString('en',{day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'});
  const roleTag = msg.role === 'admin'
    ? '<span class="chat-role-tag chat-role-admin">admin</span>'
    : msg.role === 'mod'
    ? '<span class="chat-role-tag chat-role-mod">mod</span>'
    : '';
  const nameColor = msg.role === 'admin' ? 'color:#f87171;' : msg.role === 'mod' ? 'color:#fbbf24;' : '';
  const body = msg.image_url
    ? `<img src="${escHtmlA(msg.image_url)}" class="chat-mod-img" alt="img" />`
    : `<div class="chat-mod-content">${escHtmlA(msg.content)}</div>`;
  div.innerHTML = `
    <div class="chat-mod-avatar">${(msg.username||'?').slice(0,2).toUpperCase()}</div>
    <div class="chat-mod-body">
      <div class="chat-mod-meta">
        <span class="chat-mod-name" style="${nameColor}">${escHtmlA(msg.username)}</span>
        ${roleTag}
        <span style="color:var(--text-3)">${time}</span>
      </div>
      ${body}
    </div>
    <button class="chat-mod-del" onclick="adminDeleteMsg(${msg.id},this)" title="Delete">
      <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
    </button>`;
  return div;
}

async function adminDeleteMsg(id, btn) {
  btn.disabled = true;
  const r = await fetch(`/api/chat/message/${id}`, { method: 'DELETE' }).catch(() => null);
  if (!r) { btn.disabled = false; return; }
  const d = await r.json();
  if (!d.success) { btn.disabled = false; showToast(d.message || 'Error.', 'err'); }
}

async function refreshChatMod() {
  const list = document.getElementById('chat-mod-list');
  if (!list) return;
  list.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--text-3);">Loading…</div>';
  const r = await fetch('/api/chat/messages').catch(() => null);
  if (!r || !r.ok) { list.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--red);">Failed to load.</div>'; return; }
  const d = await r.json();
  if (!d.messages.length) { list.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--text-3);">No messages.</div>'; return; }
  list.innerHTML = '';
  d.messages.forEach(m => list.appendChild(buildAdminMsgEl(m)));
}
</script>
</body>
</html>
