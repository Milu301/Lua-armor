<%- include('partials/head', { title: 'Admin Panel — ' + panelName }) %>

<style>
.tab-bar { display:flex; gap:2px; padding:0 1.75rem; background:var(--bg-card); border-bottom:1px solid var(--border); position:sticky; top:53px; z-index:40; overflow-x:auto; scrollbar-width:none; }
.tab-bar::-webkit-scrollbar { display:none; }
.tab-btn { padding:0.75rem 1rem; font-size:0.8rem; font-weight:600; color:var(--text-2); background:none; border:none; cursor:pointer; border-bottom:2px solid transparent; transition:color 0.15s, border-color 0.15s; font-family:inherit; display:flex; align-items:center; gap:0.4rem; white-space:nowrap; flex-shrink:0; }
.tab-btn:hover { color:var(--text); }
.tab-btn.active { color:var(--accent); border-bottom-color:var(--accent); }
.tab-panel { display:none; animation:fadeIn 0.15s ease; }
.tab-panel.active { display:block; }
.modal-overlay { display:none; position:fixed; inset:0; z-index:1000; background:rgba(0,0,0,0.75); backdrop-filter:blur(8px); align-items:center; justify-content:center; padding:1.5rem; }
.modal-overlay.open { display:flex; animation:fadeIn 0.2s ease; }
.modal-box { background:var(--bg-card); border:1px solid var(--border-acc); border-radius:var(--rl); padding:1.75rem; width:100%; max-width:520px; box-shadow:var(--shadow-lg); animation:slideUp 0.2s ease; max-height:90vh; overflow-y:auto; }
.modal-box h2 { font-size:1rem; font-weight:700; margin-bottom:1.25rem; }
.modal-close { float:right; background:none; border:none; cursor:pointer; color:var(--text-3); font-size:1.4rem; line-height:1; padding:2px 6px; border-radius:6px; margin-top:-4px; transition:background 0.12s,color 0.12s; }
.modal-close:hover { background:var(--bg-raised); color:var(--text); }
.field-grid { display:grid; grid-template-columns:1fr 1fr; gap:0.75rem; }
.form-row { margin-bottom:0.75rem; }
@media(max-width:900px){
  .stat-grid[style*="repeat(5"] { grid-template-columns:repeat(3,1fr) !important; }
}
</style>

<div class="layout">
  <%- include('partials/sidebar', { page: 'admin' }) %>

  <div class="main">
    <!-- Topbar -->
    <div class="topbar">
      <div class="topbar-left">
        <div class="pulse-dot" style="background:var(--accent);box-shadow:0 0 0 2px rgba(139,92,246,0.2);"></div>
        <div class="topbar-title">Admin Panel</div>
        <span class="badge badge-purple" style="font-size:0.65rem;">ADMIN</span>
      </div>
      <div class="topbar-right">
        <span class="t-xs dimmed" id="stats-live"></span>
        <span id="topbar-clock" style="font-family:'JetBrains Mono',monospace;font-size:0.72rem;color:var(--text-3);background:var(--bg-raised);border:1px solid var(--border-md);border-radius:7px;padding:3px 10px;"></span>
        <a href="/dashboard" class="btn btn-sm btn-ghost">
          <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          Dashboard
        </a>
      </div>
    </div>

    <!-- Tab bar -->
    <div class="tab-bar">
      <button class="tab-btn active" onclick="switchTab('overview',this)">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1.5" stroke-width="2"/><rect x="14" y="3" width="7" height="7" rx="1.5" stroke-width="2"/><rect x="3" y="14" width="7" height="7" rx="1.5" stroke-width="2"/><rect x="14" y="14" width="7" height="7" rx="1.5" stroke-width="2"/></svg>
        Overview
      </button>
      <button class="tab-btn" onclick="switchTab('projects',this)">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
        Projects
      </button>
      <button class="tab-btn" onclick="switchTab('users',this)">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/></svg>
        Users
        <span class="sb-badge" id="users-count-badge"><%= users.length %></span>
      </button>
      <button class="tab-btn" onclick="switchTab('live',this);refreshAdminLive();">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3" stroke-width="2"/><path stroke-linecap="round" stroke-width="2" d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14M15.54 8.46a5 5 0 010 7.07M8.46 8.46a5 5 0 000 7.07"/></svg>
        Live
        <span class="sb-badge" id="live-count-badge" style="background:var(--green);display:none;">0</span>
      </button>
      <button class="tab-btn" onclick="switchTab('announcements',this)">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/></svg>
        Announcements
      </button>
      <button class="tab-btn" onclick="switchTab('settings',this)">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Settings
      </button>
    </div>

    <!-- ═══════ TAB: OVERVIEW ═══════ -->
    <div class="tab-panel active" id="tab-overview">
      <div class="content" style="max-width:1100px;">
        <div class="stat-grid" style="grid-template-columns:repeat(5,1fr);margin-bottom:1.5rem;">
          <div class="stat" style="border-top:2px solid var(--accent);">
            <div class="stat-label">Total Users</div>
            <div class="stat-val c-purple" id="ov-users"><%= stats.totalUsers %></div>
            <div class="stat-sub">registered accounts</div>
          </div>
          <div class="stat" style="border-top:2px solid var(--green);">
            <div class="stat-label">Active Today</div>
            <div class="stat-val c-green" id="ov-active"><%= stats.activeToday %></div>
            <div class="stat-sub">users reset today</div>
          </div>
          <div class="stat" style="border-top:2px solid #3b82f6;">
            <div class="stat-label">Total Resets</div>
            <div class="stat-val c-blue" id="ov-resets"><%= Number(stats.totalResets).toLocaleString() %></div>
            <div class="stat-sub">all time</div>
          </div>
          <div class="stat" style="border-top:2px solid var(--yellow);">
            <div class="stat-label">Projects</div>
            <div class="stat-val c-yellow"><%= projects.length %></div>
            <div class="stat-sub">tiers configured</div>
          </div>
          <div class="stat" style="border-top:2px solid var(--green);cursor:pointer;" onclick="switchTab('live',document.querySelector('[onclick*=\'live\']'));refreshAdminLive();" title="View live sessions">
            <div class="stat-label">Live Now</div>
            <div class="stat-val c-green" id="ov-live">—</div>
            <div class="stat-sub">accounts online</div>
          </div>
        </div>

        <!-- Recent users -->
        <div class="card">
          <div class="card-head">
            <div class="card-icon ci-green">👥</div>
            <div><div class="card-title">Recent Registrations</div><div class="card-desc">Last 10 signups</div></div>
          </div>
          <div class="admin-table-wrap">
            <table class="admin-table">
              <thead><tr><th>Username</th><th>Project</th><th>Joined</th><th>Last Login</th><th>Status</th></tr></thead>
              <tbody>
                <% users.slice(0,10).forEach(u => { %>
                <tr>
                  <td><span style="font-weight:600;"><%= u.username %></span></td>
                  <td><% if (u.project_name) { %><span class="badge badge-purple" style="font-size:0.65rem;"><%= u.project_icon %> <%= u.project_name %></span><% } else { %><span class="dimmed t-xs">—</span><% } %></td>
                  <td><span class="t-xs dimmed"><%= new Date(u.created_at).toLocaleDateString('en',{day:'numeric',month:'short',year:'2-digit'}) %></span></td>
                  <td><span class="t-xs dimmed"><%= u.last_login ? new Date(u.last_login).toLocaleDateString('en',{day:'numeric',month:'short'}) : '—' %></span></td>
                  <td><span class="badge <%= u.is_active ? 'badge-green' : 'badge-red' %>" style="font-size:0.65rem;"><%= u.is_active ? 'Active' : 'Banned' %></span></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════ TAB: PROJECTS ═══════ -->
    <div class="tab-panel" id="tab-projects">
      <div class="content" style="max-width:1100px;">
        <div class="card">
          <div class="card-head">
            <div class="card-icon ci-purple">🗂️</div>
            <div><div class="card-title">Projects / Tiers</div><div class="card-desc">Each project maps to a Luarmor project. Users are auto-assigned on registration.</div></div>
            <button class="btn btn-primary btn-sm" style="margin-left:auto;" onclick="openProjectModal()">
              <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
              Add Project
            </button>
          </div>

          <div id="projects-list" style="display:flex;flex-direction:column;gap:0.625rem;">
            <% projects.forEach(p => { %>
            <div class="admin-project-row" id="prow-<%= p.id %>">
              <div class="admin-proj-icon" style="background:<%= p.gradient %>"><%= p.icon %></div>
              <div style="flex:1;min-width:0;">
                <div style="font-size:0.85rem;font-weight:700;display:flex;align-items:center;gap:0.5rem;">
                  <%= p.name %>
                  <% if (!p.is_active) { %><span class="badge badge-red" style="font-size:0.6rem;">Disabled</span><% } %>
                </div>
                <div class="t-xs dimmed" style="margin-top:2px;"><%= p.user_count %> users · <%= p.daily_reset_limit %> resets/day · <span class="mono"><%= p.slug %></span></div>
              </div>
              <div class="t-xs mono dimmed" style="flex-shrink:0;max-width:140px;overflow:hidden;text-overflow:ellipsis;" title="<%= p.luarmor_project_id %>"><%= p.luarmor_project_id %></div>
              <div style="display:flex;gap:0.4rem;flex-shrink:0;">
                <button class="btn btn-sm btn-secondary" onclick='openProjectModal(<%- JSON.stringify(p) %>)'>Edit</button>
                <button class="btn btn-sm" style="background:var(--red-dim);border:1px solid var(--red-border);color:#f87171;" onclick="disableProject(<%= p.id %>, '<%= p.name %>')">Disable</button>
              </div>
            </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════ TAB: USERS ═══════ -->
    <div class="tab-panel" id="tab-users">
      <div class="content" style="max-width:1100px;">
        <div class="card">
          <div class="card-head">
            <div class="card-icon ci-green">👥</div>
            <div><div class="card-title">User Management</div><div class="card-desc">Edit, ban, delete users and manage their keys</div></div>
            <div style="margin-left:auto;display:flex;gap:0.5rem;align-items:center;">
              <input type="text" class="input" id="user-search" placeholder="Search username, key, Discord…" style="width:220px;font-size:0.78rem;" oninput="searchUsers()" />
            </div>
          </div>

          <div class="admin-table-wrap">
            <table class="admin-table" id="users-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Username</th>
                  <th>Luarmor Key</th>
                  <th>Project</th>
                  <th>Discord</th>
                  <th>Role</th>
                  <th>Resets</th>
                  <th>Joined</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="users-tbody">
                <% users.forEach(u => { %>
                <tr id="urow-<%= u.id %>" data-search="<%= (u.username + ' ' + u.luarmor_key + ' ' + u.discord_id).toLowerCase() %>">
                  <td class="dimmed t-xs"><%= u.id %></td>
                  <td><div style="font-weight:600;font-size:0.82rem;"><%= u.username %></div></td>
                  <td>
                    <div class="chip" style="font-size:0.68rem;max-width:140px;" onclick="copyText('<%= u.luarmor_key %>')" title="Click to copy full key">
                      <svg width="10" height="10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" stroke-width="2"/><path stroke-width="2" d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                      <%= u.luarmor_key.slice(0,16) %>…
                    </div>
                  </td>
                  <td>
                    <% if (u.project_name) { %>
                    <span class="badge badge-purple" style="font-size:0.65rem;"><%= u.project_icon %> <%= u.project_name %></span>
                    <% } else { %><span class="dimmed t-xs">None</span><% } %>
                  </td>
                  <td><span class="mono t-xs dimmed"><%= u.discord_id || '—' %></span></td>
                  <td>
                    <% if (u.role === 'admin') { %><span class="badge badge-purple" style="font-size:0.65rem;">Admin</span>
                    <% } else if (u.role === 'mod') { %><span class="badge badge-blue" style="font-size:0.65rem;">Mod</span>
                    <% } else { %><span class="badge badge-gray" style="font-size:0.65rem;">User</span><% } %>
                  </td>
                  <td><span class="t-sm"><%= u.total_resets %></span></td>
                  <td><span class="t-xs dimmed"><%= new Date(u.created_at).toLocaleDateString('en',{day:'numeric',month:'short',year:'2-digit'}) %></span></td>
                  <td>
                    <span id="ustatus-<%= u.id %>" class="badge <%= u.is_active ? 'badge-green' : 'badge-red' %>" style="font-size:0.65rem;">
                      <%= u.is_active ? 'Active' : 'Banned' %>
                    </span>
                  </td>
                  <td>
                    <div style="display:flex;gap:0.3rem;">
                      <button class="btn btn-sm btn-secondary" style="padding:3px 7px;font-size:0.7rem;" onclick='openUserModal(<%- JSON.stringify({id:u.id,username:u.username,role:u.role,project_id:u.project_id,discord_id:u.discord_id,note:u.note,is_active:u.is_active,luarmor_key:u.luarmor_key}) %>)' title="Edit">✏️</button>
                      <button class="btn btn-sm" id="ubtn-<%= u.id %>" style="padding:3px 7px;font-size:0.7rem;background:<%= u.is_active ? 'var(--red-dim)' : 'var(--green-dim)' %>;border:1px solid <%= u.is_active ? 'var(--red-border)' : 'var(--green-border)' %>;color:<%= u.is_active ? '#f87171' : '#4ade80' %>;" onclick="toggleUser(<%= u.id %>, this)" title="<%= u.is_active ? 'Ban' : 'Unban' %>"><%= u.is_active ? '🚫' : '✅' %></button>
                      <button class="btn btn-sm" style="padding:3px 7px;font-size:0.7rem;background:var(--red-dim);border:1px solid var(--red-border);color:#f87171;" onclick="deleteUser(<%= u.id %>, '<%= u.username %>')" title="Delete">🗑️</button>
                    </div>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════ TAB: LIVE SESSIONS ═══════ -->
    <div class="tab-panel" id="tab-live">
      <div class="content" style="max-width:1100px;">
        <div class="card">
          <div class="card-head">
            <div class="card-icon" style="background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.22);color:var(--green);">
              <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3" stroke-width="2"/><path stroke-linecap="round" stroke-width="2" d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14M15.54 8.46a5 5 0 010 7.07M8.46 8.46a5 5 0 000 7.07"/></svg>
            </div>
            <div>
              <div class="card-title">Live Sessions</div>
              <div class="card-desc">All users currently executing — refreshes every 8 seconds</div>
            </div>
            <div id="admin-live-badge" style="margin-left:auto;">
              <span class="badge badge-gray" style="font-size:0.72rem;">● Loading...</span>
            </div>
          </div>
          <div id="admin-live-list">
            <div class="live-sessions-empty" style="padding:2.5rem;">
              <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:var(--text-3);margin-bottom:0.5rem;"><circle cx="12" cy="12" r="10" stroke-width="1.5"/><path stroke-linecap="round" stroke-width="1.5" d="M12 8v4m0 4h.01"/></svg>
              <div style="font-size:0.82rem;color:var(--text-3);">Loading live sessions...</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════ TAB: ANNOUNCEMENTS ═══════ -->
    <div class="tab-panel" id="tab-announcements">
      <div class="content" style="max-width:800px;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">

          <!-- Post new -->
          <div class="card" style="margin-bottom:0;">
            <div class="card-head">
              <div class="card-icon ci-blue">📢</div>
              <div><div class="card-title">Post Announcement</div><div class="card-desc">Visible to all users on dashboard</div></div>
            </div>
            <div id="ann-result"></div>
            <div class="form-row"><label class="label">Title</label><input type="text" class="input" id="ann-title" placeholder="e.g. Update v2.5 released" maxlength="128"/></div>
            <div class="form-row"><label class="label">Content</label><textarea class="input" id="ann-content" rows="3" placeholder="Describe the update…" maxlength="2000" style="resize:vertical;"></textarea></div>
            <div style="display:flex;gap:0.5rem;margin-bottom:0.75rem;align-items:center;">
              <select class="input" id="ann-type" style="flex:1;"><option value="info">Info</option><option value="success">Success</option><option value="warning">Warning</option><option value="danger">Danger</option></select>
              <label style="display:flex;align-items:center;gap:0.4rem;font-size:0.78rem;color:var(--text-2);flex-shrink:0;cursor:pointer;"><input type="checkbox" id="ann-pinned" style="accent-color:var(--accent);"/> Pinned</label>
            </div>
            <button class="btn btn-primary btn-full" onclick="postAnnouncement()">Post Announcement</button>
          </div>

          <!-- Active -->
          <div class="card" style="margin-bottom:0;">
            <div class="card-head">
              <div class="card-icon ci-yellow">📋</div>
              <div><div class="card-title">Active Announcements</div></div>
            </div>
            <% if (!announcements.length) { %>
            <div class="empty-state">No announcements yet.</div>
            <% } else { %>
            <div style="display:flex;flex-direction:column;gap:0.5rem;" id="ann-list">
              <% announcements.forEach(a => { %>
              <div class="admin-ann-row announce-<%= a.type %>" id="ann-<%= a.id %>">
                <div style="flex:1;min-width:0;">
                  <div style="font-size:0.8rem;font-weight:600;display:flex;align-items:center;gap:0.35rem;">
                    <% if (a.pinned) { %><span class="badge badge-purple" style="font-size:0.58rem;">PIN</span><% } %>
                    <span class="badge badge-gray" style="font-size:0.58rem;"><%= a.type %></span>
                    <%= a.title %>
                  </div>
                  <div class="t-xs dimmed" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:2px;"><%= a.content %></div>
                </div>
                <button class="btn btn-sm" style="background:var(--red-dim);border:1px solid var(--red-border);color:#f87171;padding:3px 7px;flex-shrink:0;" onclick="deleteAnn(<%= a.id %>)">🗑️</button>
              </div>
              <% }) %>
            </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════ TAB: SETTINGS ═══════ -->
    <div class="tab-panel" id="tab-settings">
      <div class="content" style="max-width:640px;">
        <div class="card">
          <div class="card-head">
            <div class="card-icon ci-purple">⚙️</div>
            <div><div class="card-title">Panel Settings</div><div class="card-desc">Changes apply immediately without redeploying</div></div>
          </div>
          <div id="settings-result"></div>

          <div class="form-row">
            <label class="label">Panel Name</label>
            <input type="text" class="input" id="s-panel-name" value="<%= settings.panel_name || panelName %>" maxlength="64" placeholder="LuarmorHub"/>
          </div>

          <div class="form-row">
            <label class="label">Panel Logo URL</label>
            <div style="display:flex;gap:0.5rem;align-items:center;">
              <input type="text" class="input" id="s-panel-logo" value="<%= settings.panel_logo || panelLogo %>" placeholder="https://…" oninput="previewLogo(this.value)"/>
              <img id="logo-preview" src="<%= settings.panel_logo || panelLogo %>" style="width:36px;height:36px;border-radius:8px;object-fit:cover;border:1px solid var(--border-md);flex-shrink:0;" onerror="this.style.display='none'" />
            </div>
            <div class="input-hint">Direct image URL (Discord CDN, Imgur, etc.)</div>
          </div>

          <div class="form-row">
            <label class="label">Discord Server URL</label>
            <input type="text" class="input" id="s-discord-url" value="<%= settings.discord_url || discordUrl %>" placeholder="https://discord.gg/…"/>
          </div>

          <button class="btn btn-primary" onclick="saveSettings()" style="margin-top:0.5rem;">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Save Settings
          </button>
        </div>
      </div>
    </div>

  </div><!-- /main -->
</div><!-- /layout -->

<!-- ═══ PROJECT MODAL ═══ -->
<div class="modal-overlay" id="project-modal">
  <div class="modal-box">
    <button class="modal-close" onclick="closeModal('project-modal')">×</button>
    <h2 id="pm-title">Add Project</h2>
    <input type="hidden" id="pm-id" value="" />
    <div id="pm-result"></div>

    <div class="field-grid">
      <div class="form-row"><label class="label">Project Name *</label><input type="text" class="input" id="pm-name" placeholder="Premium" maxlength="64"/></div>
      <div class="form-row"><label class="label">Icon (emoji)</label><input type="text" class="input" id="pm-icon" placeholder="⭐" maxlength="8" style="font-size:1.2rem;"/></div>
    </div>
    <div class="form-row"><label class="label">Luarmor Project ID *</label><input type="text" class="input mono" id="pm-pid" placeholder="your_project_id" /></div>
    <div class="form-row"><label class="label">Luarmor API Key *</label><input type="text" class="input mono" id="pm-pkey" placeholder="your_api_key" /></div>
    <div class="field-grid">
      <div class="form-row"><label class="label">Daily Reset Limit</label><input type="number" class="input" id="pm-limit" value="3" min="1" max="999"/></div>
      <div class="form-row"><label class="label">Accent Color</label><input type="color" class="input" id="pm-color" value="#8b5cf6" style="height:40px;padding:4px;" oninput="updateGradientPreview()"/></div>
    </div>
    <div class="form-row"><label class="label">Gradient CSS <span class="dimmed">(auto-filled from color)</span></label><input type="text" class="input mono" id="pm-gradient" placeholder="linear-gradient(135deg,#8b5cf6,#6366f1)"/></div>
    <div class="form-row"><label class="label">Description</label><input type="text" class="input" id="pm-desc" placeholder="Short description shown on register page" maxlength="200"/></div>
    <div style="display:flex;gap:0.5rem;margin-top:0.5rem;">
      <button class="btn btn-primary" onclick="saveProject()">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        Save Project
      </button>
      <button class="btn btn-ghost" onclick="closeModal('project-modal')">Cancel</button>
    </div>
  </div>
</div>

<!-- ═══ USER EDIT MODAL ═══ -->
<div class="modal-overlay" id="user-modal">
  <div class="modal-box">
    <button class="modal-close" onclick="closeModal('user-modal')">×</button>
    <h2>Edit User — <span id="um-name" style="color:var(--accent);"></span></h2>
    <input type="hidden" id="um-id" />
    <div id="um-result"></div>

    <div class="form-row">
      <label class="label">Full Luarmor Key</label>
      <div class="chip w-full" id="um-key" style="word-break:break-all;user-select:all;cursor:text;justify-content:flex-start;font-size:0.72rem;padding:0.5rem 0.75rem;" onclick="copyText(document.getElementById('um-key').dataset.key)"></div>
    </div>

    <div class="field-grid">
      <div class="form-row">
        <label class="label">Username</label>
        <input type="text" class="input" id="um-username" maxlength="32"/>
      </div>
      <div class="form-row">
        <label class="label">Role</label>
        <select class="input" id="um-role">
          <option value="user">User</option>
          <option value="mod">Mod</option>
          <option value="admin">Admin</option>
        </select>
      </div>
    </div>

    <div class="form-row">
      <label class="label">Project</label>
      <select class="input" id="um-project">
        <option value="">None</option>
        <% projects.forEach(p => { %>
        <option value="<%= p.id %>"><%= p.icon %> <%= p.name %></option>
        <% }) %>
      </select>
    </div>

    <div class="field-grid">
      <div class="form-row">
        <label class="label">Discord ID</label>
        <input type="text" class="input mono" id="um-discord" placeholder="123456789012345678" maxlength="20"/>
      </div>
      <div class="form-row">
        <label class="label">Note</label>
        <input type="text" class="input" id="um-note" placeholder="Custom note" maxlength="100"/>
      </div>
    </div>

    <div class="form-row">
      <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;font-size:0.82rem;">
        <input type="checkbox" id="um-active" style="accent-color:var(--accent);width:16px;height:16px;"/>
        Account Active (uncheck to ban)
      </label>
    </div>

    <!-- Change password -->
    <details style="margin-top:0.5rem;">
      <summary style="cursor:pointer;font-size:0.8rem;font-weight:600;color:var(--text-2);padding:0.5rem 0;">Change Password</summary>
      <div style="margin-top:0.5rem;">
        <div id="um-pw-result"></div>
        <input type="password" class="input" id="um-new-pw" placeholder="New password (min 8 chars)" style="margin-bottom:0.5rem;"/>
        <button class="btn btn-secondary btn-sm" onclick="changeUserPw()">Set Password</button>
      </div>
    </details>

    <div style="display:flex;gap:0.5rem;margin-top:1rem;flex-wrap:wrap;">
      <button class="btn btn-primary" onclick="saveUser()">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        Save Changes
      </button>
      <button class="btn btn-secondary" onclick="forceResetHwid()">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
        Force Reset HWID
      </button>
      <button class="btn btn-ghost" onclick="closeModal('user-modal')">Cancel</button>
    </div>
  </div>
</div>

<div class="toast-wrap" id="toasts"></div>

<script>
/* ── Tabs ── */
function switchTab(name, btn) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  btn.classList.add('active');
}

/* ── Toast ── */
function toast(msg, type = 'info') {
  const icons = { ok:'✅', err:'❌', warn:'⚠️', info:'ℹ️' };
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.innerHTML = `<span>${icons[type]||'ℹ️'}</span><span>${msg}</span>`;
  document.getElementById('toasts').appendChild(el);
  setTimeout(() => { el.style.animation='toastOut 0.3s forwards'; setTimeout(()=>el.remove(),320); }, 4000);
}

/* ── Modal helpers ── */
function openModal(id)  { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

/* ── Copy ── */
function copyText(txt) {
  navigator.clipboard.writeText(txt).then(() => toast('Copied!', 'ok'));
}

/* ── Projects ── */
function openProjectModal(proj) {
  document.getElementById('pm-id').value      = proj ? proj.id : '';
  document.getElementById('pm-title').textContent = proj ? 'Edit Project' : 'Add Project';
  document.getElementById('pm-name').value    = proj ? proj.name : '';
  document.getElementById('pm-icon').value    = proj ? proj.icon : '⚡';
  document.getElementById('pm-pid').value     = proj ? proj.luarmor_project_id : '';
  document.getElementById('pm-pkey').value    = proj ? proj.luarmor_api_key : '';
  document.getElementById('pm-limit').value   = proj ? proj.daily_reset_limit : 3;
  document.getElementById('pm-color').value   = proj ? (proj.color || '#8b5cf6') : '#8b5cf6';
  document.getElementById('pm-gradient').value= proj ? proj.gradient : 'linear-gradient(135deg,#8b5cf6,#6366f1)';
  document.getElementById('pm-desc').value    = proj ? (proj.description || '') : '';
  document.getElementById('pm-result').innerHTML = '';
  openModal('project-modal');
}

function updateGradientPreview() {
  const c = document.getElementById('pm-color').value;
  document.getElementById('pm-gradient').value = `linear-gradient(135deg,${c},${c}cc)`;
}

async function saveProject() {
  const id   = document.getElementById('pm-id').value;
  const body = {
    name:                document.getElementById('pm-name').value.trim(),
    luarmor_project_id:  document.getElementById('pm-pid').value.trim(),
    luarmor_api_key:     document.getElementById('pm-pkey').value.trim(),
    daily_reset_limit:   document.getElementById('pm-limit').value,
    color:               document.getElementById('pm-color').value,
    gradient:            document.getElementById('pm-gradient').value.trim(),
    icon:                document.getElementById('pm-icon').value.trim() || '⚡',
    description:         document.getElementById('pm-desc').value.trim(),
  };
  const url    = id ? `/api/admin/project/${id}` : '/api/admin/project';
  const method = id ? 'PATCH' : 'POST';
  const r = await fetch(url, { method, headers:{'Content-Type':'application/json'}, body:JSON.stringify(body) });
  const d = await r.json();
  const res = document.getElementById('pm-result');
  if (d.success) {
    res.innerHTML = `<div class="alert alert-success" style="margin-bottom:.75rem;font-size:.78rem;">✓ ${d.message}</div>`;
    toast(d.message, 'ok');
    setTimeout(() => location.reload(), 1200);
  } else {
    res.innerHTML = `<div class="alert alert-danger" style="margin-bottom:.75rem;font-size:.78rem;">${d.message}</div>`;
    toast(d.message, 'err');
  }
}

async function disableProject(id, name) {
  if (!confirm(`Disable project "${name}"? Users will still exist but the tier will be inactive.`)) return;
  const r = await fetch(`/api/admin/project/${id}`, { method:'DELETE' });
  const d = await r.json();
  if (d.success) { toast('Project disabled.', 'warn'); setTimeout(()=>location.reload(), 800); }
  else toast(d.message, 'err');
}

/* ── Users ── */
function searchUsers() {
  const q = document.getElementById('user-search').value.toLowerCase();
  document.querySelectorAll('#users-tbody tr').forEach(row => {
    row.style.display = (row.dataset.search || '').includes(q) ? '' : 'none';
  });
}

function openUserModal(u) {
  document.getElementById('um-id').value          = u.id;
  document.getElementById('um-name').textContent  = u.username;
  document.getElementById('um-username').value    = u.username;
  document.getElementById('um-role').value        = u.role || 'user';
  document.getElementById('um-project').value     = u.project_id || '';
  document.getElementById('um-discord').value     = u.discord_id || '';
  document.getElementById('um-note').value        = u.note || '';
  document.getElementById('um-active').checked    = !!u.is_active;
  const keyEl = document.getElementById('um-key');
  keyEl.textContent = u.luarmor_key;
  keyEl.dataset.key = u.luarmor_key;
  document.getElementById('um-result').innerHTML  = '';
  document.getElementById('um-pw-result').innerHTML = '';
  document.getElementById('um-new-pw').value      = '';
  openModal('user-modal');
}

async function saveUser() {
  const id = document.getElementById('um-id').value;
  const body = {
    username:   document.getElementById('um-username').value.trim(),
    role:       document.getElementById('um-role').value,
    project_id: document.getElementById('um-project').value || null,
    discord_id: document.getElementById('um-discord').value.trim(),
    note:       document.getElementById('um-note').value.trim(),
    is_active:  document.getElementById('um-active').checked,
  };
  const r = await fetch(`/api/admin/user/${id}`, { method:'PATCH', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body) });
  const d = await r.json();
  const res = document.getElementById('um-result');
  if (d.success) {
    res.innerHTML = `<div class="alert alert-success" style="margin-bottom:.75rem;font-size:.78rem;">✓ ${d.message}</div>`;
    toast(d.message, 'ok');
    setTimeout(() => location.reload(), 1000);
  } else {
    res.innerHTML = `<div class="alert alert-danger" style="margin-bottom:.75rem;font-size:.78rem;">${d.message}</div>`;
    toast(d.message, 'err');
  }
}

async function changeUserPw() {
  const id  = document.getElementById('um-id').value;
  const pwd = document.getElementById('um-new-pw').value.trim();
  const res = document.getElementById('um-pw-result');
  if (pwd.length < 8) { res.innerHTML = '<div class="alert alert-danger" style="font-size:.75rem;margin-bottom:.5rem;">Min 8 characters.</div>'; return; }
  const r = await fetch(`/api/admin/user/${id}/change-password`, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({password:pwd}) });
  const d = await r.json();
  res.innerHTML = d.success
    ? `<div class="alert alert-success" style="font-size:.75rem;margin-bottom:.5rem;">✓ ${d.message}</div>`
    : `<div class="alert alert-danger" style="font-size:.75rem;margin-bottom:.5rem;">${d.message}</div>`;
  toast(d.message, d.success ? 'ok' : 'err');
}

async function forceResetHwid() {
  const id   = document.getElementById('um-id').value;
  const name = document.getElementById('um-name').textContent;
  if (!confirm(`Force reset HWID for ${name}?`)) return;
  const r = await fetch(`/api/admin/user/${id}/force-reset`, { method:'POST' });
  const d = await r.json();
  toast(d.message, d.success ? 'ok' : 'err');
  document.getElementById('um-result').innerHTML = d.success
    ? `<div class="alert alert-success" style="margin-bottom:.75rem;font-size:.78rem;">✓ ${d.message}</div>`
    : `<div class="alert alert-danger" style="margin-bottom:.75rem;font-size:.78rem;">${d.message}</div>`;
}

async function toggleUser(id, btn) {
  const r = await fetch('/api/admin/toggle-user', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({user_id:id}) });
  const d = await r.json();
  if (d.success) {
    const badge = document.getElementById('ustatus-' + id);
    if (d.active) {
      badge.className = 'badge badge-green'; badge.style.fontSize='0.65rem'; badge.textContent='Active';
      btn.style.background='var(--red-dim)'; btn.style.borderColor='var(--red-border)'; btn.style.color='#f87171'; btn.textContent='🚫';
      btn.title = 'Ban';
    } else {
      badge.className = 'badge badge-red'; badge.style.fontSize='0.65rem'; badge.textContent='Banned';
      btn.style.background='var(--green-dim)'; btn.style.borderColor='var(--green-border)'; btn.style.color='#4ade80'; btn.textContent='✅';
      btn.title = 'Unban';
    }
    toast(d.active ? 'User unbanned.' : 'User banned.', d.active ? 'ok' : 'warn');
  } else toast(d.message, 'err');
}

async function deleteUser(id, name) {
  if (!confirm(`Permanently delete user "${name}"? This cannot be undone.`)) return;
  const r = await fetch(`/api/admin/user/${id}`, { method:'DELETE' });
  const d = await r.json();
  if (d.success) {
    const row = document.getElementById('urow-' + id);
    if (row) { row.style.opacity='0'; row.style.transition='opacity 0.3s'; setTimeout(()=>row.remove(),320); }
    toast('User deleted.', 'ok');
  } else toast(d.message, 'err');
}

/* ── Announcements ── */
async function postAnnouncement() {
  const title   = document.getElementById('ann-title').value.trim();
  const content = document.getElementById('ann-content').value.trim();
  const type    = document.getElementById('ann-type').value;
  const pinned  = document.getElementById('ann-pinned').checked;
  const res     = document.getElementById('ann-result');
  if (!title || !content) { toast('Title and content required.','warn'); return; }
  const r = await fetch('/api/admin/announcement', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({title,content,type,pinned:String(pinned)}) });
  const d = await r.json();
  if (d.success) {
    res.innerHTML = `<div class="alert alert-success" style="margin-bottom:.75rem;font-size:.78rem;">✓ Posted. Reload to see it in the list.</div>`;
    document.getElementById('ann-title').value = '';
    document.getElementById('ann-content').value = '';
    toast('Announcement posted!', 'ok');
  } else {
    res.innerHTML = `<div class="alert alert-danger" style="margin-bottom:.75rem;font-size:.78rem;">${d.message}</div>`;
    toast(d.message, 'err');
  }
}

async function deleteAnn(id) {
  if (!confirm('Delete this announcement?')) return;
  const r = await fetch(`/api/admin/announcement/${id}`, { method:'DELETE' });
  const d = await r.json();
  if (d.success) {
    const el = document.getElementById('ann-' + id);
    if (el) { el.style.animation='fadeOut 0.3s forwards'; setTimeout(()=>el.remove(),320); }
    toast('Announcement removed.', 'ok');
  } else toast('Failed.', 'err');
}

/* ── Settings ── */
function previewLogo(url) {
  const img = document.getElementById('logo-preview');
  img.src = url;
  img.style.display = '';
}

async function saveSettings() {
  const body = {
    panel_name:  document.getElementById('s-panel-name').value.trim(),
    panel_logo:  document.getElementById('s-panel-logo').value.trim(),
    discord_url: document.getElementById('s-discord-url').value.trim(),
  };
  const res = document.getElementById('settings-result');
  const r = await fetch('/api/admin/settings', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body) });
  const d = await r.json();
  if (d.success) {
    res.innerHTML = `<div class="alert alert-success" style="margin-bottom:.75rem;font-size:.78rem;">✓ Settings saved and applied live.</div>`;
    toast('Settings saved!', 'ok');
  } else {
    res.innerHTML = `<div class="alert alert-danger" style="margin-bottom:.75rem;font-size:.78rem;">${d.message}</div>`;
    toast(d.message, 'err');
  }
}

/* ── Live stats refresh ── */
async function refreshStats() {
  try {
    const r = await fetch('/api/admin/stats');
    const d = await r.json();
    if (!d.success) return;
    document.getElementById('ov-users').textContent  = d.stats.totalUsers;
    document.getElementById('ov-active').textContent = d.stats.activeToday;
    document.getElementById('ov-resets').textContent = Number(d.stats.totalResets).toLocaleString();
    document.getElementById('stats-live').textContent = 'Updated ' + new Date().toLocaleTimeString();
  } catch {}
}
setInterval(refreshStats, 30000);

/* ── Admin Live Sessions ── */
function renderAdminInv(inventory) {
  const inv = inventory && typeof inventory === 'object' ? inventory : {};
  const entries = Object.entries(inv).sort((a,b) => b[1]-a[1]);
  if (!entries.length) return '';
  const shown = entries.slice(0,12);
  const extra = entries.length - 12;
  return `<div class="live-inv-table">
    <div class="live-inv-table-header"><span>Item</span><span>Qty</span></div>
    ${shown.map(([n,c]) => `<div class="live-inv-row"><span class="live-inv-name">${n}</span><span class="live-inv-count">${Number(c).toLocaleString()}</span></div>`).join('')}
    ${extra > 0 ? `<div class="live-inv-more">+${extra} more items</div>` : ''}
  </div>`;
}

async function adminKickSession(robloxUserId, btn) {
  btn.disabled = true; btn.textContent = '...';
  try {
    const r = await fetch('/api/kick-session', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({roblox_user_id:robloxUserId}) });
    const d = await r.json();
    if (d.success) { btn.textContent = '✓ Kicked'; toast('Kick requested — player will disconnect within ~10s.', 'ok'); setTimeout(()=>refreshAdminLive(),2000); }
    else { btn.disabled = false; btn.textContent = 'Kick'; toast(d.message, 'err'); }
  } catch { btn.disabled = false; btn.textContent = 'Kick'; }
}

async function refreshAdminLive() {
  try {
    const r = await fetch('/api/admin/live-sessions');
    const d = await r.json();
    const sessions = d.sessions || [];
    const badge = document.getElementById('live-count-badge');
    const adminBadge = document.getElementById('admin-live-badge');
    const list = document.getElementById('admin-live-list');
    if (!list) return;

    if (badge) {
      badge.textContent = sessions.length;
      badge.style.display = sessions.length > 0 ? '' : 'none';
    }
    const ovLive = document.getElementById('ov-live');
    if (ovLive) ovLive.textContent = sessions.length;
    if (adminBadge) {
      adminBadge.innerHTML = sessions.length > 0
        ? `<span class="badge badge-green" style="font-size:0.72rem;">● ${sessions.length} account${sessions.length !== 1 ? 's' : ''} online</span>`
        : `<span class="badge badge-gray" style="font-size:0.72rem;">● No active sessions</span>`;
    }

    if (sessions.length === 0) {
      list.innerHTML = `<div class="live-sessions-empty" style="padding:2.5rem;">
        <svg width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:var(--text-3);margin-bottom:0.6rem;"><circle cx="12" cy="12" r="10" stroke-width="1.5"/><path stroke-linecap="round" stroke-width="1.5" d="M12 8v4m0 4h.01"/></svg>
        <div style="font-size:0.85rem;color:var(--text-2);font-weight:600;">No accounts online</div>
        <div style="font-size:0.72rem;color:var(--text-3);margin-top:3px;">Will update automatically when users execute the script</div>
      </div>`;
      return;
    }

    /* Separate registered users from guests */
    const grouped = {};
    const guests  = [];
    sessions.forEach(s => {
      if (s.is_guest) {
        guests.push(s);
      } else {
        const key = s.username || '?';
        if (!grouped[key]) grouped[key] = [];
        grouped[key].push(s);
      }
    });

    const renderSession = s => `
      <div class="admin-live-session">
        <div class="admin-live-session-top">
          <div class="admin-live-session-info">
            <span class="admin-live-roblox-name">${s.roblox_username || '—'}</span>
            ${s.place_name ? `<span class="live-session-game">🎮 ${s.place_name}</span>` : ''}
            <span class="live-session-id">ID: ${s.roblox_user_id}</span>
          </div>
          <button class="btn-kick" onclick="adminKickSession('${s.roblox_user_id}',this)" title="Kick ${s.roblox_username || ''}">
            <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
            Kick
          </button>
        </div>
        ${renderAdminInv(s.inventory)}
      </div>`;

    const registeredHtml = Object.entries(grouped).map(([username, accs]) => `
      <div class="admin-live-group">
        <div class="admin-live-group-header">
          <span class="pulse-dot" style="width:8px;height:8px;flex-shrink:0;"></span>
          <span class="admin-live-group-name">${username}</span>
          <span class="badge badge-green" style="font-size:0.62rem;">${accs.length} account${accs.length !== 1 ? 's' : ''}</span>
        </div>
        <div class="admin-live-accounts">${accs.map(renderSession).join('')}</div>
      </div>`).join('');

    const guestsHtml = guests.length === 0 ? '' : `
      <div class="admin-live-group">
        <div class="admin-live-group-header" style="background:rgba(251,146,60,0.06);">
          <span class="pulse-dot" style="width:8px;height:8px;flex-shrink:0;background:var(--yellow);box-shadow:0 0 0 3px rgba(251,146,60,0.18);"></span>
          <span class="admin-live-group-name" style="color:var(--yellow);">Guests</span>
          <span class="badge" style="background:rgba(251,146,60,0.18);color:var(--yellow);font-size:0.62rem;">${guests.length} sin cuenta</span>
          <span style="font-size:0.68rem;color:var(--text-3);margin-left:auto;">ejecutaron el script pero no están registrados</span>
        </div>
        <div class="admin-live-accounts">${guests.map(renderSession).join('')}</div>
      </div>`;

    list.innerHTML = registeredHtml + guestsHtml;
  } catch(e) {}
}

setInterval(refreshAdminLive, 8000);
refreshAdminLive(); // populate on load

/* ─── Live Clock ─── */
(function() {
  const cl = document.getElementById('topbar-clock');
  function tick() {
    if (!cl) return;
    const n = new Date();
    const pad = v => String(v).padStart(2,'0');
    cl.textContent = pad(n.getUTCHours())+':'+pad(n.getUTCMinutes())+':'+pad(n.getUTCSeconds())+' UTC';
  }
  tick(); setInterval(tick, 1000);
})();

/* ─── Count-up for admin stats ─── */
(function() {
  const targets = [
    { id: 'ov-users',  val: <%= stats.totalUsers %> },
    { id: 'ov-active', val: <%= stats.activeToday %> },
    { id: 'ov-resets', val: <%= Number(stats.totalResets) %> },
  ];
  targets.forEach(({ id, val }) => {
    const el = document.getElementById(id);
    if (!el || !window.countUp) return;
    countUp(el, val, 1200);
  });
})();

/* ─── Subtle Particle Canvas for Admin ─── */
(function() {
  const canvas = document.createElement('canvas');
  canvas.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:-1;opacity:0.3;';
  document.body.insertBefore(canvas, document.body.firstChild);
  const ctx = canvas.getContext('2d');
  let W, H;
  function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
  resize();
  window.addEventListener('resize', resize, { passive: true });
  const COLS = ['rgba(147,51,234,', 'rgba(99,102,241,', 'rgba(255,255,255,'];
  const pts = Array.from({ length: 40 }, () => ({
    x: Math.random() * 1920, y: Math.random() * 1080,
    r: 0.3 + Math.random() * 1.2,
    vx: (Math.random() - 0.5) * 0.2, vy: -0.06 - Math.random() * 0.15,
    a: 0.05 + Math.random() * 0.22, c: COLS[Math.floor(Math.random() * COLS.length)]
  }));
  (function loop() {
    ctx.clearRect(0, 0, W, H);
    pts.forEach(p => {
      p.x += p.vx; p.y += p.vy;
      if (p.y < -4 || p.x < -4 || p.x > W + 4) { p.x = Math.random() * W; p.y = H + 4; }
      ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = p.c + p.a + ')'; ctx.fill();
    });
    requestAnimationFrame(loop);
  })();
})();
</script>
</body>
</html>
