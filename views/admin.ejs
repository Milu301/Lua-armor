<script>
/* ── Tabs ── */
function switchTab(name, btn) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  btn.classList.add('active');
}

async function updateBug(id, data) {
  const res  = await fetch('/api/admin/bug-reports/' + id, {
    method:'PATCH', headers:{'Content-Type':'application/json'}, body:JSON.stringify(data)
  });
  const json = await res.json();
  if (!json.success) toast(json.message, 'err');
}

/* ── Toast ── */
function toast(msg, type = 'info') {
  const icons = { ok:'✅', err:'❌', warn:'⚠️', info:'ℹ️' };
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.innerHTML = `<span>${icons[type]||'ℹ️'}</span><span>${msg}</span>`;
  document.getElementById('toasts').appendChild(el);
  setTimeout(() => { el.style.animation='toastOut 0.3s forwards'; setTimeout(()=>el.remove(),320); }, 4000);
}

/* ── Modal helpers ── */
function openModal(id)  { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

/* ── Copy ── */
function copyText(txt) {
  navigator.clipboard.writeText(txt).then(() => toast('Copied!', 'ok'));
}

/* ── Projects ── */
async function openProjectModal(projId) {
  // Reset modal first and open immediately for snappy UX
  document.getElementById('pm-id').value       = projId || '';
  document.getElementById('pm-title').textContent = projId ? 'Edit Project' : 'Add Project';
  document.getElementById('pm-name').value     = '';
  document.getElementById('pm-icon').value     = '⚡';
  document.getElementById('pm-pid').value      = '';
  document.getElementById('pm-pkey').value     = '';
  document.getElementById('pm-limit').value    = 3;
  document.getElementById('pm-color').value    = '#8b5cf6';
  document.getElementById('pm-gradient').value = 'linear-gradient(135deg,#8b5cf6,#6366f1)';
  document.getElementById('pm-desc').value     = '';
  document.getElementById('pm-free').checked   = false;
  document.getElementById('pm-result').innerHTML = projId
    ? '<div class="alert alert-info" style="margin-bottom:.5rem;font-size:.75rem;">Loading…</div>' : '';
  openModal('project-modal');

  if (!projId) return; // New project — nothing to fetch

  try {
    const r = await fetch(`/api/admin/project/${projId}`);
    const d = await r.json();
    if (!d.success) { document.getElementById('pm-result').innerHTML = `<div class="alert alert-danger" style="font-size:.75rem;">Failed to load project data.</div>`; return; }
    const proj = d.project;
    document.getElementById('pm-name').value     = proj.name || '';
    document.getElementById('pm-icon').value     = proj.icon || '⚡';
    document.getElementById('pm-pid').value      = proj.luarmor_project_id || '';
    document.getElementById('pm-pkey').value     = proj.luarmor_api_key || '';
    document.getElementById('pm-limit').value    = proj.daily_reset_limit || 3;
    document.getElementById('pm-color').value    = proj.color || '#8b5cf6';
    document.getElementById('pm-gradient').value = proj.gradient || 'linear-gradient(135deg,#8b5cf6,#6366f1)';
    document.getElementById('pm-desc').value     = proj.description || '';
    document.getElementById('pm-free').checked   = !!proj.is_free;
    document.getElementById('pm-result').innerHTML = '';
  } catch {
    document.getElementById('pm-result').innerHTML = '<div class="alert alert-danger" style="font-size:.75rem;">Network error loading project.</div>';
  }
}

function updateGradientPreview() {
  const c = document.getElementById('pm-color').value;
  document.getElementById('pm-gradient').value = `linear-gradient(135deg,${c},${c}cc)`;
}

async function saveProject() {
  const id   = document.getElementById('pm-id').value;
  const body = {
    name:                document.getElementById('pm-name').value.trim(),
    luarmor_project_id:  document.getElementById('pm-pid').value.trim(),
    luarmor_api_key:     document.getElementById('pm-pkey').value.trim(),
    daily_reset_limit:   document.getElementById('pm-limit').value,
    color:               document.getElementById('pm-color').value,
    gradient:            document.getElementById('pm-gradient').value.trim(),
    icon:                document.getElementById('pm-icon').value.trim() || '⚡',
    description:         document.getElementById('pm-desc').value.trim(),
    is_free:             document.getElementById('pm-free').checked,
  };
  const url    = id ? `/api/admin/project/${id}` : '/api/admin/project';
  const method = id ? 'PATCH' : 'POST';
  const r = await fetch(url, { method, headers:{'Content-Type':'application/json'}, body:JSON.stringify(body) });
  const d = await r.json();
  const res = document.getElementById('pm-result');
  if (d.success) {
    res.innerHTML = `<div class="alert alert-success" style="margin-bottom:.75rem;font-size:.78rem;">✓ ${d.message}</div>`;
    toast(d.message, 'ok');
    setTimeout(() => location.reload(), 1200);
  } else {
    res.innerHTML = `<div class="alert alert-danger" style="margin-bottom:.75rem;font-size:.78rem;">${d.message}</div>`;
    toast(d.message, 'err');
  }
}

async function disableProject(id, name) {
  if (!confirm(`Disable project "${name}"? Users will still exist but the tier will be inactive.`)) return;
  const r = await fetch(`/api/admin/project/${id}`, { method:'DELETE' });
  const d = await r.json();
  if (d.success) { toast('Project disabled.', 'warn'); setTimeout(()=>location.reload(), 800); }
  else toast(d.message, 'err');
}

async function deleteProject(id, name) {
  if (!confirm(`WARNING: Completely delete project "${name}"? This action cannot be undone and will detach all users from this project.`)) return;
  const r = await fetch(`/api/admin/project/${id}/hard`, { method:'DELETE' });
  const d = await r.json();
  if (d.success) { toast('Project deleted permanently.', 'ok'); setTimeout(()=>location.reload(), 800); }
  else toast(d.message, 'err');
}

/* ── Users ── */
function searchUsers() {
  const q = document.getElementById('user-search').value.toLowerCase();
  document.querySelectorAll('#users-tbody tr').forEach(row => {
    row.style.display = (row.dataset.search || '').includes(q) ? '' : 'none';
  });
}

async function openUserModal(userId) {
  // Reset and open immediately
  document.getElementById('um-id').value           = userId;
  document.getElementById('um-name').textContent   = '…';
  document.getElementById('um-username').value     = '';
  document.getElementById('um-role').value         = 'user';
  document.getElementById('um-project').value      = '';
  document.getElementById('um-discord').value      = '';
  document.getElementById('um-note').value         = '';
  document.getElementById('um-active').checked     = true;
  document.getElementById('um-verified').checked   = false;
  document.getElementById('um-result').innerHTML   = '<div class="alert alert-info" style="margin-bottom:.5rem;font-size:.75rem;">Loading…</div>';
  document.getElementById('um-pw-result').innerHTML = '';
  document.getElementById('um-new-pw').value       = '';
  const keyEl = document.getElementById('um-key');
  keyEl.textContent = '…'; keyEl.dataset.key = '';
  openModal('user-modal');

  try {
    const r = await fetch(`/api/admin/user/${userId}`);
    const d = await r.json();
    if (!d.success) { document.getElementById('um-result').innerHTML = '<div class="alert alert-danger" style="font-size:.75rem;">Failed to load user.</div>'; return; }
    const u = d.user;
    document.getElementById('um-id').value          = u.id;
    document.getElementById('um-name').textContent  = u.username;
    document.getElementById('um-username').value    = u.username;
    document.getElementById('um-role').value        = u.role || 'user';
    document.getElementById('um-project').value     = u.project_id || '';
    document.getElementById('um-discord').value     = u.discord_id || '';
    document.getElementById('um-note').value        = u.note || '';
    document.getElementById('um-active').checked    = !!u.is_active;
    document.getElementById('um-verified').checked  = !!u.is_verified_seller;
    keyEl.textContent = u.luarmor_key || '—';
    keyEl.dataset.key = u.luarmor_key || '';
    document.getElementById('um-result').innerHTML  = '';
  } catch {
    document.getElementById('um-result').innerHTML = '<div class="alert alert-danger" style="font-size:.75rem;">Network error loading user.</div>';
  }
}

/* Copy user key securely via API fetch */
async function copyUserKey(userId, el) {
  try {
    const r = await fetch(`/api/admin/user/${userId}`);
    const d = await r.json();
    if (d.success && d.user.luarmor_key) {
      await navigator.clipboard.writeText(d.user.luarmor_key);
      toast('Key copied!', 'ok');
    } else { toast('Could not fetch key.', 'err'); }
  } catch { toast('Copy failed.', 'err'); }
}

async function saveUser() {
  const id = document.getElementById('um-id').value;
  const body = {
    username:   document.getElementById('um-username').value.trim(),
    role:       document.getElementById('um-role').value,
    project_id: document.getElementById('um-project').value || null,
    discord_id: document.getElementById('um-discord').value.trim(),
    note:       document.getElementById('um-note').value.trim(),
    is_active:  document.getElementById('um-active').checked,
    is_verified_seller: document.getElementById('um-verified').checked,
  };
  const r = await fetch(`/api/admin/user/${id}`, { method:'PATCH', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body) });
  const d = await r.json();
  const res = document.getElementById('um-result');
  if (d.success) {
    res.innerHTML = `<div class="alert alert-success" style="margin-bottom:.75rem;font-size:.78rem;">✓ ${d.message}</div>`;
    toast(d.message, 'ok');
    setTimeout(() => location.reload(), 1000);
  } else {
    res.innerHTML = `<div class="alert alert-danger" style="margin-bottom:.75rem;font-size:.78rem;">${d.message}</div>`;
    toast(d.message, 'err');
  }
}

async function changeUserPw() {
  const id  = document.getElementById('um-id').value;
  const pwd = document.getElementById('um-new-pw').value.trim();
  const res = document.getElementById('um-pw-result');
  if (pwd.length < 8) { res.innerHTML = '<div class="alert alert-danger" style="font-size:.75rem;margin-bottom:.5rem;">Min 8 characters.</div>'; return; }
  const r = await fetch(`/api/admin/user/${id}/change-password`, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({password:pwd}) });
  const d = await r.json();
  res.innerHTML = d.success
    ? `<div class="alert alert-success" style="font-size:.75rem;margin-bottom:.5rem;">✓ ${d.message}</div>`
    : `<div class="alert alert-danger" style="font-size:.75rem;margin-bottom:.5rem;">${d.message}</div>`;
  toast(d.message, d.success ? 'ok' : 'err');
}

async function forceResetHwid() {
  const id   = document.getElementById('um-id').value;
  const name = document.getElementById('um-name').textContent;
  if (!confirm(`Force reset HWID for ${name}?`)) return;
  const r = await fetch(`/api/admin/user/${id}/force-reset`, { method:'POST' });
  const d = await r.json();
  toast(d.message, d.success ? 'ok' : 'err');
  document.getElementById('um-result').innerHTML = d.success
    ? `<div class="alert alert-success" style="margin-bottom:.75rem;font-size:.78rem;">✓ ${d.message}</div>`
    : `<div class="alert alert-danger" style="margin-bottom:.75rem;font-size:.78rem;">${d.message}</div>`;
}

async function toggleUser(id, btn) {
  const r = await fetch('/api/admin/toggle-user', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({user_id:id}) });
  const d = await r.json();
  if (d.success) {
    const badge = document.getElementById('ustatus-' + id);
    if (d.active) {
      badge.className = 'badge badge-green'; badge.style.fontSize='0.65rem'; badge.textContent='Active';
      btn.style.background='var(--red-dim)'; btn.style.borderColor='var(--red-border)'; btn.style.color='#f87171'; btn.textContent='🚫';
      btn.title = 'Ban';
    } else {
      badge.className = 'badge badge-red'; badge.style.fontSize='0.65rem'; badge.textContent='Banned';
      btn.style.background='var(--green-dim)'; btn.style.borderColor='var(--green-border)'; btn.style.color='#4ade80'; btn.textContent='✅';
      btn.title = 'Unban';
    }
    toast(d.active ? 'User unbanned.' : 'User banned.', d.active ? 'ok' : 'warn');
  } else toast(d.message, 'err');
}

async function deleteUser(id, name) {
  if (!confirm(`Permanently delete user "${name}"? This cannot be undone.`)) return;
  const r = await fetch(`/api/admin/user/${id}`, { method:'DELETE' });
  const d = await r.json();
  if (d.success) {
    const row = document.getElementById('urow-' + id);
    if (row) { row.style.opacity='0'; row.style.transition='opacity 0.3s'; setTimeout(()=>row.remove(),320); }
    toast('User deleted.', 'ok');
  } else toast(d.message, 'err');
}

/* ── Announcements ── */
async function postAnnouncement() {
  const title   = document.getElementById('ann-title').value.trim();
  const content = document.getElementById('ann-content').value.trim();
  const type    = document.getElementById('ann-type').value;
  const pinned  = document.getElementById('ann-pinned').checked;
  const res     = document.getElementById('ann-result');
  if (!title || !content) { toast('Title and content required.','warn'); return; }
  const r = await fetch('/api/admin/announcement', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({title,content,type,pinned:String(pinned)}) });
  const d = await r.json();
  if (d.success) {
    res.innerHTML = `<div class="alert alert-success" style="margin-bottom:.75rem;font-size:.78rem;">✓ Posted. Reload to see it in the list.</div>`;
    document.getElementById('ann-title').value = '';
    document.getElementById('ann-content').value = '';
    toast('Announcement posted!', 'ok');
  } else {
    res.innerHTML = `<div class="alert alert-danger" style="margin-bottom:.75rem;font-size:.78rem;">${d.message}</div>`;
    toast(d.message, 'err');
  }
}

async function deleteAnn(id) {
  if (!confirm('Delete this announcement?')) return;
  const r = await fetch(`/api/admin/announcement/${id}`, { method:'DELETE' });
  const d = await r.json();
  if (d.success) {
    const el = document.getElementById('ann-' + id);
    if (el) { el.style.animation='fadeOut 0.3s forwards'; setTimeout(()=>el.remove(),320); }
    toast('Announcement removed.', 'ok');
  } else toast('Failed.', 'err');
}

/* ── Settings ── */
function previewLogo(url) {
  const img = document.getElementById('logo-preview');
  img.src = url;
  img.style.display = '';
}

/* ═══ PAYMENTS TAB ═══ */
let _plansCache = [];

async function loadPaymentsTab() {
  await Promise.all([loadAdminPlans(), loadAdminOrders()]);
}

async function loadAdminPlans() {
  try {
    const r = await fetch('/api/admin/payment-plans');
    const d = await r.json();
    if (!d.success) return;
    _plansCache = d.plans;
    document.getElementById('pay-plans-count').textContent = d.plans.filter(p=>p.is_active).length;
    const el = document.getElementById('admin-plans-list');
    if (!d.plans.length) { el.innerHTML = '<div class="empty-state" style="padding:2rem;">No plans yet. Click "New Plan" to create one.</div>'; return; }
    el.innerHTML = d.plans.map(p => `
      <div class="admin-project-row" id="planrow-${p.id}" style="opacity:${p.is_active?1:0.5};">
        <div class="admin-proj-icon" style="background:${p.gradient}">${p.icon}</div>
        <div style="flex:1;min-width:0;">
          <div style="font-size:0.85rem;font-weight:700;display:flex;align-items:center;gap:0.5rem;">
            ${p.name}
            ${!p.is_active?'<span class="badge badge-red" style="font-size:0.6rem;">Disabled</span>':''}
            <span class="badge badge-gray" style="font-size:0.6rem;">${p.duration_days}d</span>
          </div>
          <div class="t-xs dimmed" style="margin-top:2px;">
            $${Number(p.price_usd).toFixed(2)} USD
            ${p.project_name?' · 🔗 '+p.project_name:' · ⚠️ No project linked'}
          </div>
        </div>
        <div style="display:flex;gap:0.4rem;flex-shrink:0;">
          <button class="btn btn-sm btn-secondary" onclick="openPlanModal(${p.id})">Edit</button>
          <button class="btn btn-sm" style="background:var(--red-dim);border:1px solid var(--red-border);color:#f87171;" onclick="deletePlan(${p.id},'${p.name}')">Disable</button>
        </div>
      </div>
    `).join('');
  } catch(e) {
    document.getElementById('admin-plans-list').innerHTML = '<div class="empty-state" style="padding:1.5rem;">Error loading plans.</div>';
  }
}

async function loadAdminOrders() {
  try {
    const r = await fetch('/api/admin/payment-orders');
    const d = await r.json();
    if (!d.success) return;
    const orders = d.orders;
    document.getElementById('pay-total').textContent    = orders.length;
    const approved = orders.filter(o=>o.status==='approved');
    document.getElementById('pay-approved').textContent = approved.length;
    const revenue = approved.reduce((s,o)=>s+Number(o.amount_usd),0);
    document.getElementById('pay-revenue').textContent  = '$'+revenue.toFixed(2);
    const tbody = document.getElementById('orders-tbody');
    if (!orders.length) { tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--text-3);padding:2rem;">No orders yet.</td></tr>'; return; }
    const statusBadge = s => ({
      approved: '<span class="badge badge-green" style="font-size:0.65rem;">✓ Approved</span>',
      pending:  '<span class="badge badge-gray" style="font-size:0.65rem;">⏳ Pending</span>',
      failed:   '<span class="badge badge-red" style="font-size:0.65rem;">✗ Failed</span>',
    }[s] || `<span class="badge badge-gray" style="font-size:0.65rem;">${s}</span>`);
    tbody.innerHTML = orders.map(o => `
      <tr>
        <td><span class="mono t-xs" title="${o.order_ref}">${o.order_ref.slice(0,20)}…</span></td>
        <td><span style="font-weight:600;font-size:0.82rem;">${o.username||'—'}</span></td>
        <td><span class="t-sm">${o.plan_name||'—'}</span></td>
        <td><span class="t-sm" style="font-weight:600;">$${Number(o.amount_usd).toFixed(2)}</span> <span class="dimmed t-xs">USD</span></td>
        <td>${statusBadge(o.status)}</td>
        <td><span class="t-xs dimmed">${new Date(o.created_at).toLocaleDateString('en',{day:'numeric',month:'short',year:'2-digit'})}</span></td>
        <td><span class="mono t-xs dimmed">${o.bold_tx_id?o.bold_tx_id.slice(0,14)+'…':'—'}</span></td>
      </tr>
    `).join('');
  } catch(e) {
    document.getElementById('orders-tbody').innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--text-3);">Error loading orders.</td></tr>';
  }
}

function openPlanModal(planId) {
  document.getElementById('plm-id').value    = planId || '';
  document.getElementById('plm-title').textContent = planId ? 'Edit Plan' : 'New Payment Plan';
  document.getElementById('plm-name').value  = '';
  document.getElementById('plm-icon').value  = '⚡';
  document.getElementById('plm-price').value = '';
  document.getElementById('plm-days').value  = 30;
  document.getElementById('plm-project').value = '';
  document.getElementById('plm-desc').value  = '';
  document.getElementById('plm-color').value = '#8b5cf6';
  document.getElementById('plm-sort').value  = 0;
  document.getElementById('plm-gradient').value = 'linear-gradient(135deg,#8b5cf6,#6366f1)';
  document.getElementById('plm-result').innerHTML = '';
  openModal('plan-modal');

  if (planId) {
    const p = _plansCache.find(x=>x.id===planId);
    if (p) {
      document.getElementById('plm-name').value    = p.name;
      document.getElementById('plm-icon').value    = p.icon;
      document.getElementById('plm-price').value   = p.price_usd;
      document.getElementById('plm-days').value    = p.duration_days;
      document.getElementById('plm-project').value = p.project_id || '';
      document.getElementById('plm-gamepass').value = p.roblox_gamepass_id || '';
      document.getElementById('plm-desc').value    = p.description;
      document.getElementById('plm-color').value   = p.color || '#8b5cf6';
      document.getElementById('plm-sort').value    = p.sort_order;
      document.getElementById('plm-gradient').value = p.gradient;
    }
  }
}

function updatePlanGradient() {
  const c = document.getElementById('plm-color').value;
  document.getElementById('plm-gradient').value = `linear-gradient(135deg,${c},${c}cc)`;
}

async function savePlan() {
  const id = document.getElementById('plm-id').value;
  const body = {
    name:         document.getElementById('plm-name').value.trim(),
    price_usd:    document.getElementById('plm-price').value,
    duration_days:document.getElementById('plm-days').value,
    project_id:   document.getElementById('plm-project').value || null,
    roblox_gamepass_id: document.getElementById('plm-gamepass').value.trim() || null,
    description:  document.getElementById('plm-desc').value.trim(),
    icon:         document.getElementById('plm-icon').value.trim() || '⚡',
    color:        document.getElementById('plm-color').value,
    gradient:     document.getElementById('plm-gradient').value.trim(),
    sort_order:   document.getElementById('plm-sort').value,
  };
  if (!body.name || !body.price_usd) { toast('Name and price required.','warn'); return; }
  const url    = id ? `/api/admin/payment-plans/${id}` : '/api/admin/payment-plans';
  const method = id ? 'PATCH' : 'POST';
  const r = await fetch(url, { method, headers:{'Content-Type':'application/json'}, body:JSON.stringify(body) });
  const d = await r.json();
  const res = document.getElementById('plm-result');
  if (d.success) {
    res.innerHTML = `<div class="alert alert-success" style="margin-bottom:.75rem;font-size:.78rem;">✓ Plan saved!</div>`;
    toast('Plan saved!', 'ok');
    closeModal('plan-modal');
    loadAdminPlans();
  } else {
    res.innerHTML = `<div class="alert alert-danger" style="margin-bottom:.75rem;font-size:.78rem;">${d.message}</div>`;
    toast(d.message, 'err');
  }
}

async function deletePlan(id, name) {
  if (!confirm(`Disable plan "${name}"? It will be hidden from the /plans page.`)) return;
  const r = await fetch(`/api/admin/payment-plans/${id}`, { method:'DELETE' });
  const d = await r.json();
  if (d.success) { toast('Plan disabled.', 'warn'); loadAdminPlans(); }
  else toast(d.message, 'err');
}

async function saveSettings() {
  const body = {
    panel_name:  document.getElementById('s-panel-name').value.trim(),
    panel_logo:  document.getElementById('s-panel-logo').value.trim(),
    discord_url: document.getElementById('s-discord-url').value.trim(),
  };
  const res = document.getElementById('settings-result');
  const r = await fetch('/api/admin/settings', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body) });
  const d = await r.json();
  if (d.success) {
    res.innerHTML = `<div class="alert alert-success" style="margin-bottom:.75rem;font-size:.78rem;">✓ Settings saved and applied live.</div>`;
    toast('Settings saved!', 'ok');
  } else {
    res.innerHTML = `<div class="alert alert-danger" style="margin-bottom:.75rem;font-size:.78rem;">${d.message}</div>`;
    toast(d.message, 'err');
  }
}

/* ── Live stats refresh ── */
async function refreshStats() {
  try {
    const r = await fetch('/api/admin/stats');
    const d = await r.json();
    if (!d.success) return;
    document.getElementById('ov-users').textContent  = d.stats.totalUsers;
    document.getElementById('ov-active').textContent = d.stats.activeToday;
    document.getElementById('ov-resets').textContent = Number(d.stats.totalResets).toLocaleString();
    document.getElementById('stats-live').textContent = 'Updated ' + new Date().toLocaleTimeString();
  } catch {}
}
setInterval(refreshStats, 30000);

/* ── Admin Live Sessions ── */
function renderAdminInv(inventory) {
  const inv = inventory && typeof inventory === 'object' ? inventory : {};
  const entries = Object.entries(inv).sort((a,b) => b[1]-a[1]);
  if (!entries.length) return '';
  const shown = entries.slice(0,12);
  const extra = entries.length - 12;
  return `<div class="live-inv-table">
    <div class="live-inv-table-header"><span>Item</span><span>Qty</span></div>
    ${shown.map(([n,c]) => `<div class="live-inv-row"><span class="live-inv-name">${n}</span><span class="live-inv-count">${Number(c).toLocaleString()}</span></div>`).join('')}
    ${extra > 0 ? `<div class="live-inv-more">+${extra} more items</div>` : ''}
  </div>`;
}

async function adminKickSession(robloxUserId, btn) {
  btn.disabled = true; btn.textContent = '...';
  try {
    const r = await fetch('/api/kick-session', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({roblox_user_id:robloxUserId}) });
    const d = await r.json();
    if (d.success) { btn.textContent = '✓ Kicked'; toast('Kick requested — player will disconnect within ~10s.', 'ok'); setTimeout(()=>refreshAdminLive(),2000); }
    else { btn.disabled = false; btn.textContent = 'Kick'; toast(d.message, 'err'); }
  } catch { btn.disabled = false; btn.textContent = 'Kick'; }
}

async function refreshAdminLive() {
  try {
    const r = await fetch('/api/admin/live-sessions');
    const d = await r.json();
    const sessions = d.sessions || [];
    const badge = document.getElementById('live-count-badge');
    const adminBadge = document.getElementById('admin-live-badge');
    const list = document.getElementById('admin-live-list');
    if (!list) return;

    if (badge) {
      badge.textContent = sessions.length;
      badge.style.display = sessions.length > 0 ? '' : 'none';
    }
    const ovLive = document.getElementById('ov-live');
    if (ovLive) ovLive.textContent = sessions.length;
    if (adminBadge) {
      adminBadge.innerHTML = sessions.length > 0
        ? `<span class="badge badge-green" style="font-size:0.72rem;">● ${sessions.length} account${sessions.length !== 1 ? 's' : ''} online</span>`
        : `<span class="badge badge-gray" style="font-size:0.72rem;">● No active sessions</span>`;
    }

    if (sessions.length === 0) {
      list.innerHTML = `<div class="live-sessions-empty" style="padding:2.5rem;">
        <svg width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:var(--text-3);margin-bottom:0.6rem;"><circle cx="12" cy="12" r="10" stroke-width="1.5"/><path stroke-linecap="round" stroke-width="1.5" d="M12 8v4m0 4h.01"/></svg>
        <div style="font-size:0.85rem;color:var(--text-2);font-weight:600;">No accounts online</div>
        <div style="font-size:0.72rem;color:var(--text-3);margin-top:3px;">Will update automatically when users execute the script</div>
      </div>`;
      return;
    }

    /* Separate registered users from guests */
    const grouped = {};
    const guests  = [];
    sessions.forEach(s => {
      if (s.is_guest) {
        guests.push(s);
      } else {
        const key = s.username || '?';
        if (!grouped[key]) grouped[key] = [];
        grouped[key].push(s);
      }
    });

    const renderSession = s => `
      <div class="admin-live-session">
        <div class="admin-live-session-top">
          <div class="admin-live-session-info">
            <span class="admin-live-roblox-name">${s.roblox_username || '—'}</span>
            ${s.place_name ? `<span class="live-session-game">🎮 ${s.place_name}</span>` : ''}
            <span class="live-session-id">ID: ${s.roblox_user_id}</span>
          </div>
          <button class="btn-kick" onclick="adminKickSession('${s.roblox_user_id}',this)" title="Kick ${s.roblox_username || ''}">
            <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
            Kick
          </button>
        </div>
        ${renderAdminInv(s.inventory)}
      </div>`;

    const registeredHtml = Object.entries(grouped).map(([username, accs]) => `
      <div class="admin-live-group">
        <div class="admin-live-group-header">
          <span class="pulse-dot" style="width:8px;height:8px;flex-shrink:0;"></span>
          <span class="admin-live-group-name">${username}</span>
          <span class="badge badge-green" style="font-size:0.62rem;">${accs.length} account${accs.length !== 1 ? 's' : ''}</span>
        </div>
        <div class="admin-live-accounts">${accs.map(renderSession).join('')}</div>
      </div>`).join('');

    const guestsHtml = guests.length === 0 ? '' : `
      <div class="admin-live-group">
        <div class="admin-live-group-header" style="background:rgba(251,146,60,0.06);">
          <span class="pulse-dot" style="width:8px;height:8px;flex-shrink:0;background:var(--yellow);box-shadow:0 0 0 3px rgba(251,146,60,0.18);"></span>
          <span class="admin-live-group-name" style="color:var(--yellow);">Guests</span>
          <span class="badge" style="background:rgba(251,146,60,0.18);color:var(--yellow);font-size:0.62rem;">${guests.length} sin cuenta</span>
          <span style="font-size:0.68rem;color:var(--text-3);margin-left:auto;">ejecutaron el script pero no están registrados</span>
        </div>
        <div class="admin-live-accounts">${guests.map(renderSession).join('')}</div>
      </div>`;

    list.innerHTML = registeredHtml + guestsHtml;
  } catch(e) {}
}

setInterval(refreshAdminLive, 8000);
refreshAdminLive(); // populate on load

/* ─── Live Clock ─── */
(function() {
  const cl = document.getElementById('topbar-clock');
  function tick() {
    if (!cl) return;
    const n = new Date();
    const pad = v => String(v).padStart(2,'0');
    cl.textContent = pad(n.getUTCHours())+':'+pad(n.getUTCMinutes())+':'+pad(n.getUTCSeconds())+' UTC';
  }
  tick(); setInterval(tick, 1000);
})();

