/* ── Live session polling ── */
function renderSessions(sessions) {
  const list  = document.getElementById('roblox-sessions-list');
  const badge = document.getElementById('roblox-session-badge');
  if (!list || !badge) return;
  if (sessions && sessions.length > 0) {
    badge.innerHTML = `<span class="badge badge-green" style="font-size:0.72rem;">● ${sessions.length} Online</span>`;
    list.innerHTML = sessions.map(s => {
      const inv = s.inventory && typeof s.inventory === 'object' ? s.inventory : {};
      const invEntries = Object.entries(inv).sort((a,b) => b[1]-a[1]);
      const shown = invEntries.slice(0, 15);
      const extra = invEntries.length - 15;
      const invHtml = invEntries.length > 0
        ? `<div class="live-inv-table">
            <div class="live-inv-table-header"><span>Item</span><span>Qty</span></div>
            ${shown.map(([n,c]) =>
              `<div class="live-inv-row"><span class="live-inv-name">${n}</span><span class="live-inv-count">${c.toLocaleString()}</span></div>`
            ).join('')}
            ${extra > 0 ? `<div class="live-inv-more">+${extra} more items</div>` : ''}
          </div>`
        : '';
      return `<div class="live-session-row">
        <div class="live-session-top">
          <div style="display:flex;align-items:center;gap:0.5rem;flex:1;min-width:0;">
            <span class="pulse-dot" style="width:7px;height:7px;flex-shrink:0;"></span>
            <span class="live-session-name">${s.roblox_username || '—'}</span>
            ${s.place_name ? `<span class="live-session-game">🎮 ${s.place_name}</span>` : ''}
            <span class="live-session-id">ID: ${s.roblox_user_id}</span>
          </div>
          <button class="btn-kick" onclick="kickSession('${s.roblox_user_id}', this)" title="Kick this account">
            <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
            </svg>
            Kick
          </button>
        </div>${invHtml}</div>`;
    }).join('');
  } else {
    badge.innerHTML = `<span class="badge badge-gray" style="font-size:0.72rem;">● Offline</span>`;
    list.innerHTML = `<div class="live-sessions-empty">
      <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:var(--text-3);margin-bottom:0.5rem;">
        <circle cx="12" cy="12" r="10" stroke-width="1.5"/>
        <path stroke-linecap="round" stroke-width="1.5" d="M12 8v4m0 4h.01"/>
      </svg>
      <div style="font-size:0.82rem;color:var(--text-3);">No accounts executing right now</div>
      <div style="font-size:0.7rem;color:var(--text-3);margin-top:2px;">Execute the script in Roblox to see live data here</div>
    </div>`;
  }
}

async function pollLiveSession() {
  try {
    const r = await fetch('/api/live-status');
    if (!r.ok) return;
    const d = await r.json();
    renderSessions(d.online ? d.sessions : []);
  } catch {}
}

async function kickSession(robloxUserId, btn) {
  if (!robloxUserId) return;
  btn.disabled = true;
  btn.textContent = 'Kicking…';
  try {
    const r = await fetch('/api/kick-session', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ roblox_user_id: robloxUserId }),
    });
    const d = await r.json();
    if (d.success) {
      toast('Kick sent — account will disconnect within 10s.', 'ok');
      btn.textContent = 'Kicked ✓';
    } else {
      toast(d.message || 'Failed to kick.', 'err');
      btn.disabled = false; btn.textContent = 'Kick';
    }
  } catch { btn.disabled = false; btn.textContent = 'Kick'; }
}

setInterval(pollLiveSession, 8000);
pollLiveSession();

/* ── Multi-key management ── */
async function addKey() {
  const keyVal   = (document.getElementById('new-key-input')?.value  || '').trim();
  const labelVal = (document.getElementById('new-key-label')?.value  || '').trim();
  const area     = document.getElementById('key-add-result');
  if (!keyVal) { area.innerHTML = '<div class="alert alert-danger mb-2" style="font-size:0.78rem;">❌ Paste a key first.</div>'; return; }
  area.innerHTML = '<div class="alert alert-info mb-2" style="font-size:0.78rem;"><div class="spinner" style="width:12px;height:12px;display:inline-block;"></div> Verifying…</div>';
  try {
    const r = await fetch('/api/user-keys', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ key: keyVal, label: labelVal }),
    });
    const d = await r.json();
    if (d.success) {
      area.innerHTML = `<div class="alert alert-success mb-2" style="font-size:0.78rem;">✅ Key added — ${d.project_name}</div>`;
      document.getElementById('new-key-input').value  = '';
      document.getElementById('new-key-label').value  = '';
      toast('Key added!', 'ok');
      setTimeout(() => location.reload(), 1200);
    } else {
      area.innerHTML = `<div class="alert alert-danger mb-2" style="font-size:0.78rem;">❌ ${d.message}</div>`;
    }
  } catch { area.innerHTML = '<div class="alert alert-danger mb-2" style="font-size:0.78rem;">❌ Network error.</div>'; }
}

async function deleteKey(keyId, btn) {
  if (!confirm('Remove this key from your account?')) return;
  btn.disabled = true;
  try {
    const r = await fetch(`/api/user-keys/${keyId}`, { method: 'DELETE' });
    const d = await r.json();
    if (d.success) {
      const row = document.getElementById('keyrow-' + keyId);
      if (row) { row.style.opacity = '0'; row.style.transition = 'opacity 0.3s'; setTimeout(() => row.remove(), 320); }
      toast('Key removed.', 'ok');
    } else { toast(d.message, 'err'); btn.disabled = false; }
  } catch { btn.disabled = false; }
}

async function resetExtraKey(keyId, btn) {
  btn.disabled = true; btn.textContent = '↺…';
  try {
    const r = await fetch('/api/reset-hwid-extra', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ key_id: keyId }),
    });
    const d = await r.json();
    if (d.success) { btn.textContent = '✓'; toast('HWID reset!', 'ok'); setTimeout(() => { btn.disabled = false; btn.textContent = '↺ Reset'; }, 2500); }
    else { btn.disabled = false; btn.textContent = '↺ Reset'; toast(d.message || 'Failed.', 'err'); }
  } catch { btn.disabled = false; btn.textContent = '↺ Reset'; }
}

