<%- include('partials/head', { title: 'Dashboard — ' + panelName }) %>

<%
function fmtTs(ts) {
  if (!ts) return 'N/A';
  return new Date(Number(ts) * 1000).toLocaleString('en', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' });
}
function fmtExpiry(ts) {
  if (!ts || ts < 0) return 'Never expires';
  const diff = ts - Date.now() / 1000;
  if (diff <= 0) return 'Expired';
  const d = Math.floor(diff / 86400);
  const h = Math.floor((diff % 86400) / 3600);
  const m = Math.floor((diff % 3600) / 60);
  if (d > 0) return d + 'd ' + h + 'h left';
  if (h > 0) return h + 'h ' + m + 'm left';
  return m + 'm left';
}
const exp          = luaUser ? luaUser.auth_expire : null;
const expired      = exp && exp > 0 && exp < Date.now() / 1000;
const expiringSoon = exp && exp > 0 && !expired && (exp - Date.now()/1000) < 7 * 86400;
const pct          = Math.min(100, Math.round((resetsToday / dailyLimit) * 100));
const pfClass      = pct >= 100 ? 'pf-red' : pct >= 70 ? 'pf-yellow' : 'pf-green';
const executions   = (luaUser && luaUser.total_executions != null) ? luaUser.total_executions : 0;
const hasDiscord   = !!(user && user.discordId) || !!(luaUser && luaUser.discord_id);
const hasHwid      = !!(luaUser && luaUser.identifier);
%>

<div class="layout">
  <%- include('partials/sidebar', { page: 'dashboard' }) %>

  <div class="main">
    <!-- Topbar -->
    <div class="topbar">
      <div class="topbar-left">
        <div class="pulse-dot"></div>
        <div class="topbar-title">Dashboard</div>
      </div>
      <div class="topbar-right">
        <span class="t-xs muted" id="lastUpdated">Updated just now</span>
        <button class="btn btn-sm btn-ghost" onclick="refresh()">
          <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
          Refresh
        </button>
      </div>
    </div>

    <div class="content">

      <!-- Expiry banners -->
      <% if (expired) { %>
      <div class="danger-banner">
        <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="flex-shrink:0">
          <path stroke-linecap="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <span>Your key has <strong>expired</strong>. Contact staff to renew access.</span>
      </div>
      <% } else if (expiringSoon) { %>
      <div class="warn-banner">
        <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="flex-shrink:0">
          <path stroke-linecap="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <span>Your key expires soon — <strong><%= fmtExpiry(exp) %></strong>. Renew before losing access.</span>
      </div>
      <% } %>

      <!-- Announcements -->
      <% if (announcements && announcements.length > 0) { %>
      <div class="announce-stack">
        <% announcements.forEach(a => { %>
        <div class="announce-item announce-<%= a.type %>">
          <% if (a.pinned) { %>
          <div class="announce-pin">
            <svg width="11" height="11" fill="currentColor" viewBox="0 0 24 24"><path d="M16 4v8l2 4H6l2-4V4h8zm-8 0H6a2 2 0 00-2 2v6l-2 4h16l-2-4V6a2 2 0 00-2-2h-2M12 20v-2"/></svg>
            PINNED
          </div>
          <% } %>
          <div class="announce-body">
            <div class="announce-title"><%= a.title %></div>
            <div class="announce-content"><%= a.content %></div>
          </div>
          <div class="announce-meta"><%= new Date(a.created_at).toLocaleDateString('en', {day:'numeric',month:'short',year:'numeric'}) %></div>
        </div>
        <% }) %>
      </div>
      <% } %>

      <!-- Welcome banner -->
      <div class="welcome-banner">
        <img 
          src="https://cdn.discordapp.com/icons/1398423987817807934/a_6f62815e5aee24b4964bd4113626e3fe.webp?size=64"
          class="welcome-avatar" alt="logo"
        />
        <div class="welcome-text">
          <div class="welcome-title">Welcome back, <span style="color:var(--accent)"><%= user ? user.username : 'User' %></span></div>
          <div class="welcome-sub">
            Key: <span class="mono" style="color:var(--accent)"><%= user ? (user.luarmorKey || '').slice(0,20) + '…' : '—' %></span>
            &nbsp;·&nbsp;
            <span class="<%= !expired ? 'c-green' : 'c-red' %>">
              <%= !expired ? '● Active' : '● Expired' %>
            </span>
            <% if (proj) { %>
            &nbsp;·&nbsp;<span class="badge badge-purple" style="font-size:0.7rem;"><%= proj.icon %> <%= proj.name %></span>
            <% } %>
          </div>
        </div>
        <div class="welcome-exec">
          <div class="welcome-exec-num" id="exec-count"><%= executions.toLocaleString() %></div>
          <div class="welcome-exec-label">total executions</div>
        </div>
      </div>

      <!-- Top Stats Row -->
      <div class="stat-grid" style="grid-template-columns:repeat(4,1fr);">
        <div class="stat">
          <div class="stat-label">Key Status</div>
          <div style="margin-top:8px;">
            <% const s = luaUser ? luaUser.status : 'unknown'; %>
            <% if (s === 'active')  { %><span class="badge badge-green">● Active</span><% } %>
            <% if (s === 'reset')   { %><span class="badge badge-yellow">● Reset</span><% } %>
            <% if (s === 'banned')  { %><span class="badge badge-red">● Banned</span><% } %>
            <% if (!['active','reset','banned'].includes(s)) { %><span class="badge badge-gray"><%= s %></span><% } %>
          </div>
          <div class="stat-sub"><% if (luaUser && luaUser.banned) { %>Key is banned<% } else { %>No restrictions<% } %></div>
        </div>

        <div class="stat">
          <div class="stat-label">Resets Today</div>
          <div class="stat-val <%= resetsLeft > 0 ? 'c-green' : 'c-yellow' %>" id="s-today"><%= resetsToday %></div>
          <div class="stat-sub" id="s-left"><%= resetsLeft %> of <%= dailyLimit %> remaining</div>
        </div>

        <div class="stat">
          <div class="stat-label">Expiry</div>
          <div class="stat-val c-blue" style="font-size:0.875rem;margin-top:4px;">
            <%= exp && exp > 0 ? fmtExpiry(exp) : 'Never' %>
          </div>
          <div class="stat-sub"><%= exp && exp > 0 ? fmtTs(exp) : 'Permanent key' %></div>
        </div>

        <div class="stat">
          <div class="stat-label">Executions</div>
          <div class="stat-val c-purple" id="s-exec"><%= executions.toLocaleString() %></div>
          <div class="stat-sub">total runs</div>
        </div>
      </div>

      <!-- Connected Accounts -->
      <div class="card" id="stats">
        <div class="card-head">
          <div class="card-icon ci-purple">🔗</div>
          <div>
            <div class="card-title">Connected Accounts & Devices</div>
            <div class="card-desc">Everything linked to your Luarmor key</div>
          </div>
        </div>

        <div class="accounts-grid">

          <!-- Discord Account -->
          <div class="account-card <%= hasDiscord ? 'connected' : 'disconnected' %>">
            <div class="account-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="color: #5865f2;">
                <path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/>
              </svg>
            </div>
            <div class="account-info">
              <div class="account-name">Discord</div>
              <div class="account-val mono">
                <% const dId = (user && user.discordId) || (luaUser && luaUser.discord_id) || ''; %>
                <% if (hasDiscord) { %><%= dId %><% } else { %>Not linked<% } %>
              </div>
            </div>
            <div class="account-status">
              <% if (hasDiscord) { %>
                <span class="badge badge-green">✓ Linked</span>
              <% } else { %>
                <span class="badge badge-gray">Not linked</span>
              <% } %>
            </div>
          </div>

          <!-- HWID Device -->
          <div class="account-card <%= hasHwid ? 'connected' : 'disconnected' %>">
            <div class="account-icon">
              <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:#8b5cf6;">
                <rect x="2" y="3" width="20" height="14" rx="2" stroke-width="2"/>
                <path stroke-linecap="round" stroke-width="2" d="M8 21h8M12 17v4"/>
              </svg>
            </div>
            <div class="account-info">
              <div class="account-name">Linked Device (HWID)</div>
              <div class="account-val mono">
                <% if (hasHwid) { %><%= luaUser.identifier.slice(0,28) %>…<% } else { %>No device linked yet<% } %>
              </div>
            </div>
            <div class="account-status">
              <% if (hasHwid) { %>
                <span class="badge badge-green">✓ Active</span>
              <% } else { %>
                <span class="badge badge-gray">None</span>
              <% } %>
            </div>
          </div>

          <!-- Roblox Live Session -->
          <div class="account-card <%= liveSession ? 'connected' : 'disconnected' %>" id="roblox-session-card" style="grid-column:1/-1;">
            <div class="account-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="color:#e74c3c;">
                <path d="M5.001 5.54L8.916 18.46l10.083-2.54L15.084 3zm7.315 5.397l1.688 5.896-3.525.888-1.688-5.896z"/>
              </svg>
            </div>
            <div class="account-info" style="flex:1;" id="roblox-session-info">
              <div class="account-name">Roblox — Live Session</div>
              <div id="roblox-session-val">
                <% if (liveSession) { %>
                <div class="account-val" style="display:flex;flex-wrap:wrap;gap:0.4rem;align-items:center;margin-top:2px;">
                  <span class="mono" style="color:var(--text-1)"><%= liveSession.roblox_username || '—' %></span>
                  <% if (liveSession.place_name) { %>
                  <span class="badge badge-gray" style="font-size:0.65rem;">🎮 <%= liveSession.place_name %></span>
                  <% } %>
                </div>
                <% } else { %>
                <div class="account-val muted">Not executing right now</div>
                <% } %>
              </div>
            </div>
            <div class="account-status" id="roblox-session-badge">
              <% if (liveSession) { %>
                <span class="badge badge-green">● Online</span>
              <% } else { %>
                <span class="badge badge-gray">● Offline</span>
              <% } %>
            </div>
          </div>

          <!-- Note / Tag -->
          <div class="account-card <%= (luaUser && luaUser.note) ? 'connected' : 'disconnected' %>">
            <div class="account-icon">
              <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:#f59e0b;">
                <path stroke-linecap="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
            </div>
            <div class="account-info">
              <div class="account-name">Custom Note / Tag</div>
              <div class="account-val">
                <% if (luaUser && luaUser.note) { %><%= luaUser.note %><% } else { %>No note set<% } %>
              </div>
            </div>
            <div class="account-status">
              <% if (luaUser && luaUser.note) { %>
                <span class="badge badge-yellow">Set</span>
              <% } else { %>
                <span class="badge badge-gray">Empty</span>
              <% } %>
            </div>
          </div>

        </div>

        <!-- Execution bar chart (visual) -->
        <div style="margin-top:1.25rem; padding-top:1.25rem; border-top:1px solid var(--border);">
          <div class="prog-meta">
            <span style="font-size:0.78rem; font-weight:600; color:var(--text-2);">Total Script Executions</span>
            <span class="badge badge-purple" id="exec-badge"><%= executions.toLocaleString() %> runs</span>
          </div>
          <div class="exec-meter">
            <div class="exec-fill" id="exec-fill" style="width:<%= Math.min(100, executions > 0 ? Math.max(5, Math.min(100, executions / 10)) : 0) %>%"></div>
          </div>
          <div class="t-xs dimmed mt-1">Each time your script runs in the executor counts as one execution.</div>
        </div>
      </div>

      <!-- HWID Reset -->
      <div class="hwid-card" id="hwid">
        <div class="hwid-orb hwid-orb-1"></div>
        <div class="hwid-orb hwid-orb-2"></div>

        <!-- Header -->
        <div class="hwid-header">
          <div class="hwid-header-left">
            <div class="hwid-icon-wrap">
              <svg class="hwid-icon-svg" width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
              </svg>
            </div>
            <div>
              <div class="hwid-title">HWID Reset</div>
              <div class="hwid-subtitle">Unlink your device &amp; bind a new one</div>
            </div>
          </div>
          <div class="hwid-quota-pill" id="quota-pill">
            <span id="quota-num"><%= resetsToday %></span>/<%= dailyLimit %> used
          </div>
        </div>

        <!-- Ring + Stats row -->
        <div class="hwid-body">
          <div class="hwid-ring-wrap">
            <svg class="hwid-ring" viewBox="0 0 120 120">
              <defs>
                <linearGradient id="ringGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#8b5cf6"/>
                  <stop offset="100%" stop-color="#6366f1"/>
                </linearGradient>
                <filter id="ringGlow">
                  <feGaussianBlur stdDeviation="3" result="blur"/>
                  <feComposite in="SourceGraphic" in2="blur" operator="over"/>
                </filter>
              </defs>
              <circle class="hwid-ring-bg"   cx="60" cy="60" r="50" fill="none" stroke-width="7"/>
              <circle class="hwid-ring-track" cx="60" cy="60" r="50" fill="none" stroke-width="7"/>
              <circle class="hwid-ring-prog" id="ring-prog" cx="60" cy="60" r="50" fill="none" stroke-width="7"
                stroke="url(#ringGrad)"
                stroke-dasharray="314"
                stroke-dashoffset="<%= Math.round(314 * (1 - pct/100)) %>"
                stroke-linecap="round"
                transform="rotate(-90 60 60)"
              />
            </svg>
            <div class="hwid-ring-inner">
              <div class="hwid-ring-pct" id="ring-pct"><%= pct %>%</div>
              <div class="hwid-ring-lbl">quota used</div>
            </div>
          </div>

          <div class="hwid-stats-col">
            <div class="hwid-stat">
              <span class="hwid-stat-label">Used Today</span>
              <span class="hwid-stat-val c-yellow" id="s-today"><%= resetsToday %></span>
            </div>
            <div class="hwid-stat">
              <span class="hwid-stat-label">Remaining</span>
              <span class="hwid-stat-val <%= resetsLeft > 0 ? 'c-green' : 'c-red' %>" id="s-left"><%= resetsLeft %></span>
            </div>
            <div class="hwid-stat">
              <span class="hwid-stat-label">Daily Limit</span>
              <span class="hwid-stat-val"><%= dailyLimit %></span>
            </div>
            <div class="hwid-stat">
              <span class="hwid-stat-label">Resets At</span>
              <span class="hwid-stat-val c-blue" style="font-size:0.75rem;">00:00 UTC</span>
            </div>
          </div>
        </div>

        <!-- Progress bar -->
        <div class="hwid-prog-wrap">
          <div class="hwid-prog-track">
            <div class="hwid-prog-fill <%= pfClass %>" id="prog-fill" style="width:<%= pct %>%">
              <div class="hwid-prog-shimmer"></div>
            </div>
          </div>
          <div class="hwid-prog-meta">
            <span class="t-xs dimmed">Resets at midnight UTC</span>
            <span class="t-xs" id="prog-label" style="color:var(--text-2)"><%= resetsToday %>/<%= dailyLimit %></span>
          </div>
        </div>

        <!-- Result area -->
        <div id="reset-result"></div>

        <!-- Particles layer -->
        <div id="particles-wrap" aria-hidden="true"></div>

        <!-- Button -->
        <% if (resetsLeft > 0) { %>
        <button class="hwid-btn" id="reset-btn" onclick="doReset()">
          <span id="btn-state-idle" class="hwid-btn-state">
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-width="2.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
            Reset HWID
            <span class="hwid-btn-badge" id="resets-left-txt"><%= resetsLeft %> remaining</span>
          </span>
          <span id="btn-state-loading" class="hwid-btn-state" style="display:none;">
            <span class="hwid-spinner"></span>
            <span id="loading-msg">Contacting Luarmor…</span>
          </span>
          <span id="btn-state-success" class="hwid-btn-state" style="display:none;">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
            </svg>
            Done!
          </span>
        </button>
        <% } else { %>
        <button class="hwid-btn hwid-btn-disabled" disabled>
          <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10" stroke-width="2"/>
            <path stroke-linecap="round" stroke-width="2" d="M12 8v4m0 4h.01"/>
          </svg>
          Limit reached — resets at 00:00 UTC
        </button>
        <% } %>
      </div>

      <!-- Key Info -->
      <div class="card" id="keyinfo">
        <div class="card-head">
          <div class="card-icon ci-blue">🔑</div>
          <div>
            <div class="card-title">Key Information</div>
            <div class="card-desc">Live data pulled from Luarmor</div>
          </div>
          <button class="btn btn-sm btn-ghost" style="margin-left:auto;" onclick="openModal('key-modal')">
            <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
            View Full Key
          </button>
        </div>

        <div class="info-row">
          <span class="info-k">Your Key</span>
          <div class="chip" onclick="openModal('key-modal')">
            <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <rect x="9" y="9" width="13" height="13" rx="2" stroke-width="2"/>
              <path stroke-width="2" d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
            </svg>
            <%= user ? (user.luarmorKey || '').slice(0,20) + '…' : '—' %>
          </div>
        </div>
        <div class="info-row">
          <span class="info-k">Status</span>
          <div>
            <% if ((luaUser && luaUser.status) === 'active')  { %><span class="badge badge-green">Active</span><% } %>
            <% if ((luaUser && luaUser.status) === 'reset')   { %><span class="badge badge-yellow">Reset</span><% } %>
            <% if ((luaUser && luaUser.status) === 'banned')  { %><span class="badge badge-red">Banned</span><% } %>
            <% if (!luaUser || !['active','reset','banned'].includes(luaUser.status)) { %><span class="badge badge-gray">Unknown</span><% } %>
          </div>
        </div>
        <div class="info-row">
          <span class="info-k">Banned</span>
          <div>
            <% if (luaUser && luaUser.banned) { %><span class="badge badge-red">🚫 Yes</span><% } else { %><span class="badge badge-green">✅ No</span><% } %>
          </div>
        </div>
        <div class="info-row">
          <span class="info-k">Discord ID</span>
          <span class="info-v mono t-sm" id="discord-id-txt"><%= (luaUser && luaUser.discord_id) ? luaUser.discord_id : '—' %></span>
        </div>
        <div class="info-row">
          <span class="info-k">Note</span>
          <span class="info-v muted t-sm"><%= (luaUser && luaUser.note) ? luaUser.note : '—' %></span>
        </div>
        <div class="info-row">
          <span class="info-k">Expiry</span>
          <span class="info-v t-sm">
            <%= exp && exp > 0 ? fmtTs(exp) + ' (' + fmtExpiry(exp) + ')' : 'Never expires' %>
          </span>
        </div>
        <div class="info-row">
          <span class="info-k">Total Executions</span>
          <span class="info-v c-purple" id="s-exec-row"><strong><%= executions.toLocaleString() %></strong></span>
        </div>
      </div>

      <!-- Two columns: Discord + Note -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;" id="discord">

        <div class="card" style="margin-bottom:0;">
          <div class="card-head">
            <div class="card-icon ci-purple" style="font-size:18px;">💬</div>
            <div>
              <div class="card-title">Link Discord</div>
              <div class="card-desc">Attach your Discord account</div>
            </div>
          </div>

          <% const linkedDid = (user && user.discordId) || (luaUser && luaUser.discord_id) || ''; %>
          <% if (linkedDid) { %>
          <div class="alert alert-success mb-3" style="font-size:0.78rem;">
            ✓ Linked: <span class="mono"><%= linkedDid %></span>
          </div>
          <% } %>

          <div id="discord-result"></div>
          <div class="form-group">
            <label class="label">Discord User ID</label>
            <input type="text" class="input mono" id="discord-input" placeholder="e.g. 123456789012345678" maxlength="20" />
          </div>
          <button class="btn btn-primary btn-full" onclick="linkDiscord()">Link Account</button>
          <div class="t-xs dimmed mt-2">
            Settings → Advanced → Developer Mode → right-click name → Copy ID
          </div>
        </div>

        <div class="card" style="margin-bottom:0;">
          <div class="card-head">
            <div class="card-icon ci-yellow">📝</div>
            <div>
              <div class="card-title">Custom Note</div>
              <div class="card-desc">Visible in the Luarmor dashboard</div>
            </div>
          </div>
          <div id="note-result"></div>
          <div class="form-group">
            <label class="label">Your note <span class="dimmed">(max 100 chars)</span></label>
            <input type="text" class="input" id="note-input" placeholder="e.g. my gaming PC" maxlength="100"
              value="<%= (luaUser && luaUser.note) ? luaUser.note : (user && user.note ? user.note : '') %>" />
          </div>
          <button class="btn btn-secondary btn-full" onclick="saveNote()">Save Note</button>
        </div>

      </div>

    </div>
  </div>
</div>

<div class="toast-wrap" id="toasts"></div>

<!-- View Key Modal -->
<div class="overlay" id="key-modal">
  <div class="modal">
    <div class="modal-head">
      <h2>Your Full Key</h2>
      <button class="modal-x" onclick="closeModal('key-modal')">×</button>
    </div>
    <div class="alert alert-warning mb-3" style="font-size:0.8rem;">
      ⚠️ Never share your key with anyone. Whoever has it has full access.
    </div>
    <div class="chip w-full" style="word-break:break-all;cursor:text;user-select:all;justify-content:flex-start;padding:0.75rem;">
      <%= user ? user.luarmorKey : '' %>
    </div>
    <div class="flex gap-2 mt-3">
      <button class="btn btn-primary" onclick="copyFullKey()">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <rect x="9" y="9" width="13" height="13" rx="2" stroke-width="2"/>
          <path stroke-width="2" d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
        </svg>
        Copy Key
      </button>
      <button class="btn btn-ghost" onclick="closeModal('key-modal')">Close</button>
    </div>
  </div>
</div>

<script>
const FULL_KEY    = <%- JSON.stringify(user ? user.luarmorKey : '') %>;
const DAILY_LIMIT = <%= dailyLimit %>;
let resetsToday   = <%= resetsToday %>;
let resetsLeft    = <%= resetsLeft %>;

function toast(msg, type = 'info') {
  const icons = { ok: '✅', err: '❌', warn: '⚠️', info: 'ℹ️' };
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.innerHTML = `<span>${icons[type] || 'ℹ️'}</span><span>${msg}</span>`;
  document.getElementById('toasts').appendChild(el);
  setTimeout(() => { el.style.animation = 'toastOut 0.3s forwards'; setTimeout(() => el.remove(), 320); }, 4000);
}

/* ── Progress helpers ── */
function updateProgress() {
  const pct = Math.min(100, Math.round((resetsToday / DAILY_LIMIT) * 100));

  // Bar
  const fill = document.getElementById('prog-fill');
  if (fill) {
    fill.style.width = pct + '%';
    fill.className = 'hwid-prog-fill ' + (pct >= 100 ? 'pf-red' : pct >= 70 ? 'pf-yellow' : 'pf-green');
  }

  // Label
  const lbl = document.getElementById('prog-label');
  if (lbl) lbl.textContent = resetsToday + '/' + DAILY_LIMIT;

  // Ring
  const ring = document.getElementById('ring-prog');
  if (ring) {
    const offset = Math.round(314 * (1 - pct / 100));
    ring.style.strokeDashoffset = offset;
  }
  const ringPct = document.getElementById('ring-pct');
  if (ringPct) ringPct.textContent = pct + '%';

  // Stats
  const st = document.getElementById('s-today');
  if (st) st.textContent = resetsToday;
  const sl = document.getElementById('s-left');
  if (sl) {
    sl.textContent = resetsLeft;
    sl.className = 'hwid-stat-val ' + (resetsLeft > 0 ? 'c-green' : 'c-red');
  }
  const rl = document.getElementById('resets-left-txt');
  if (rl) rl.textContent = resetsLeft + ' remaining';

  // Quota pill
  const qn = document.getElementById('quota-num');
  if (qn) qn.textContent = resetsToday;
}

/* ── Particle burst ── */
function spawnParticles(container, count = 18, success = true) {
  const colors = success
    ? ['#8b5cf6','#a78bfa','#6366f1','#22c55e','#34d399','#fff']
    : ['#ef4444','#f87171','#fbbf24'];
  for (let i = 0; i < count; i++) {
    const p = document.createElement('div');
    p.style.cssText = [
      'position:absolute',
      'border-radius:50%',
      'pointer-events:none',
      `width:${4 + Math.random()*6}px`,
      `height:${4 + Math.random()*6}px`,
      `background:${colors[Math.floor(Math.random()*colors.length)]}`,
      `left:${20 + Math.random()*60}%`,
      `top:${30 + Math.random()*40}%`,
      'opacity:1',
      'transition:none',
    ].join(';');
    container.appendChild(p);
    const angle  = Math.random() * Math.PI * 2;
    const speed  = 40 + Math.random() * 80;
    const dx = Math.cos(angle) * speed;
    const dy = Math.sin(angle) * speed - 30;
    let start = null;
    const dur = 600 + Math.random() * 400;
    function step(ts) {
      if (!start) start = ts;
      const t = (ts - start) / dur;
      if (t >= 1) { p.remove(); return; }
      const ease = 1 - Math.pow(t, 2);
      p.style.transform = `translate(${dx*t}px, ${dy*t + 40*t*t}px)`;
      p.style.opacity = ease;
      requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }
}

/* ── Loading message rotation ── */
const loadingMessages = [
  'Contacting Luarmor…',
  'Sending reset request…',
  'Unlinking device…',
  'Almost done…',
];
let loadingMsgInterval = null;

function startLoadingMessages() {
  let i = 0;
  const el = document.getElementById('loading-msg');
  if (el) el.textContent = loadingMessages[0];
  loadingMsgInterval = setInterval(() => {
    i = (i + 1) % loadingMessages.length;
    if (el) el.textContent = loadingMessages[i];
  }, 900);
}
function stopLoadingMessages() {
  clearInterval(loadingMsgInterval);
  loadingMsgInterval = null;
}

/* ── doReset ── */
async function doReset() {
  const btn = document.getElementById('reset-btn');
  if (!btn || btn.disabled) return;

  const idle    = document.getElementById('btn-state-idle');
  const loading = document.getElementById('btn-state-loading');
  const success = document.getElementById('btn-state-success');
  const result  = document.getElementById('reset-result');
  const pwrap   = document.getElementById('particles-wrap');

  // → Loading state
  btn.disabled = true;
  btn.classList.add('hwid-btn-busy');
  if (idle)    idle.style.display    = 'none';
  if (loading) loading.style.display = '';
  if (success) success.style.display = 'none';
  if (result)  result.innerHTML      = '';
  startLoadingMessages();

  try {
    const r = await fetch('/api/reset-hwid', { method: 'POST' });

    // Handle non-JSON (session expired redirect)
    if (!r.ok && r.status === 401) {
      const d = await r.json().catch(() => ({}));
      if (d.expired) {
        stopLoadingMessages();
        if (result) result.innerHTML = '<div class="hwid-alert hwid-alert-warn">⚠️ Session expired — <a href="/login" style="color:var(--accent)">log in again</a></div>';
        btn.disabled = false;
        btn.classList.remove('hwid-btn-busy');
        if (idle) idle.style.display = '';
        if (loading) loading.style.display = 'none';
        return;
      }
    }

    const d = await r.json();
    stopLoadingMessages();

    if (d.success) {
      resetsToday = d.resetsToday;
      resetsLeft  = d.resetsLeft;

      // → Success state
      if (loading) loading.style.display = 'none';
      if (success) success.style.display = '';
      btn.classList.remove('hwid-btn-busy');
      btn.classList.add('hwid-btn-ok');

      // Particles burst
      if (pwrap) spawnParticles(pwrap, 22, true);

      // Update all UI
      updateProgress();

      // Success message
      if (result) result.innerHTML = `<div class="hwid-alert hwid-alert-ok">✅ ${d.message}</div>`;
      toast('HWID reset successfully!', 'ok');

      // After 2s → back to idle or disabled
      setTimeout(() => {
        btn.classList.remove('hwid-btn-ok');
        if (resetsLeft <= 0) {
          btn.classList.add('hwid-btn-disabled');
          btn.disabled = true;
          if (success) success.style.display = 'none';
          if (idle) {
            idle.style.display = '';
            document.getElementById('btn-state-idle').querySelector('svg') && (idle.innerHTML = idle.innerHTML);
            const badge = document.getElementById('resets-left-txt');
            if (badge) badge.textContent = '0 remaining';
          }
        } else {
          if (success) success.style.display = 'none';
          if (idle)    idle.style.display    = '';
          btn.disabled = false;
        }
      }, 2000);

    } else {
      // → Error state
      btn.classList.remove('hwid-btn-busy');
      btn.classList.add('hwid-btn-shake');
      setTimeout(() => btn.classList.remove('hwid-btn-shake'), 500);

      if (loading) loading.style.display = 'none';
      if (idle)    idle.style.display    = '';
      btn.disabled = false;

      if (pwrap) spawnParticles(pwrap, 8, false);
      if (result) result.innerHTML = `<div class="hwid-alert hwid-alert-err">❌ ${d.message}</div>`;
      toast(d.message || 'Reset failed. Try again.', 'err');
    }
  } catch (e) {
    stopLoadingMessages();
    btn.classList.remove('hwid-btn-busy');
    btn.classList.add('hwid-btn-shake');
    setTimeout(() => btn.classList.remove('hwid-btn-shake'), 500);
    if (loading) loading.style.display = 'none';
    if (idle)    idle.style.display    = '';
    btn.disabled = false;
    if (result) result.innerHTML = '<div class="hwid-alert hwid-alert-err">❌ Network error. Check your connection.</div>';
    toast('Network error. Try again.', 'err');
  }
}

async function linkDiscord() {
  const id   = (document.getElementById('discord-input')?.value || '').trim();
  const area = document.getElementById('discord-result');
  if (!id || !/^\d{15,20}$/.test(id)) {
    area.innerHTML = '<div class="alert alert-danger mb-3">❌ Invalid ID — must be 15–20 digits.</div>';
    return;
  }
  area.innerHTML = '<div class="alert alert-info mb-3"><div class="spinner"></div> Linking…</div>';
  try {
    const r = await fetch('/api/link-discord', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ discord_id: id }) });
    const d = await r.json();
    if (d.success) {
      area.innerHTML = `<div class="alert alert-success mb-3">✅ ${d.message || 'Discord linked successfully.'}</div>`;
      document.getElementById('discord-id-txt').textContent = id;
      const sd = document.getElementById('s-discord');
      if (sd) sd.innerHTML = '<span class="badge badge-green">✓ Linked</span>';
      toast('Discord linked!', 'ok');
    } else {
      area.innerHTML = `<div class="alert alert-danger mb-3">❌ ${d.message}</div>`;
    }
  } catch {
    area.innerHTML = '<div class="alert alert-danger mb-3">❌ Network error.</div>';
  }
}

async function saveNote() {
  const note = (document.getElementById('note-input')?.value || '').trim();
  const area = document.getElementById('note-result');
  area.innerHTML = '<div class="alert alert-info mb-3"><div class="spinner"></div> Saving…</div>';
  try {
    const r = await fetch('/api/update-note', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ note }) });
    const d = await r.json();
    if (d.success) {
      area.innerHTML = '<div class="alert alert-success mb-3">✅ Note saved.</div>';
      toast('Note updated!', 'ok');
    } else {
      area.innerHTML = `<div class="alert alert-danger mb-3">❌ ${d.message}</div>`;
    }
  } catch {
    area.innerHTML = '<div class="alert alert-danger mb-3">❌ Network error.</div>';
  }
}

async function refresh() {
  try {
    const r = await fetch('/api/userinfo');
    const d = await r.json();
    if (d.success) {
      resetsToday = d.resetsToday;
      resetsLeft  = d.resetsLeft;
      updateProgress();
      // update execution count if returned
      if (d.user && d.user.total_executions != null) {
        const ex = d.user.total_executions;
        const els = ['exec-count','s-exec','s-exec-row'];
        els.forEach(id => { const el = document.getElementById(id); if (el) el.textContent = ex.toLocaleString(); });
        const eb = document.getElementById('exec-badge');
        if (eb) eb.textContent = ex.toLocaleString() + ' runs';
      }
      document.getElementById('lastUpdated').textContent = 'Updated just now';
      toast('Data refreshed.', 'ok');
    }
  } catch { toast('Refresh failed.', 'err'); }
}

function openModal(id)  { document.getElementById(id)?.classList.add('open'); }
function closeModal(id) { document.getElementById(id)?.classList.remove('open'); }
document.querySelectorAll('.overlay').forEach(el => {
  el.addEventListener('click', e => { if (e.target === el) el.classList.remove('open'); });
});
function copyFullKey() {
  navigator.clipboard.writeText(FULL_KEY).then(() => { toast('Key copied!', 'ok'); closeModal('key-modal'); });
}

/* ── Live session polling ── */
async function pollLiveSession() {
  try {
    const r = await fetch('/api/live-status');
    if (!r.ok) return;
    const d = await r.json();
    const card  = document.getElementById('roblox-session-card');
    const val   = document.getElementById('roblox-session-val');
    const badge = document.getElementById('roblox-session-badge');
    if (!card || !val || !badge) return;
    if (d.online && d.session) {
      card.className = card.className.replace('disconnected','connected');
      if (!card.className.includes('connected')) card.className += ' connected';
      val.innerHTML = `<div class="account-val" style="display:flex;flex-wrap:wrap;gap:0.4rem;align-items:center;margin-top:2px;">
        <span class="mono" style="color:var(--text-1)">${d.session.roblox_username || '—'}</span>
        ${d.session.place_name ? `<span class="badge badge-gray" style="font-size:0.65rem;">🎮 ${d.session.place_name}</span>` : ''}
      </div>`;
      badge.innerHTML = '<span class="badge badge-green">● Online</span>';
    } else {
      card.className = card.className.replace('connected','disconnected');
      if (!card.className.includes('disconnected')) card.className += ' disconnected';
      val.innerHTML = '<div class="account-val muted">Not executing right now</div>';
      badge.innerHTML = '<span class="badge badge-gray">● Offline</span>';
    }
  } catch {}
}
setInterval(pollLiveSession, 30000);

document.querySelectorAll('a[href*="#"]').forEach(a => {
  a.addEventListener('click', e => {
    const id = a.getAttribute('href').split('#')[1];
    if (!id) return;
    const t = document.getElementById(id);
    if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
  });
});

setInterval(refresh, 2 * 60 * 1000);
</script>
</body>
</html>
