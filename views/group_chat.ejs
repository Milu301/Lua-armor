<%- include('partials/head', { title: group.name + ' — ' + panelName }) %>

<style>
.gc-layout { display: flex; height: calc(100vh - 70px); gap: 1rem; padding: 1rem; overflow: hidden; }
.gc-main { flex: 1; display: flex; flex-direction: column; background: var(--bg-card); border-radius: 20px; box-shadow: 0 10px 40px rgba(0,0,0,0.4); border: 1px solid var(--border-md); overflow: hidden; position: relative; }
.gc-main::before { content: ''; position: absolute; top:0; left:0; width:100%; height:4px; background: linear-gradient(90deg, #3b82f6, #8b5cf6, #ec4899); z-index:10; }
.gc-header { padding: 1rem 1.5rem; border-bottom: 1px solid var(--border-md); display: flex; justify-content: space-between; align-items: center; background: rgba(139,92,246,0.04); flex-shrink: 0; }
.gc-title-group { display: flex; align-items: center; gap: 0.75rem; }
.gc-title { font-size: 1.2rem; font-weight: 800; }
.gc-voice-room { display: none; flex-direction: column; gap: 1rem; padding: 1rem 1.5rem; background: rgba(0,0,0,0.25); border-bottom: 1px solid var(--border-md); flex-shrink: 0; }
.gc-voice-room.active { display: flex; animation: slideDown 0.3s ease; }
@keyframes slideDown { from { transform:translateY(-15px); opacity:0; } to { transform:translateY(0); opacity:1; } }
.gc-voice-bar { display: flex; justify-content: space-between; align-items: center; }
.gc-voice-label { display: flex; align-items: center; gap: 0.5rem; font-weight: 700; color: #10b981; font-size: 0.9rem; }
.gc-voice-actions { display: flex; gap: 0.5rem; }
.gc-v-btn { background: rgba(255,255,255,0.07); border: 1px solid var(--border-md); color: var(--text); border-radius: 10px; width: 38px; height: 38px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s; }
.gc-v-btn:hover { background: rgba(139,92,246,0.2); border-color: var(--accent); color: var(--accent); }
.gc-v-btn.muted { background: rgba(239,68,68,0.15); color: #ef4444; border-color: rgba(239,68,68,0.4); }
.gc-v-btn.screen-on { background: rgba(59,130,246,0.15); color: #60a5fa; border-color: rgba(59,130,246,0.4); }
.gc-voice-grid { display: flex; flex-wrap: wrap; gap: 0.75rem; }
.gc-voice-peer { background: rgba(255,255,255,0.04); border: 2px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 1rem 1.5rem; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; transition: all 0.3s; min-width: 100px; }
.gc-voice-peer.speaking { border-color: #10b981; box-shadow: 0 0 20px rgba(16,185,129,0.3); background: rgba(16,185,129,0.07); }
.gc-voice-avatar { width: 52px; height: 52px; border-radius: 50%; background: linear-gradient(135deg, var(--accent), #ec4899); display: flex; align-items: center; justify-content: center; font-size: 1.3rem; font-weight: bold; color: white; }
.gc-voice-name { font-weight: 600; font-size: 0.82rem; color: var(--text-2); }
.gc-screenshare { display: none; width: 100%; max-height: 350px; border-radius: 12px; overflow: hidden; background: #000; border: 1px solid var(--border-md); }
.gc-screenshare video { width: 100%; height: 100%; object-fit: contain; display: block; }
.gc-messages { flex: 1; overflow-y: auto; padding: 1.25rem 1.5rem; display: flex; flex-direction: column; gap: 1rem; scroll-behavior: smooth; }
.gc-msg { display: flex; gap: 0.85rem; animation: fadeInUp 0.3s ease; }
@keyframes fadeInUp { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
.gc-av-wrap { position: relative; flex-shrink: 0; }
.gc-avatar { width: 38px; height: 38px; border-radius: 11px; background: var(--border-md); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.9rem; }
.gc-bubble { flex: 1; max-width: 78%; }
.gc-meta { display: flex; gap: 0.5rem; align-items: baseline; margin-bottom: 0.3rem; }
.gc-name { font-weight: 700; font-size: 0.88rem; }
.gc-time { color: var(--text-3); font-size: 0.75rem; }
.gc-text { background: var(--bg-raised); padding: 0.75rem 1rem; border-radius: 4px 16px 16px 16px; font-size: 0.93rem; line-height: 1.5; border: 1px solid var(--border-md); word-break: break-word; }
.gc-input-bar { display: flex; gap: 0.75rem; padding: 1rem 1.25rem; background: var(--bg-card); border-top: 1px solid var(--border); flex-shrink: 0; }
.gc-input { flex: 1; background: var(--bg-body); border: 1px solid var(--border-md); border-radius: 20px; padding: 0.75rem 1.25rem; color: var(--text); font-family: inherit; font-size: 0.93rem; resize: none; overflow-y: auto; max-height: 120px; transition: border-color 0.2s; }
.gc-input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(139,92,246,0.12); }
.gc-send { width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, var(--accent), #6366f1); color: white; border: none; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: transform 0.2s; flex-shrink: 0; box-shadow: 0 4px 12px rgba(139,92,246,0.35); }
.gc-send:hover { transform: scale(1.1); }
.gc-side { width: 250px; display: flex; flex-direction: column; background: var(--bg-card); border-radius: 20px; border: 1px solid var(--border-md); overflow: hidden; flex-shrink: 0; }
.gc-side-header { padding: 1rem 1.25rem; border-bottom: 1px solid var(--border-md); font-weight: 800; font-size: 0.9rem; display: flex; justify-content: space-between; align-items: center; }
.gc-members { flex: 1; overflow-y: auto; padding: 0.75rem; display: flex; flex-direction: column; gap: 0.4rem; }
.gc-member { display: flex; align-items: center; gap: 0.75rem; padding: 0.65rem 0.75rem; border-radius: 12px; background: rgba(0,0,0,0.15); transition: all 0.2s; }
.gc-member:hover { background: var(--bg-raised); transform: translateX(3px); }
.gc-add-btn { margin: 0.75rem; padding: 0.65rem; border: 1px dashed var(--border-md); border-radius: 12px; background: transparent; color: var(--text-2); font-weight: 600; font-size: 0.85rem; cursor: pointer; transition: all 0.2s; }
.gc-add-btn:hover { border-color: var(--accent); color: var(--accent); background: rgba(139,92,246,0.06); }
.status-dot { width: 9px; height: 9px; border-radius: 50%; border: 2px solid var(--bg-card); position: absolute; bottom: -1px; right: -1px; }
.gc-btn-join { background: linear-gradient(135deg,#10b981,#059669); color: white; border: none; padding: 0.5rem 1rem; border-radius: 10px; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; box-shadow: 0 4px 12px rgba(16,185,129,0.3); transition: all 0.2s; }
.gc-btn-join:hover { transform: translateY(-1px); }
.gc-btn-join.active { background: linear-gradient(135deg,#ef4444,#b91c1c); box-shadow: 0 4px 12px rgba(239,68,68,0.3); }
</style>


<div class="layout">
  <%- include('partials/sidebar', { page: 'social' }) %>

  <div class="main">
    <div class="gc-layout">
      <!-- Chat & Voice Main -->
      <div class="gc-main">
        <div class="gc-header">
          <div class="gc-title-group">
            <span class="badge badge-purple" style="font-size: 0.7rem; margin-right: 0.5rem;">GROUP</span>
            <div class="gc-title"><%= group.name %></div>
          </div>
          <button class="gc-btn-voice" id="btnVoice" onclick="toggleVoice()">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
            <span id="voiceBtnText">Join Voice</span>
          </button>
        </div>

        <!-- Voice / Video Room Area -->
        <div class="gc-voice-room" id="voiceRoom">
          <div class="gc-voice-bar">
            <div class="gc-voice-label">
              <div class="pulse-dot" style="background:#10b981;"></div> Voice Connected
            </div>
            <div class="gc-voice-actions">
              <button class="gc-v-btn" id="btnMute" onclick="toggleMute()" title="Mute">
                <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
              </button>
              <button class="gc-v-btn" id="btnScreen" onclick="toggleScreenShare()" title="Share Screen">
                <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </button>
            </div>
          </div>
          <div class="gc-screenshare" id="screenShareContainer">
            <video id="screenShareVideo" autoplay playsinline></video>
          </div>
          <div class="gc-voice-grid" id="voiceGrid">
            <div class="gc-voice-peer" id="peer-self">
              <div class="gc-voice-avatar" style="<%= user.avatarUrl ? 'background:url('+user.avatarUrl+') center/cover;color:transparent;' : '' %>"><%= user.avatarUrl ? '' : user.username.charAt(0).toUpperCase() %></div>
              <div class="gc-voice-name"><%= user.username %> (You)</div>
            </div>
          </div>
        </div>

        <!-- Messages -->
        <div class="gc-messages" id="msgContainer">
          <% messages.forEach(m => { %>
            <div class="gc-msg">
              <div class="gc-av-wrap">
                <div class="gc-avatar" style="<%= m.avatar_url ? 'background:url('+m.avatar_url+') center/cover;color:transparent;' : '' %>"><%= m.avatar_url ? '' : m.username.charAt(0).toUpperCase() %></div>
              </div>
              <div class="gc-bubble">
                <div class="gc-meta">
                  <span class="gc-name"><%= m.username %></span>
                  <span class="gc-time"><%= new Date(m.created_at).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}) %></span>
                </div>
                <div class="gc-text"><%= m.content %></div>
              </div>
            </div>
          <% }) %>
          <div id="chatBottom"></div>
        </div>

        <div class="gc-input-bar">
          <textarea id="msgInput" class="gc-input" placeholder="Message #<%= group.name %>..." rows="1" onkeydown="onKey(event)" oninput="autoGrow(this)"></textarea>
          <button class="gc-send" onclick="sendMsg()" title="Send">
            <svg width="17" height="17" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
          </button>
        </div>
      </div>

      <!-- Members Sidebar -->
      <div class="gc-side">
        <div class="gc-side-header">
          <span>Members</span>
          <span class="badge" style="background: var(--bg-raised); font-size: 0.7rem;"><%= members.length %></span>
        </div>
        <div class="gc-members">
          <% members.forEach(m => { %>
            <div class="gc-member" data-uid="<%= m.id %>">
              <div style="position:relative;flex-shrink:0;">
                <div class="gc-avatar" style="width:32px;height:32px;font-size:0.82rem;<%= m.avatar_url ? 'background:url('+m.avatar_url+') center/cover;color:transparent;' : '' %>"><%= m.avatar_url ? '' : m.username.charAt(0).toUpperCase() %></div>
                <div class="status-dot" style="background:<%= m.online_status === 'idle' ? '#f59e0b' : m.online_status === 'dnd' ? '#ef4444' : m.online_status === 'offline' ? '#6b7280' : '#22c55e' %>;"></div>
              </div>
              <span style="font-weight:600;font-size:0.87rem;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= m.username %></span>
              <% if (m.is_admin) { %>
                <span style="font-size:0.62rem;font-weight:700;background:rgba(139,92,246,0.15);color:var(--accent);border:1px solid rgba(139,92,246,0.3);border-radius:5px;padding:1px 5px;flex-shrink:0;">ADMIN</span>
              <% } else if (isGroupAdmin && m.id !== user.id) { %>
                <button onclick="setAdmin(<%= m.id %>, '<%= m.username %>')" title="Make Admin" style="background:none;border:none;color:var(--text-3);cursor:pointer;padding:2px;border-radius:4px;flex-shrink:0;transition:color 0.2s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-3)'">
                  <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
                </button>
              <% } %>
            </div>
          <% }) %>
        </div>
        <% if (isGroupAdmin) { %>
        <button class="gc-add-btn" onclick="addFriendToGroup()">+ Add Friend</button>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
const GROUP_ID      = <%= group.id %>;
const MY_ID         = <%= user.id %>;
const MY_NAME       = "<%= user.username %>";
const IS_GROUP_ADMIN = <%= isGroupAdmin ? 'true' : 'false' %>;

/* ── Chat ── */
const msgContainer = document.getElementById('msgContainer');
const msgInput     = document.getElementById('msgInput');
const socket       = io({ transports: ['websocket','polling'] });

socket.on('group_message', msg => {
  if (msg.group_id !== GROUP_ID) return;
  const time = new Date(msg.created_at).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});
  const div = document.createElement('div');
  div.className = 'gc-msg';
  div.innerHTML = `
    <div class="gc-avatar" style="${msg.avatar_url ? 'background: url('+msg.avatar_url+') center/cover; color: transparent;' : ''}">${msg.avatar_url ? '' : msg.username.charAt(0).toUpperCase()}</div>
    <div class="gc-bubble">
      <div class="gc-meta">
        <span class="gc-name">${msg.username}</span>
        <span class="gc-time">${time}</span>
      </div>
      <div class="gc-text">${msg.content}</div>
    </div>`;
  msgContainer.insertBefore(div, document.getElementById('chatBottom'));
  msgContainer.scrollTop = msgContainer.scrollHeight;
});

async function sendMsg() {
  const text = msgInput.value.trim();
  if(!text) return;
  msgInput.disabled = true;
  await fetch('/api/groups/' + GROUP_ID + '/message', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ content: text })
  });
  msgInput.value = '';
  msgInput.disabled = false;
  msgInput.focus();
}

function onKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMsg(); }
}
function autoGrow(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 120) + 'px';
}
msgContainer.scrollTop = msgContainer.scrollHeight;

async function addFriendToGroup() {
  const username = prompt("Enter friend's username to add:");
  if (!username) return;
  const res  = await fetch('/api/groups/' + GROUP_ID + '/add', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ username })
  });
  const data = await res.json();
  if (window.toast) toast(data.message, data.success ? 'ok' : 'err'); else alert(data.message);
  if (data.success) location.reload();
}

async function setAdmin(userId, username) {
  if (!confirm('Promote ' + username + ' to group admin?')) return;
  const res  = await fetch('/api/groups/' + GROUP_ID + '/set-admin', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ user_id: userId, is_admin: true })
  });
  const data = await res.json();
  if (window.toast) toast(data.message, data.success ? 'ok' : 'err'); else alert(data.message);
  if (data.success) location.reload();
}

/* ═══ VOICE — BroadcastChannel → hidden iframe ═══ */
let inVoice  = false;
let isMuted  = false;
let screenOn = false;
let _bc      = null;

function getBC() {
  if (_bc) return _bc;
  if (window.voicePersist) { _bc = window.voicePersist.getBC(); }
  return _bc;
}

/* Handle events FROM the iframe */
window._vcHandleMsg = function(data) {
  if (data.type === 'self_speaking') {
    const s = document.getElementById('peer-self');
    if (s) s.classList.toggle('speaking', data.speaking);
  }
  if (data.type === 'peer_joined') { addPeerUI(data.userId, data.username, data.avatarUrl); }
  if (data.type === 'peer_left')   { removePeerUI(data.userId); }
  if (data.type === 'peer_speaking') {
    const p = document.getElementById('peer-' + data.userId);
    if (p) p.classList.toggle('speaking', data.speaking);
  }
  if (data.type === 'screen_started') {
    screenOn = true;
    document.getElementById('btnScreen').classList.add('screen-on');
    document.getElementById('screenShareContainer').style.display = 'block';
  }
  if (data.type === 'screen_ended') {
    screenOn = false;
    document.getElementById('btnScreen').classList.remove('screen-on');
    document.getElementById('screenShareContainer').style.display = 'none';
  }
  if (data.type === 'error') { if (window.toast) toast(data.msg, 'err'); else alert(data.msg); }
};

function addPeerUI(id, name, avatarUrl) {
  if (document.getElementById('peer-' + id)) return;
  const div = document.createElement('div');
  div.className = 'gc-voice-peer'; div.id = 'peer-' + id;
  div.innerHTML =
    '<div class="gc-voice-avatar" style="' + (avatarUrl ? 'background:url(' + avatarUrl + ') center/cover;color:transparent;' : '') + '">' +
      (avatarUrl ? '' : name.charAt(0).toUpperCase()) + '</div>' +
    '<div class="gc-voice-name">' + name + '</div>';
  document.getElementById('voiceGrid').appendChild(div);
}

function removePeerUI(id) {
  const el = document.getElementById('peer-' + id);
  if (el) el.remove();
}

function cleanupVoiceUI() {
  inVoice = false; isMuted = false; screenOn = false;
  document.getElementById('voiceRoom').classList.remove('active');
  document.getElementById('btnVoice').classList.remove('active');
  document.getElementById('voiceBtnText').textContent = 'Join Voice';
  document.querySelectorAll('.gc-voice-peer:not(#peer-self)').forEach(e => e.remove());
  document.getElementById('screenShareContainer').style.display = 'none';
}

async function toggleVoice() {
  if (inVoice) {
    window.voicePersist && window.voicePersist.clear();
    cleanupVoiceUI();
  } else {
    /* Initialize iframe + BC via voicePersist */
    window.voicePersist && window.voicePersist.save(GROUP_ID, '<%= group.name %>');

    /* Wait for BC then send start command */
    let tries = 0;
    const wait = setInterval(() => {
      const bc = window.voicePersist && window.voicePersist.getBC();
      if (bc || tries++ > 20) {
        clearInterval(wait);
        if (bc) {
          _bc = bc;
          _bc.onmessage = (e) => window._vcHandleMsg(e.data);
          _bc.postMessage({ type: 'start' });
        }
      }
    }, 150);

    document.getElementById('voiceRoom').classList.add('active');
    document.getElementById('btnVoice').classList.add('active');
    document.getElementById('voiceBtnText').textContent = 'Leave Voice';
    inVoice = true;
  }
}

function toggleMute() {
  if (!inVoice) return;
  isMuted = !isMuted;
  const bc = getBC();
  if (bc) bc.postMessage({ type: isMuted ? 'mute' : 'unmute' });
  document.getElementById('btnMute').classList.toggle('muted', isMuted);
}

function toggleScreenShare() {
  if (!inVoice) return;
  const bc = getBC();
  if (!bc) return;
  bc.postMessage({ type: screenOn ? 'screen_stop' : 'screen_start' });
}

</script>
</body>
</html>
