<%- include('partials/head', { title: group.name + ' — ' + panelName }) %>

<style>
.gc-wrap { display:flex; height:calc(100vh - 70px); padding:1rem; gap:1rem; overflow:hidden; }

/* ── Main chat panel ── */
.gc-main { flex:1; display:flex; flex-direction:column; background:var(--bg-card); border:1px solid var(--border-md); border-radius:20px; overflow:hidden; position:relative; }
.gc-main::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; background:linear-gradient(90deg,#3b82f6,#8b5cf6,#ec4899); z-index:5; }

/* ── Header ── */
.gc-header { padding:0.9rem 1.25rem; border-bottom:1px solid var(--border-md); display:flex; align-items:center; justify-content:space-between; flex-shrink:0; background:rgba(255,255,255,0.015); }
.gc-header-left { display:flex; align-items:center; gap:0.75rem; }
.gc-group-icon { width:36px; height:36px; border-radius:10px; background:linear-gradient(135deg,#8b5cf6,#ec4899); display:flex; align-items:center; justify-content:center; font-weight:800; font-size:1rem; color:white; flex-shrink:0; }
.gc-group-name { font-size:1.05rem; font-weight:800; }
.gc-group-sub { font-size:0.72rem; color:var(--text-3); margin-top:1px; }
.gc-join-btn { display:flex; align-items:center; gap:0.4rem; padding:0.5rem 1rem; border-radius:10px; font-weight:700; font-size:0.82rem; border:none; cursor:pointer; transition:all 0.2s; }
.gc-join-btn.idle { background:rgba(16,185,129,0.12); border:1px solid rgba(16,185,129,0.3); color:#10b981; }
.gc-join-btn.idle:hover { background:rgba(16,185,129,0.22); }
.gc-join-btn.active-call { background:rgba(239,68,68,0.12); border:1px solid rgba(239,68,68,0.3); color:#ef4444; }

/* ── Voice room ── */
.gc-voice-room { display:none; padding:0.85rem 1.25rem; background:rgba(0,0,0,0.25); border-bottom:1px solid var(--border-md); flex-shrink:0; }
.gc-voice-room.active { display:block; animation:slideDown 0.3s ease; }
@keyframes slideDown { from{transform:translateY(-10px);opacity:0;} to{transform:translateY(0);opacity:1;} }
.gc-voice-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:0.75rem; }
.gc-voice-live { display:flex; align-items:center; gap:0.5rem; font-size:0.8rem; font-weight:700; color:#10b981; }
.gc-voice-controls { display:flex; gap:0.4rem; }
.gc-v-btn { width:34px; height:34px; border-radius:9px; background:rgba(255,255,255,0.06); border:1px solid var(--border-md); color:var(--text); display:flex; align-items:center; justify-content:center; cursor:pointer; transition:all 0.2s; }
.gc-v-btn:hover { background:rgba(139,92,246,0.15); border-color:var(--accent); color:var(--accent); }
.gc-v-btn.muted { background:rgba(239,68,68,0.12); color:#ef4444; border-color:rgba(239,68,68,0.3); }
.gc-v-btn.screen-on { background:rgba(59,130,246,0.12); color:#60a5fa; border-color:rgba(59,130,246,0.3); }
.gc-peers { display:flex; flex-wrap:wrap; gap:0.6rem; }
.gc-peer { background:rgba(255,255,255,0.04); border:2px solid rgba(255,255,255,0.08); border-radius:14px; padding:0.7rem 1rem; display:flex; flex-direction:column; align-items:center; gap:0.35rem; min-width:80px; transition:all 0.3s; }
.gc-peer.speaking { border-color:#10b981; box-shadow:0 0 16px rgba(16,185,129,0.3); background:rgba(16,185,129,0.07); }
.gc-peer-av { width:44px; height:44px; border-radius:50%; background:linear-gradient(135deg,var(--accent),#ec4899); display:flex; align-items:center; justify-content:center; font-size:1.1rem; font-weight:800; color:white; }
.gc-peer-name { font-size:0.72rem; font-weight:600; color:var(--text-2); white-space:nowrap; }
.gc-screen-box { display:none; width:100%; max-height:320px; border-radius:10px; overflow:hidden; background:#000; border:1px solid var(--border-md); margin-top:0.75rem; }
.gc-screen-box video { width:100%; height:100%; object-fit:contain; display:block; }

/* ── Messages ── */
.gc-msgs { flex:1; overflow-y:auto; padding:1.25rem; display:flex; flex-direction:column; gap:0.85rem; scroll-behavior:smooth; }
.gc-msgs::-webkit-scrollbar { width:4px; }
.gc-msgs::-webkit-scrollbar-thumb { background:var(--border-md); border-radius:4px; }
.gc-msg { display:flex; gap:0.75rem; animation:fadeInUp 0.25s ease; }
@keyframes fadeInUp { from{opacity:0;transform:translateY(6px);} to{opacity:1;transform:translateY(0);} }
.gc-av { width:36px; height:36px; border-radius:10px; background:var(--border-md); display:flex; align-items:center; justify-content:center; font-weight:700; font-size:0.88rem; flex-shrink:0; }
.gc-bubble { flex:1; max-width:80%; }
.gc-meta { display:flex; gap:0.45rem; align-items:baseline; margin-bottom:0.25rem; }
.gc-uname { font-weight:700; font-size:0.87rem; }
.gc-time { color:var(--text-3); font-size:0.73rem; }
.gc-text { background:var(--bg-raised); padding:0.65rem 0.95rem; border-radius:4px 14px 14px 14px; font-size:0.91rem; line-height:1.55; border:1px solid var(--border-md); word-break:break-word; display:inline-block; }

/* ── Input ── */
.gc-input-bar { display:flex; gap:0.65rem; padding:0.85rem 1rem; border-top:1px solid var(--border-md); align-items:flex-end; flex-shrink:0; }
.gc-textarea { flex:1; background:var(--bg-body); border:1px solid var(--border-md); border-radius:14px; padding:0.65rem 1rem; color:var(--text); font-family:inherit; font-size:0.91rem; resize:none; overflow-y:auto; max-height:120px; transition:border-color 0.2s; line-height:1.5; }
.gc-textarea:focus { outline:none; border-color:var(--accent); box-shadow:0 0 0 3px rgba(139,92,246,0.1); }
.gc-send { width:38px; height:38px; border-radius:50%; background:linear-gradient(135deg,var(--accent),#6366f1); color:white; border:none; display:flex; align-items:center; justify-content:center; cursor:pointer; transition:transform 0.2s; flex-shrink:0; box-shadow:0 4px 12px rgba(139,92,246,0.35); }
.gc-send:hover { transform:scale(1.1); }

/* ── Sidebar ── */
.gc-side { width:220px; flex-shrink:0; display:flex; flex-direction:column; background:var(--bg-card); border:1px solid var(--border-md); border-radius:20px; overflow:hidden; }
.gc-side-head { padding:0.85rem 1rem; border-bottom:1px solid var(--border-md); font-size:0.78rem; font-weight:800; text-transform:uppercase; letter-spacing:0.07em; color:var(--text-2); display:flex; align-items:center; justify-content:space-between; flex-shrink:0; }
.gc-members-list { flex:1; overflow-y:auto; padding:0.6rem; display:flex; flex-direction:column; gap:0.3rem; }
.gc-member { display:flex; align-items:center; gap:0.6rem; padding:0.55rem 0.65rem; border-radius:10px; transition:background 0.2s; }
.gc-member:hover { background:var(--bg-raised); }
.gc-m-av { width:30px; height:30px; border-radius:8px; background:var(--border-md); display:flex; align-items:center; justify-content:center; font-size:0.78rem; font-weight:700; flex-shrink:0; }
.gc-m-info { flex:1; min-width:0; }
.gc-m-name { font-size:0.84rem; font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.gc-m-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
.gc-admin-badge { font-size:0.58rem; font-weight:800; background:rgba(139,92,246,0.12); color:var(--accent); border:1px solid rgba(139,92,246,0.25); border-radius:4px; padding:1px 5px; flex-shrink:0; }
.gc-promote-btn { background:none; border:none; color:var(--text-3); cursor:pointer; padding:2px; border-radius:4px; flex-shrink:0; opacity:0.6; transition:all 0.2s; }
.gc-promote-btn:hover { opacity:1; color:var(--accent); }
.gc-add-member { margin:0.6rem; padding:0.6rem; border:1px dashed var(--border-md); border-radius:10px; background:transparent; color:var(--text-3); font-size:0.82rem; font-weight:600; cursor:pointer; transition:all 0.2s; text-align:center; }
.gc-add-member:hover { border-color:var(--accent); color:var(--accent); background:rgba(139,92,246,0.05); }
</style>

<div class="layout">
  <%- include('partials/sidebar', { page: 'social' }) %>
  <div class="main">

    <div class="topbar">
      <div class="topbar-left">
        <a href="/social" style="color:var(--text-3);display:flex;align-items:center;gap:0.3rem;font-size:0.82rem;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-3)'">
          <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          Social
        </a>
        <span style="color:var(--border-md);margin:0 0.25rem;">/</span>
        <div class="topbar-title"><%= group.name %></div>
      </div>
    </div>

    <div class="gc-wrap">

      <!-- ── CHAT MAIN ── -->
      <div class="gc-main">

        <!-- Header -->
        <div class="gc-header">
          <div class="gc-header-left">
            <div class="gc-group-icon"><%= group.name.charAt(0).toUpperCase() %></div>
            <div>
              <div class="gc-group-name"><%= group.name %></div>
              <div class="gc-group-sub"><%= members.length %> members • Private Group</div>
            </div>
          </div>
          <button class="gc-join-btn idle" id="btnVoice" onclick="toggleVoice()">
            <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
            <span id="voiceBtnTxt">Join Voice</span>
          </button>
        </div>

        <!-- Voice Room -->
        <div class="gc-voice-room" id="voiceRoom">
          <div class="gc-voice-top">
            <div class="gc-voice-live">
              <div class="pulse-dot" style="background:#10b981;width:7px;height:7px;"></div>
              Voice Connected
            </div>
            <div class="gc-voice-controls">
              <button class="gc-v-btn" id="btnMute" onclick="toggleMute()" title="Mute">
                <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
              </button>
              <button class="gc-v-btn" id="btnScreen" onclick="toggleScreenShare()" title="Screen Share">
                <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </button>
            </div>
          </div>
          <div class="gc-screen-box" id="screenBox"><video id="screenVideo" autoplay playsinline></video></div>
          <div class="gc-peers" id="peersGrid">
            <div class="gc-peer" id="peer-self">
              <div class="gc-peer-av" style="<%= user.avatarUrl ? 'background:url('+user.avatarUrl+') center/cover;color:transparent;' : '' %>">
                <%= user.avatarUrl ? '' : user.username.charAt(0).toUpperCase() %>
              </div>
              <div class="gc-peer-name"><%= user.username %> (You)</div>
            </div>
          </div>
        </div>

        <!-- Messages -->
        <div class="gc-msgs" id="msgContainer">
          <% messages.forEach(m => { %>
          <div class="gc-msg">
            <div class="gc-av" style="<%= m.avatar_url ? 'background:url('+m.avatar_url+') center/cover;color:transparent;' : '' %>">
              <%= m.avatar_url ? '' : m.username.charAt(0).toUpperCase() %>
            </div>
            <div class="gc-bubble">
              <div class="gc-meta">
                <span class="gc-uname"><%= m.username %></span>
                <span class="gc-time"><%= new Date(m.created_at).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}) %></span>
              </div>
              <div class="gc-text"><%= m.content %></div>
            </div>
          </div>
          <% }) %>
          <div id="chatBottom"></div>
        </div>

        <!-- Input -->
        <div class="gc-input-bar">
          <textarea id="msgInput" class="gc-textarea" placeholder="Message #<%= group.name %>…" rows="1" onkeydown="onKey(event)" oninput="autoGrow(this)"></textarea>
          <button class="gc-send" onclick="sendMsg()">
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="transform:translateX(1px)"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
          </button>
        </div>

      </div><!-- /.gc-main -->

      <!-- ── MEMBERS SIDEBAR ── -->
      <div class="gc-side">
        <div class="gc-side-head">
          <span>Members</span>
          <span style="background:var(--bg-raised);border-radius:20px;padding:1px 8px;font-size:0.7rem;"><%= members.length %></span>
        </div>

        <div class="gc-members-list">
          <% members.forEach(m => { %>
            <%
              const dotColor = m.online_status === 'idle' ? '#f59e0b'
                : m.online_status === 'dnd' ? '#ef4444'
                : m.online_status === 'offline' ? '#6b7280' : '#22c55e';
              const statusLabel = m.online_status === 'idle' ? 'Idle'
                : m.online_status === 'dnd' ? 'Do Not Disturb'
                : m.online_status === 'offline' ? 'Offline' : 'Online';
            %>
            <div class="gc-member"
              data-uid="<%= m.id %>"
              data-uname="<%= m.username %>"
              data-is-admin="<%= m.is_admin ? '1' : '0' %>"
              data-status="<%= statusLabel %>"
              onclick="openMemberMenu(this, event)"
              style="cursor:pointer;"
            >
              <div style="position:relative;flex-shrink:0;">
                <div class="gc-m-av" style="<%= m.avatar_url ? 'background:url('+m.avatar_url+') center/cover;color:transparent;' : '' %>">
                  <%= m.avatar_url ? '' : m.username.charAt(0).toUpperCase() %>
                </div>
                <div style="width:8px;height:8px;border-radius:50%;background:<%= dotColor %>;border:1.5px solid var(--bg-card);position:absolute;bottom:-1px;right:-1px;"></div>
              </div>
              <div class="gc-m-info">
                <div class="gc-m-name"><%= m.username %></div>
                <div style="font-size:0.7rem;color:var(--text-3);margin-top:1px;"><%= statusLabel %></div>
              </div>
              <% if (m.is_admin) { %>
                <span class="gc-admin-badge">ADMIN</span>
              <% } %>
            </div>
          <% }) %>
        </div>

        <% if (isGroupAdmin) { %>
          <button class="gc-add-member" onclick="addMember()">+ Add Friend</button>
        <% } %>
      </div>

      <!-- Member Context Menu -->
      <div id="memberCtxMenu" style="
        display:none; position:fixed; z-index:9990;
        background:var(--bg-card); border:1px solid var(--border-md);
        border-radius:14px; min-width:180px;
        box-shadow:0 12px 40px rgba(0,0,0,0.55);
        overflow:hidden; animation:fadeIn 0.15s ease;
      ">
        <div id="ctxHeader" style="padding:0.75rem 1rem 0.5rem; border-bottom:1px solid var(--border-md);">
          <div id="ctxName" style="font-weight:800;font-size:0.92rem;"></div>
          <div id="ctxStatus" style="font-size:0.72rem;color:var(--text-3);margin-top:2px;"></div>
        </div>
        <div id="ctxAdminRow" style="display:none; padding:0.4rem 0.5rem;">
          <button onclick="ctxMakeAdmin()" style="
            width:100%; background:rgba(139,92,246,0.1);
            border:1px solid rgba(139,92,246,0.2);
            border-radius:9px; color:var(--accent);
            padding:0.55rem 0.85rem; font-weight:700; font-size:0.83rem;
            cursor:pointer; display:flex; align-items:center; gap:0.5rem;
            transition:background 0.2s; text-align:left;
          " onmouseover="this.style.background='rgba(139,92,246,0.2)'" onmouseout="this.style.background='rgba(139,92,246,0.1)'">
            <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            Make Group Admin
          </button>
        </div>
        <div style="padding:0.4rem 0.5rem 0.5rem;" id="ctxAlreadyAdmin" style="display:none;">
          <div style="padding:0.4rem 0.85rem;font-size:0.78rem;color:var(--text-3);">✓ Already an admin</div>
        </div>
      </div>

    </div><!-- /.gc-wrap -->
  </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
const GROUP_ID       = <%= group.id %>;
const MY_ID          = <%= user.id %>;
const MY_NAME        = "<%= user.username %>";
const IS_GROUP_ADMIN = <%= isGroupAdmin ? 'true' : 'false' %>;

const msgContainer = document.getElementById('msgContainer');
const msgInput     = document.getElementById('msgInput');
const socket       = io({ transports: ['websocket','polling'] });

/* ── Chat ── */
socket.on('group_message', msg => {
  if (msg.group_id !== GROUP_ID) return;
  appendMsg(msg);
  msgContainer.scrollTop = msgContainer.scrollHeight;
});

function appendMsg(m) {
  const div = document.createElement('div');
  div.className = 'gc-msg';
  const t = new Date(m.created_at || Date.now()).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
  const av = m.avatar_url
    ? `background:url(${m.avatar_url}) center/cover;color:transparent;`
    : '';
  div.innerHTML = `
    <div class="gc-av" style="${av}">${m.avatar_url ? '' : (m.username||'?').charAt(0).toUpperCase()}</div>
    <div class="gc-bubble">
      <div class="gc-meta">
        <span class="gc-uname">${escH(m.username||'')}</span>
        <span class="gc-time">${t}</span>
      </div>
      <div class="gc-text">${escH(m.content||'')}</div>
    </div>`;
  msgContainer.appendChild(div);
}
function escH(s){ const d=document.createElement('div');d.textContent=s;return d.innerHTML; }

async function sendMsg() {
  const text = msgInput.value.trim();
  if (!text) return;
  msgInput.value = ''; msgInput.style.height = '';
  await fetch('/api/groups/' + GROUP_ID + '/message', {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ content: text })
  });
}
function onKey(e)    { if (e.key==='Enter' && !e.shiftKey) { e.preventDefault(); sendMsg(); } }
function autoGrow(el){ el.style.height='auto'; el.style.height = Math.min(el.scrollHeight,120)+'px'; }
msgContainer.scrollTop = msgContainer.scrollHeight;

/* ── Add Member / Set Admin ── */
async function addMember() {
  const username = prompt("Friend's username to add:");
  if (!username) return;
  const res  = await fetch('/api/groups/'+GROUP_ID+'/add',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username})});
  const data = await res.json();
  toast(data.message, data.success?'ok':'err');
  if (data.success) setTimeout(()=>location.reload(),800);
}
async function setAdmin(userId, username) {
  const res  = await fetch('/api/groups/'+GROUP_ID+'/set-admin',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({user_id:userId,is_admin:true})});
  const data = await res.json();
  toast(data.message, data.success?'ok':'err');
  if (data.success) setTimeout(()=>location.reload(),800);
}

/* ── Member Context Menu (left click) ── */
let _ctxUserId = null, _ctxUsername = null;
const _ctxMenu = document.getElementById('memberCtxMenu');

function openMemberMenu(el, e) {
  e.stopPropagation();
  _ctxUserId   = Number(el.dataset.uid);
  _ctxUsername = el.dataset.uname;
  const isAdmin  = el.dataset.isAdmin === '1';
  const status   = el.dataset.status || 'Online';

  document.getElementById('ctxName').textContent   = _ctxUsername;
  document.getElementById('ctxStatus').textContent = status;

  /* Show "Make Admin" button only for group admins, targeting non-admins, non-self */
  const canPromote = IS_GROUP_ADMIN && !isAdmin && _ctxUserId !== MY_ID;
  document.getElementById('ctxAdminRow').style.display     = canPromote ? 'block' : 'none';
  document.getElementById('ctxAlreadyAdmin').style.display = (!canPromote && isAdmin) ? 'block' : 'none';

  /* Position near the click */
  const x = Math.min(e.clientX, window.innerWidth  - 200);
  const y = Math.min(e.clientY, window.innerHeight - 160);
  _ctxMenu.style.left    = x + 'px';
  _ctxMenu.style.top     = y + 'px';
  _ctxMenu.style.display = 'block';
}

function ctxMakeAdmin() {
  _ctxMenu.style.display = 'none';
  setAdmin(_ctxUserId, _ctxUsername);
}

/* Close on outside click */
document.addEventListener('click', e => {
  if (_ctxMenu.style.display !== 'none' && !_ctxMenu.contains(e.target)) {
    _ctxMenu.style.display = 'none';
  }
});
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') _ctxMenu.style.display = 'none';
});

/* ── Voice via BroadcastChannel → hidden iframe ── */
let inVoice=false, isMuted=false, screenOn=false, _bc=null;
function getBC(){ if(!_bc && window.voicePersist) _bc=window.voicePersist.getBC(); return _bc; }

window._vcHandleMsg = function(d) {
  if(d.type==='self_speaking'){ const s=document.getElementById('peer-self'); if(s) s.classList.toggle('speaking',d.speaking); }
  if(d.type==='peer_joined')  addPeerUI(d.userId,d.username,d.avatarUrl);
  if(d.type==='peer_left')    removePeerUI(d.userId);
  if(d.type==='peer_speaking'){ const p=document.getElementById('peer-'+d.userId); if(p) p.classList.toggle('speaking',d.speaking); }
  if(d.type==='screen_started'){ screenOn=true; document.getElementById('btnScreen').classList.add('screen-on'); document.getElementById('screenBox').style.display='block'; }
  if(d.type==='screen_ended')  { screenOn=false; document.getElementById('btnScreen').classList.remove('screen-on'); document.getElementById('screenBox').style.display='none'; }
  if(d.type==='error') toast(d.msg,'err');
};
function addPeerUI(id,name,av){
  if(document.getElementById('peer-'+id)) return;
  const d=document.createElement('div'); d.className='gc-peer'; d.id='peer-'+id;
  d.innerHTML=`<div class="gc-peer-av" style="${av?'background:url('+av+') center/cover;color:transparent;':''}">${av?'':name.charAt(0).toUpperCase()}</div><div class="gc-peer-name">${name}</div>`;
  document.getElementById('peersGrid').appendChild(d);
}
function removePeerUI(id){ const e=document.getElementById('peer-'+id); if(e) e.remove(); }

async function toggleVoice(){
  if(inVoice){
    window.voicePersist && window.voicePersist.clear();
    inVoice=false; isMuted=false; screenOn=false;
    document.getElementById('voiceRoom').classList.remove('active');
    document.getElementById('btnVoice').className='gc-join-btn idle';
    document.getElementById('voiceBtnTxt').textContent='Join Voice';
    document.querySelectorAll('.gc-peer:not(#peer-self)').forEach(e=>e.remove());
    document.getElementById('screenBox').style.display='none';
  } else {
    window.voicePersist && window.voicePersist.save(GROUP_ID,'<%= group.name %>');
    let tries=0;
    const wait=setInterval(()=>{
      const bc=window.voicePersist && window.voicePersist.getBC();
      if(bc||tries++>20){ clearInterval(wait); if(bc){ _bc=bc; _bc.onmessage=e=>window._vcHandleMsg(e.data); _bc.postMessage({type:'start'}); } }
    },150);
    document.getElementById('voiceRoom').classList.add('active');
    document.getElementById('btnVoice').className='gc-join-btn active-call';
    document.getElementById('voiceBtnTxt').textContent='Leave Voice';
    inVoice=true;
  }
}
function toggleMute(){
  if(!inVoice) return; isMuted=!isMuted;
  const bc=getBC(); if(bc) bc.postMessage({type:isMuted?'mute':'unmute'});
  document.getElementById('btnMute').classList.toggle('muted',isMuted);
}
function toggleScreenShare(){
  if(!inVoice) return; const bc=getBC(); if(!bc) return;
  bc.postMessage({type:screenOn?'screen_stop':'screen_start'});
}
</script>
</body>
</html>
