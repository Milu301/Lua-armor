<%- include('partials/head', { title: (typeof panelName !== 'undefined' ? panelName : 'Aurora Hub') + ' — Home' }) %>

<style>
/* Reset & Fonts */
@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&display=swap');
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');

:root {
  --bg: #07070f;
  --surface: #12121a;
  --surface-glass: rgba(18, 18, 26, 0.6);
  --border: rgba(255, 255, 255, 0.12);
  --border-glow: rgba(139, 92, 246, 0.4);
  --primary: #8b5cf6;
  --primary-light: #a78bfa;
  --secondary: #0ea5e9;
  --accent: #f59e0b;
  --text: #f8fafc;
  --text-dim: #94a3b8;
}

body {
  font-family: 'Space Grotesk', sans-serif;
  background-color: var(--bg);
  color: var(--text);
  margin: 0;
  overflow-x: hidden;
  line-height: 1.5;
}

/* Scrollbar */
::-webkit-scrollbar { width: 10px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 5px; }
::-webkit-scrollbar-thumb:hover { background: var(--primary); }

/* Epic Ambient Background */
.ambient-bg {
  position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: -2;
  background: 
    radial-gradient(circle at 20% 30%, rgba(139, 92, 246, 0.2) 0%, transparent 40%),
    radial-gradient(circle at 80% 70%, rgba(14, 165, 233, 0.15) 0%, transparent 40%),
    radial-gradient(circle at 50% 50%, rgba(245, 158, 11, 0.05) 0%, transparent 60%);
  filter: blur(60px);
  animation: pulse-bg 10s infinite alternate;
}
@keyframes pulse-bg {
  0% { transform: scale(1); opacity: 0.8; }
  100% { transform: scale(1.1); opacity: 1; }
}

.noise-overlay {
  position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: -1;
  opacity: 0.03; pointer-events: none;
  background-image: url('data:image/svg+xml,%3Csvg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"%3E%3Cfilter id="noiseFilter"%3E%3CfeTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/%3E%3C/filter%3E%3Crect width="100%25" height="100%25" filter="url(%23noiseFilter)"/%3E%3C/svg%3E');
}

/* Navbar */
.nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 1rem 4rem; display: flex; justify-content: space-between; align-items: center;
  background: rgba(7, 7, 15, 0.7); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
  border-bottom: 1px solid var(--border); transition: all 0.3s;
}
.nav-brand {
  display: flex; align-items: center; gap: 1rem; text-decoration: none;
}
.nav-brand img { width: 44px; height: 44px; border-radius: 12px; border: 1px solid var(--border); box-shadow: 0 0 15px rgba(139,92,246,0.2); }
.nav-brand span { font-weight: 800; font-size: 1.5rem; color: #fff; letter-spacing: -0.5px; }
.nav-links { display: flex; gap: 2.5rem; }
.nav-links a {
  color: var(--text-dim); text-decoration: none; font-weight: 600; font-size: 0.95rem;
  transition: 0.3s; position: relative;
}
.nav-links a:hover { color: #fff; }
.nav-links a::after {
  content: ''; position: absolute; bottom: -5px; left: 0; width: 0%; height: 2px;
  background: var(--primary-light); transition: 0.3s;
}
.nav-links a:hover::after { width: 100%; }

/* Buttons */
.btn {
  display: inline-flex; align-items: center; gap: 0.5rem; justify-content: center;
  padding: 0.8rem 1.8rem; font-family: 'Space Grotesk', sans-serif; font-weight: 700;
  border-radius: 12px; text-decoration: none; transition: 0.3s; cursor: pointer;
  border: none; position: relative; overflow: hidden;
}
.btn-glow {
  background: linear-gradient(135deg, var(--primary), #6366f1); color: #fff;
  box-shadow: 0 0 20px rgba(139, 92, 246, 0.4), inset 0 1px 1px rgba(255,255,255,0.2);
}
.btn-glow:hover {
  transform: translateY(-2px) scale(1.02);
  box-shadow: 0 10px 30px rgba(124, 58, 237, 0.5), inset 0 1px 1px rgba(255,255,255,0.3);
}
.btn-gold {
  background: linear-gradient(135deg, #f59e0b, #ea580c); color: #fff;
  box-shadow: 0 0 20px rgba(245, 158, 11, 0.3);
}
.btn-gold:hover {
  transform: translateY(-2px); box-shadow: 0 10px 30px rgba(245, 158, 11, 0.5);
}
.btn-glass {
  background: rgba(255,255,255,0.03); color: #fff; border: 1px solid var(--border);
}
.btn-glass:hover {
  background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.2);
}

/* YouTube Epic Section */
.yt-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;
  margin-top: 3rem;
}
.yt-card {
  background: var(--surface-glass); border: 1px solid var(--border); border-radius: 20px;
  overflow: hidden; transition: 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  position: relative; text-decoration: none; color: var(--text);
  box-shadow: 0 10px 30px rgba(0,0,0,0.3); display: block;
}
.yt-card:hover {
  transform: translateY(-10px); border-color: #ff0000;
  box-shadow: 0 20px 40px rgba(255,0,0,0.2), 0 0 20px rgba(255,0,0,0.4);
}
.yt-card .yt-thumb {
  width: 100%; aspect-ratio: 16/9; object-fit: cover; border-bottom: 1px solid var(--border);
  transition: 0.4s;
}
.yt-card:hover .yt-thumb {
  transform: scale(1.05);
}
.yt-card .yt-thumb-wrapper {
  overflow: hidden; position: relative;
}
.yt-card .yt-play-btn {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) scale(0.8);
  color: #ff0000; font-size: 3rem; opacity: 0; transition: 0.3s;
  filter: drop-shadow(0 0 10px rgba(255,0,0,0.8));
}
.yt-card:hover .yt-play-btn {
  opacity: 1; transform: translate(-50%, -50%) scale(1);
}
.yt-info {
  padding: 1.5rem;
}
.yt-title {
  font-family: 'Space Grotesk', sans-serif; font-size: 1.1rem; font-weight: 700;
  margin: 0 0 0.5rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.yt-date {
  font-size: 0.85rem; color: var(--text-dim);
}

/* Hero Section */
.hero {
  min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center;
  text-align: center; padding: 0 2rem; position: relative;
}
.hero-pill {
  background: rgba(124, 58, 237, 0.1); border: 1px solid rgba(124, 58, 237, 0.3);
  padding: 0.5rem 1.5rem; border-radius: 50px; color: var(--primary-light);
  font-weight: 600; font-size: 0.9rem; margin-bottom: 2rem; letter-spacing: 1px; text-transform: uppercase;
  display: inline-flex; align-items: center; gap: 0.5rem;
  animation: float 3s ease-in-out infinite;
}
.hero h1 {
  font-size: clamp(3rem, 8vw, 6.5rem); font-weight: 900; line-height: 1;
  margin: 0 0 1.5rem 0; letter-spacing: -2px;
  background: linear-gradient(to bottom right, #ffffff, #a78bfa, #38bdf8);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.hero p {
  font-family: 'Inter', sans-serif; font-size: clamp(1rem, 2vw, 1.25rem);
  color: var(--text-dim); max-width: 600px; margin: 0 auto 3rem; line-height: 1.7;
}

/* Floating Elements around Hero */
.float-icon {
  position: absolute; width: 60px; height: 60px; border-radius: 16px;
  background: rgba(255,255,255,0.03); border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center; font-size: 1.5rem;
  backdrop-filter: blur(10px); animation: float-slow 6s ease-in-out infinite;
  color: #fff;
}
.fi-1 { top: 20%; left: 15%; animation-delay: 0s; color: #a78bfa; }
.fi-2 { top: 30%; right: 15%; animation-delay: 1s; color: #38bdf8; }
.fi-3 { bottom: 25%; left: 20%; animation-delay: 2s; color: #f59e0b; }
.fi-4 { bottom: 20%; right: 20%; animation-delay: 3s; color: #10b981; }

/* Pricing / Tiers Section */
.section { padding: 8rem 2rem; max-width: 1400px; margin: 0 auto; }
.section-head { text-align: center; margin-bottom: 5rem; }
.section-head h2 { font-size: 3.5rem; font-weight: 800; margin: 0 0 1rem; letter-spacing: -1px; }
.section-head p { font-family: 'Inter', sans-serif; color: var(--text-dim); font-size: 1.1rem; }

.tiers-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 2.5rem; align-items: center; justify-content: center; max-width: 1000px; margin: 0 auto; }
.tier-card {
  background: var(--surface-glass); border: 1px solid var(--border); border-radius: 30px;
  padding: 3rem; position: relative; overflow: hidden; transition: 0.4s;
  backdrop-filter: blur(20px); display: flex; flex-direction: column;
}
.tier-card:hover { transform: translateY(-10px); border-color: rgba(255,255,255,0.1); }
.tier-card.premium {
  background: linear-gradient(180deg, rgba(30, 27, 75, 0.8) 0%, rgba(15, 23, 42, 0.8) 100%);
  border-color: rgba(124, 58, 237, 0.5); transform: scale(1.05); z-index: 10;
  box-shadow: 0 20px 50px rgba(0,0,0,0.5), inset 0 0 0 1px rgba(124, 58, 237, 0.3);
}
.tier-card.premium:hover { transform: scale(1.05) translateY(-10px); border-color: var(--primary-light); box-shadow: 0 30px 60px rgba(124, 58, 237, 0.2); }

.tier-badge {
  position: absolute; top: 1.5rem; right: 1.5rem; background: rgba(245, 158, 11, 0.2);
  color: #fcd34d; padding: 0.4rem 1rem; border-radius: 20px; font-size: 0.8rem; font-weight: 700;
  border: 1px solid rgba(245, 158, 11, 0.4);
}
.tier-icon {
  width: 70px; height: 70px; border-radius: 20px; display: flex; align-items: center; justify-content: center;
  font-size: 2rem; margin-bottom: 2rem;
}
.tier-free .tier-icon { background: rgba(255,255,255,0.05); color: #94a3b8; }
.tier-premium .tier-icon { background: linear-gradient(135deg, var(--primary), #f59e0b); color: #fff; box-shadow: 0 10px 20px rgba(245, 158, 11, 0.2); }

.tier-title { font-size: 2rem; font-weight: 800; margin: 0 0 0.5rem; }
.tier-desc { font-family: 'Inter', sans-serif; color: var(--text-dim); margin-bottom: 2rem; font-size: 0.95rem; }

.tier-features { list-style: none; padding: 0; margin: 0 0 2.5rem; font-family: 'Inter', sans-serif; flex-grow: 1; }
.tier-features li { display: flex; align-items: flex-start; gap: 1rem; margin-bottom: 1.2rem; font-size: 1.05rem; }
.tier-free .tier-features li i { color: #64748b; margin-top: 4px; }
.tier-premium .tier-features li i { color: #10b981; margin-top: 4px; }

/* Feature Showcase */
.showcase { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; padding: 8rem 2rem; max-width: 1400px; margin: 0 auto; }
.showcase-text h3 { font-size: 3rem; font-weight: 800; line-height: 1.1; margin-bottom: 1.5rem; }
.showcase-text p { font-family: 'Inter', sans-serif; color: var(--text-dim); font-size: 1.1rem; margin-bottom: 2rem; }
.showcase-visual { position: relative; }
.visual-box {
  background: rgba(15, 15, 20, 0.6); border: 1px solid var(--border); border-radius: 30px;
  padding: 2rem; backdrop-filter: blur(20px); position: relative; z-index: 2;
  box-shadow: 0 25px 50px rgba(0,0,0,0.5);
}
.visual-glow {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
  width: 120%; height: 120%; background: radial-gradient(circle, rgba(124, 58, 237, 0.2) 0%, transparent 60%);
  z-index: 1; pointer-events: none;
}
.code-window {
  background: #0d0d12; border: 1px solid rgba(255,255,255,0.05); border-radius: 16px; overflow: hidden;
}
.code-header { background: #15151a; padding: 1rem; display: flex; gap: 8px; border-bottom: 1px solid rgba(255,255,255,0.05); }
.dot { width: 12px; height: 12px; border-radius: 50%; }
.dot-r { background: #ef4444; } .dot-y { background: #f59e0b; } .dot-g { background: #10b981; }
.code-body { padding: 1.5rem; font-family: monospace; color: #a78bfa; font-size: 0.9rem; overflow-x: auto; white-space: pre-wrap; word-wrap: break-word; }

/* Grid of mini features */
.grid-features { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; margin-top: 4rem; }
.g-card { background: rgba(255,255,255,0.02); border: 1px solid var(--border); border-radius: 24px; padding: 2.5rem; transition: 0.3s; }
.g-card:hover { background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.1); transform: translateY(-5px); }
.g-icon { font-size: 2.5rem; margin-bottom: 1.5rem; color: var(--primary-light); }

/* Animations */
@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
@keyframes float-slow { 0%, 100% { transform: translateY(0) rotate(0deg); } 50% { transform: translateY(-20px) rotate(5deg); } }

/* Marquee */
.marquee-wrapper { width: 100%; overflow: hidden; padding: 3rem 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); background: rgba(0,0,0,0.3); }
.marquee { display: flex; gap: 3rem; width: max-content; animation: marquee 40s linear infinite; }
.m-item { font-size: 1.5rem; font-weight: 800; color: rgba(255,255,255,0.2); text-transform: uppercase; letter-spacing: 2px; display: flex; align-items: center; gap: 1rem; }
.m-item i { color: rgba(124, 58, 237, 0.5); }
@keyframes marquee { to { transform: translateX(-50%); } }

/* Footer */
.footer { border-top: 1px solid var(--border); padding: 4rem 2rem; text-align: center; color: var(--text-dim); background: #030305; font-family: 'Inter', sans-serif; }

/* Responsive */
@media (max-width: 1024px) {
  .tier-card.premium { transform: scale(1); }
  .tier-card.premium:hover { transform: translateY(-10px); }
  .showcase { grid-template-columns: 1fr; gap: 3rem; }
}
@media (max-width: 768px) {
  .nav { padding: 1rem 1.5rem; }
  .nav-links {
    position: fixed; top: 0; right: -100%; width: 250px; height: 100vh;
    background: rgba(7, 7, 15, 0.95); backdrop-filter: blur(24px);
    flex-direction: column; padding: 5rem 2rem; gap: 2rem;
    transition: right 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    border-left: 1px solid var(--border);
    z-index: 99;
  }
  .nav-links.active { right: 0; }
  .nav-actions { display: none; }
  .nav-actions.active {
    display: flex; flex-direction: column; position: fixed;
    bottom: 2rem; right: -100%; width: 250px; padding: 0 2rem;
    transition: right 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 100; gap: 1rem;
  }
  .nav-actions.active.show { right: 0; }
  
  .mobile-toggle { display: block; z-index: 101; background: none; border: none; color: #fff; font-size: 1.5rem; cursor: pointer; }
  
  .hero h1 { font-size: 3rem; }
  .section-head h2 { font-size: 2.2rem; }
  .float-icon { display: none; }
  .showcase-text h3 { font-size: 2rem; }
  .tier-card { padding: 2rem; }
}
.mobile-toggle { display: none; }

</style>

<!-- Phosphor Icons -->
<script src="https://unpkg.com/@phosphor-icons/web"></script>

<div class="ambient-bg"></div>
<div class="noise-overlay"></div>

<!-- Navigation -->
<nav class="nav">
  <a href="/" class="nav-brand">
    <img src="<%= typeof panelLogo !== 'undefined' ? panelLogo : '/logo.png' %>" onerror="this.src='https://ui-avatars.com/api/?name=AH&background=7c3aed&color=fff'" alt="Logo">
    <span><%= typeof panelName !== 'undefined' ? panelName : 'Aurora Hub' %></span>
  </a>
  <div class="nav-links" id="navLinks">
    <a href="#features" onclick="toggleMobileMenu()">Features</a>
    <a href="#premium" onclick="toggleMobileMenu()">Pricing</a>
    <a href="#games" onclick="toggleMobileMenu()">Games</a>
    <a href="/tutorials">Tutorials</a>
  </div>
  <div class="nav-actions" id="navActions" style="display: flex; gap: 1rem;">
    <% if (user) { %>
      <a href="/dashboard" class="btn btn-glass"><i class="ph ph-squares-four"></i> Dashboard</a>
      <a href="/plans" class="btn btn-glow"><i class="ph-fill ph-crown"></i> Get Premium</a>
    <% } else { %>
      <a href="/login" class="btn btn-glass">Login</a>
      <a href="/register" class="btn btn-glow">Get Started</a>
    <% } %>
  </div>
  <button class="mobile-toggle" id="mobileToggle" onclick="toggleMobileMenu()">
    <i class="ph ph-list"></i>
  </button>
</nav>

<script>
  function toggleMobileMenu() {
    const links = document.getElementById('navLinks');
    const actions = document.getElementById('navActions');
    const icon = document.querySelector('#mobileToggle i');
    
    links.classList.toggle('active');
    
    if (links.classList.contains('active')) {
      actions.classList.add('active');
      setTimeout(() => actions.classList.add('show'), 10);
      icon.classList.remove('ph-list');
      icon.classList.add('ph-x');
    } else {
      actions.classList.remove('show');
      setTimeout(() => actions.classList.remove('active'), 400);
      icon.classList.remove('ph-x');
      icon.classList.add('ph-list');
    }
  }
</script>

