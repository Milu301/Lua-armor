<%- include('partials/head', { title: 'Leaderboard — ' + (typeof panelName !== 'undefined' ? panelName : 'AuroraHub') }) %>

<style>
@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&display=swap');
:root {
  --bg: #07070f; --surface: #12121a; --border: rgba(255,255,255,0.1);
  --primary: #8b5cf6; --primary-light: #a78bfa; --gold: #f59e0b; --blood: #ef4444;
  --text: #f8fafc; --text-dim: #94a3b8;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Space Grotesk',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}
.ambient{position:fixed;inset:0;z-index:-1;
  background:radial-gradient(circle at 20% 20%,rgba(139,92,246,.18) 0,transparent 45%),
             radial-gradient(circle at 80% 80%,rgba(245,158,11,.12) 0,transparent 45%),
             radial-gradient(circle at 50% 50%,rgba(239,68,68,.08) 0,transparent 55%);
  filter:blur(60px);}

/* Nav */
nav{display:flex;align-items:center;justify-content:space-between;padding:1.2rem 2rem;border-bottom:1px solid var(--border);background:rgba(7,7,15,.8);backdrop-filter:blur(20px);position:sticky;top:0;z-index:100;}
.nav-logo{display:flex;align-items:center;gap:.6rem;font-weight:800;font-size:1.1rem;}
.nav-logo img{width:32px;height:32px;border-radius:8px;}
.nav-links{display:flex;gap:1.5rem;align-items:center;}
.nav-links a{color:var(--text-dim);text-decoration:none;font-size:.9rem;font-weight:600;transition:color .2s;}
.nav-links a:hover,.nav-links a.active{color:#fff;}
.btn-login{background:linear-gradient(135deg,var(--primary),#6366f1);color:#fff;padding:.5rem 1.2rem;border-radius:10px;font-weight:700;font-size:.85rem;text-decoration:none;transition:opacity .2s;}
.btn-login:hover{opacity:.85;}

/* Page */
.page{max-width:1000px;margin:0 auto;padding:3rem 1.5rem 4rem;}
.page-header{text-align:center;margin-bottom:3rem;}
.badge{display:inline-flex;align-items:center;gap:.5rem;background:rgba(245,158,11,.12);border:1px solid rgba(245,158,11,.3);border-radius:20px;padding:.4rem 1.2rem;margin-bottom:1.5rem;}
.badge span{font-size:.8rem;font-weight:700;color:var(--gold);letter-spacing:1px;text-transform:uppercase;}
.page-header h1{font-size:clamp(2rem,5vw,3.5rem);font-weight:800;background:linear-gradient(135deg,#fff 30%,var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:.8rem;}
.page-header p{color:var(--text-dim);font-size:1rem;max-width:500px;margin:0 auto;}

/* Tabs */
.tabs{display:flex;gap:.5rem;justify-content:center;margin-bottom:2.5rem;}
.tab-btn{padding:.65rem 1.8rem;border-radius:12px;border:1px solid var(--border);background:rgba(255,255,255,.04);color:var(--text-dim);font-weight:700;font-size:.9rem;cursor:pointer;transition:all .2s;}
.tab-btn.active{background:linear-gradient(135deg,var(--primary),#6366f1);border-color:transparent;color:#fff;box-shadow:0 4px 20px rgba(139,92,246,.35);}
.tab-btn:not(.active):hover{border-color:var(--primary);color:#fff;}

/* Board */
.board{display:flex;flex-direction:column;gap:.6rem;}
.board-row{display:flex;align-items:center;gap:1rem;background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:16px;padding:1rem 1.5rem;transition:all .2s;cursor:default;}
.board-row:hover{background:rgba(255,255,255,.06);border-color:rgba(255,255,255,.15);transform:translateX(4px);}
.board-row.top-1{background:linear-gradient(135deg,rgba(245,158,11,.12),rgba(245,158,11,.04));border-color:rgba(245,158,11,.3);}
.board-row.top-2{background:linear-gradient(135deg,rgba(148,163,184,.1),rgba(148,163,184,.03));border-color:rgba(148,163,184,.25);}
.board-row.top-3{background:linear-gradient(135deg,rgba(205,127,50,.1),rgba(205,127,50,.03));border-color:rgba(205,127,50,.25);}

.rank{font-size:1.1rem;font-weight:800;min-width:40px;text-align:center;}
.rank.r1{color:var(--gold);} .rank.r2{color:#94a3b8;} .rank.r3{color:#cd7f32;}
.rank-medal{font-size:1.4rem;}

.user-av{width:42px;height:42px;border-radius:12px;overflow:hidden;flex-shrink:0;border:2px solid rgba(255,255,255,.08);}
.user-av img{width:100%;height:100%;object-fit:cover;}
.user-av-ini{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:1.1rem;}

.user-info{flex:1;min-width:0;}
.user-name{font-weight:700;font-size:.95rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.user-name a{color:inherit;text-decoration:none;}
.user-name a:hover{color:var(--primary-light);}
.user-sub{font-size:.75rem;color:var(--text-dim);margin-top:2px;}

.stat-val{font-size:1.25rem;font-weight:800;white-space:nowrap;}
.stat-val.gold-val{color:var(--gold);}
.stat-val.blood-val{color:var(--blood);}
.stat-label{font-size:.7rem;color:var(--text-dim);text-align:right;}

.empty{text-align:center;padding:4rem 2rem;color:var(--text-dim);}
.empty-icon{font-size:3rem;margin-bottom:1rem;}
.loading{text-align:center;padding:3rem;color:var(--text-dim);}

/* Responsive */
@media(max-width:600px){
  .board-row{padding:.75rem 1rem;gap:.75rem;}
  .stat-val{font-size:1rem;}
}
</style>

<div class="layout">
  <%- include('partials/sidebar', { page: 'leaderboard' }) %>

  <div class="main">
    <div class="topbar">
      <div class="topbar-left">
        <div class="pulse-dot"></div>
        <div class="topbar-title">Leaderboard</div>
      </div>
    </div>

<div class="page">
  <div class="page-header">
    <div class="badge"><span>🏆 Global Rankings</span></div>
    <h1>Farming Leaderboard</h1>
    <p>Top farmers across all Booga Booga sessions. Stats update in real-time as you play.</p>
  </div>

  <div class="tabs">
    <button class="tab-btn active" id="tab-gold" onclick="switchTab('gold')">
      🪙 Gold Rankings
    </button>
    <button class="tab-btn" id="tab-blood" onclick="switchTab('blood')">
      🩸 Bloodfruit Rankings
    </button>
  </div>

  <div id="board-gold" class="board">
    <div class="loading">Loading rankings…</div>
  </div>
  <div id="board-blood" class="board" style="display:none;">
    <div class="loading">Loading rankings…</div>
  </div>
</div>

<script src="https://unpkg.com/@phosphor-icons/web"></script>
<script>
let goldData = [], bloodData = [];
let loaded = false;

function switchTab(type) {
  document.getElementById('tab-gold').classList.toggle('active', type === 'gold');
  document.getElementById('tab-blood').classList.toggle('active', type === 'blood');
  document.getElementById('board-gold').style.display = type === 'gold' ? 'flex' : 'none';
  document.getElementById('board-blood').style.display = type === 'blood' ? 'flex' : 'none';
  document.getElementById('board-gold').style.flexDirection = 'column';
  document.getElementById('board-blood').style.flexDirection = 'column';
}

function fmt(n) {
  n = Number(n) || 0;
  if (n >= 1e9) return (n/1e9).toFixed(1) + 'B';
  if (n >= 1e6) return (n/1e6).toFixed(1) + 'M';
  if (n >= 1e3) return (n/1e3).toFixed(1) + 'K';
  return n.toLocaleString();
}

function medalFor(i) {
  if (i === 0) return '<span class="rank-medal">🥇</span>';
  if (i === 1) return '<span class="rank-medal">🥈</span>';
  if (i === 2) return '<span class="rank-medal">🥉</span>';
  return `<span class="rank r${i+1}">#${i+1}</span>`;
}

function rowClass(i) {
  if (i === 0) return 'board-row top-1';
  if (i === 1) return 'board-row top-2';
  if (i === 2) return 'board-row top-3';
  return 'board-row';
}

function avatar(u, size=42) {
  if (u.avatar_url) return `<img src="${u.avatar_url}" onerror="this.parentElement.innerHTML='<div class=user-av-ini style=background:${u.profile_color||'#8b5cf6'}22;color:${u.profile_color||'#8b5cf6'};>${u.username[0].toUpperCase()}</div>'">`;
  const c = u.profile_color || '#8b5cf6';
  return `<div class="user-av-ini" style="background:${c}22;color:${c};">${u.username[0].toUpperCase()}</div>`;
}

function roleTag(role) {
  if (role === 'admin') return ' <span style="background:rgba(239,68,68,.15);color:#f87171;border:1px solid rgba(239,68,68,.3);font-size:.65rem;padding:1px 6px;border-radius:6px;font-weight:700;">ADMIN</span>';
  if (role === 'mod') return ' <span style="background:rgba(14,165,233,.15);color:#38bdf8;border:1px solid rgba(14,165,233,.3);font-size:.65rem;padding:1px 6px;border-radius:6px;font-weight:700;">MOD</span>';
  return '';
}

function renderBoard(containerId, rows, statKey, statLabel, statClass) {
  const el = document.getElementById(containerId);
  if (!rows.length) {
    el.innerHTML = '<div class="empty"><div class="empty-icon">🌾</div><p>No farming data yet.<br>Start playing Booga Booga to appear here!</p></div>';
    return;
  }
  el.innerHTML = rows.map((u, i) => `
    <div class="${rowClass(i)}">
      ${medalFor(i)}
      <div class="user-av">${avatar(u)}</div>
      <div class="user-info">
        <div class="user-name"><a href="/profile/${encodeURIComponent(u.username)}">${u.username}</a>${roleTag(u.role)}</div>
        <div class="user-sub">${u.sessions || 0} sessions tracked</div>
      </div>
      <div style="text-align:right;">
        <div class="stat-val ${statClass}">${fmt(u[statKey])}</div>
        <div class="stat-label">${statLabel}</div>
      </div>
    </div>
  `).join('');
}

async function loadLeaderboard() {
  try {
    const res = await fetch('/api/leaderboard');
    const data = await res.json();
    if (!data.success) throw new Error(data.message);
    goldData = data.gold;
    bloodData = data.blood;
    renderBoard('board-gold', goldData, 'gold_total', 'Gold Farmed', 'gold-val');
    renderBoard('board-blood', bloodData, 'blood_total', 'Bloodfruit Farmed', 'blood-val');
  } catch (err) {
    document.getElementById('board-gold').innerHTML = `<div class="empty"><p>Failed to load: ${err.message}</p></div>`;
  }
}

loadLeaderboard();
// Auto-refresh every 30 seconds
setInterval(loadLeaderboard, 30000);
</script>
  </div> <!-- /.main -->
</div> <!-- /.layout -->
</body>
</html>
