<%- include('partials/head', { title: 'Login — ' + panelName }) %>

<div class="login-page">
  <div class="login-bg"></div>
  <div class="login-card">
    <div class="login-logo">
      <div class="login-logo-icon">🔑</div>
      <h1><%= panelName %></h1>
      <p>Ingresa tu key de Luarmor para continuar</p>
    </div>

    <% if (error) { %>
    <div class="alert alert-error mb-3">
      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="flex-shrink:0;margin-top:1px;">
        <circle cx="12" cy="12" r="10" stroke-width="2"/>
        <path stroke-linecap="round" stroke-width="2" d="M12 8v4m0 4h.01"/>
      </svg>
      <span><%= error %></span>
    </div>
    <% } %>

    <form action="/login" method="POST" id="loginForm">
      <div class="form-group">
        <label class="form-label">Tu Key de Luarmor</label>
        <input
          type="text"
          name="key"
          class="form-input font-mono"
          placeholder="Pega tu key aquí..."
          required
          minlength="6"
          maxlength="128"
          autocomplete="off"
          autocorrect="off"
          spellcheck="false"
        />
        <div class="text-xs text-muted mt-1">Puedes encontrar tu key en el executor o donde la compraste.</div>
      </div>

      <button type="submit" class="btn btn-primary btn-full btn-lg" id="loginBtn">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-width="2" d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4M10 17l5-5-5-5M15 12H3"/>
        </svg>
        Entrar al Panel
      </button>
    </form>

    <div class="divider"></div>
    <div class="text-xs text-muted" style="text-align:center;">
      Tu key nunca se almacena en texto plano. Verificación segura mediante Luarmor API.
    </div>
  </div>
</div>

<script>
document.getElementById('loginForm').addEventListener('submit', function() {
  const btn = document.getElementById('loginBtn');
  btn.disabled = true;
  btn.innerHTML = '<div class="spinner"></div> Verificando...';
});
</script>

</body>
</html>
