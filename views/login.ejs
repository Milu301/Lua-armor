<%- include('partials/head', { title: 'Sign In — ' + panelName }) %>

<div class="auth-page">
  <div class="auth-bg">
    <div class="auth-orb auth-orb-1"></div>
    <div class="auth-orb auth-orb-2"></div>
    <div class="auth-orb auth-orb-3"></div>
    <div class="auth-grid"></div>
  </div>

  <div class="auth-card">
    <!-- Top shine -->
    <div class="auth-card-shine"></div>

    <!-- Brand -->
    <div class="auth-brand">
      <div class="auth-logo">
        <img src="<%= panelLogo %>" alt="<%= panelName %>" style="width:40px;height:40px;border-radius:10px;object-fit:cover;" />
      </div>
      <div class="auth-brand-text">
        <div class="auth-brand-name"><%= panelName %></div>
        <div class="auth-brand-sub">Member Dashboard</div>
      </div>
    </div>

    <div class="auth-divider"></div>

    <h1 class="auth-heading">Welcome back</h1>
    <p class="auth-sub">Sign in to manage your Luarmor key &amp; HWID resets</p>

    <% if (error) { %>
    <div class="alert alert-danger" style="margin-bottom:1.25rem;">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="flex-shrink:0">
        <circle cx="12" cy="12" r="10" stroke-width="2"/>
        <path stroke-linecap="round" stroke-width="2" d="M12 8v4m0 4h.01"/>
      </svg>
      <span><%= error %></span>
    </div>
    <% } %>

    <form action="/login" method="POST" id="loginForm" autocomplete="off">
      <div class="form-group">
        <label class="label">Username</label>
        <div class="input-wrap">
          <svg class="input-icon" width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          <input type="text" name="username" class="input input-icon-pad" placeholder="your_username"
            required minlength="3" maxlength="32" autocomplete="username" spellcheck="false" />
        </div>
      </div>

      <div class="form-group">
        <label class="label" style="display:flex;justify-content:space-between;">
          Password
          <span class="dimmed" style="font-weight:400;">Forgot it? Ask in Discord</span>
        </label>
        <div class="input-wrap">
          <svg class="input-icon" width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <rect x="3" y="11" width="18" height="11" rx="2" stroke-width="2"/>
            <path stroke-linecap="round" stroke-width="2" d="M7 11V7a5 5 0 0110 0v4"/>
          </svg>
          <input type="password" name="password" id="pwField" class="input input-icon-pad input-icon-right-pad"
            placeholder="••••••••" required minlength="8" autocomplete="current-password" />
          <button type="button" class="input-eye" onclick="togglePw()" title="Show/hide password">
            <svg id="eye-open" width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
            <svg id="eye-closed" width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:none;">
              <path stroke-linecap="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
            </svg>
          </button>
        </div>
      </div>

      <button type="submit" class="btn btn-primary btn-full btn-lg" id="loginBtn" style="margin-top:0.5rem;">
        <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-width="2" d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4M10 17l5-5-5-5M15 12H3"/>
        </svg>
        Sign In
      </button>
    </form>

    <div class="auth-footer-links">
      <span class="dimmed t-sm">Don't have an account?</span>
      <a href="/register" class="auth-link">
        Register with your Luarmor key
        <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <div class="auth-discord-strip">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="#5865f2">
        <path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/>
      </svg>
      <span class="t-xs">Need a key? Join our Discord to get access.</span>
      <a href="<%= discordUrl %>" target="_blank" rel="noopener" class="btn btn-sm" style="background:rgba(88,101,242,0.15);border:1px solid rgba(88,101,242,0.30);color:#818cf8;margin-left:auto;">
        Join Server
      </a>
    </div>
  </div>

  <!-- Version badge -->
  <div class="auth-version">v3.0 · Secured by Luarmor</div>
</div>

<script>
document.getElementById('loginForm').addEventListener('submit', function() {
  const btn = document.getElementById('loginBtn');
  btn.disabled = true;
  btn.innerHTML = '<div class="spinner"></div> Signing in…';
});

function togglePw() {
  const f = document.getElementById('pwField');
  const o = document.getElementById('eye-open');
  const c = document.getElementById('eye-closed');
  if (f.type === 'password') {
    f.type = 'text';
    o.style.display = 'none';
    c.style.display = '';
  } else {
    f.type = 'password';
    o.style.display = '';
    c.style.display = 'none';
  }
}
</script>
</body>
</html>
