<%- include('partials/head', { title: 'Sign In — ' + panelName }) %>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-card-shine"></div>

    <!-- Brand -->
    <div class="auth-brand">
      <div class="auth-logo">
        <img src="<%= typeof panelLogo !== 'undefined' ? panelLogo : '/logo.png' %>" alt="Logo" style="width:100%;height:100%;object-fit:cover;border-radius:inherit;" onerror="this.parentElement.innerHTML='🔑'" />
      </div>
      <div>
        <div class="auth-brand-name"><%= panelName %></div>
        <div class="auth-brand-sub">Member Panel</div>
      </div>
    </div>

    <div class="auth-divider"></div>

    <!-- Heading -->
    <h1 class="auth-heading">Welcome back</h1>
    <p class="auth-sub">Sign in to your account to continue</p>

    <!-- Error -->
    <% if (error) { %>
    <div class="alert alert-danger mb-3">
      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
      <span><%= error %></span>
    </div>
    <% } %>

    <!-- Form -->
    <form action="/login" method="POST" id="loginForm" autocomplete="off">
      <div class="form-group">
        <label class="label">Username</label>
        <div class="input-wrap">
          <svg class="input-icon" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          <input type="text" name="username" class="input input-icon-pad" placeholder="your_username" required minlength="3" maxlength="32" autocomplete="username" spellcheck="false" />
        </div>
      </div>

      <div class="form-group">
        <label class="label">
          Password
          <a href="<%= typeof discordUrl !== 'undefined' ? discordUrl : '#' %>" target="_blank" class="auth-link" style="font-size:0.72rem;">Forgot it?</a>
        </label>
        <div class="input-wrap">
          <svg class="input-icon" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          <input type="password" name="password" id="pwField" class="input input-icon-pad input-icon-right-pad" placeholder="••••••••" required minlength="8" autocomplete="current-password" />
          <button type="button" class="input-eye" onclick="togglePw()" title="Toggle visibility">
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="eye-icon"><path stroke-linecap="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
          </button>
        </div>
      </div>

      <button type="submit" class="btn btn-primary btn-lg btn-full" id="loginBtn">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
        Sign In
      </button>

      <a href="/auth/discord" class="btn btn-discord btn-lg btn-full" style="margin-top:0.8rem;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/></svg>
        Login with Discord
      </a>
    </form>

    <!-- Footer -->
    <div class="auth-footer-links">
      <a href="/register" class="auth-link">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M18 9v3m0 0v3m0-6h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
        Create account
      </a>
      <a href="/home" class="auth-link" style="color:var(--text-3);">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Back to home
      </a>
    </div>

    <!-- Discord strip -->
    <div class="auth-discord-strip">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="color:#5865f2;flex-shrink:0;"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/></svg>
      <div style="flex:1;font-size:0.8rem;color:var(--text-2);">Need a key? Join our Discord server.</div>
      <a href="<%= typeof discordUrl !== 'undefined' ? discordUrl : '#' %>" target="_blank" class="btn btn-sm btn-ghost" style="color:#818cf8;border-color:rgba(88,101,242,0.2);">Join</a>
    </div>

    <div class="auth-version">v5.0.0 — © <%= new Date().getFullYear() %> <%= panelName %></div>
  </div>
</div>

<script>
document.getElementById('loginForm').addEventListener('submit', function() {
  const btn = document.getElementById('loginBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span> Authenticating…';
});

function togglePw() {
  const f = document.getElementById('pwField');
  const icon = document.getElementById('eye-icon');
  if (f.type === 'password') {
    f.type = 'text';
    icon.innerHTML = '<path stroke-linecap="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>';
  } else {
    f.type = 'password';
    icon.innerHTML = '<path stroke-linecap="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>';
  }
}
</script>
</body>
</html>
