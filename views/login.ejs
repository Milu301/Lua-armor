<%- include('partials/head', { title: 'Sign In — ' + panelName }) %>

<div class="login-page">
  <div class="login-glow"></div>

  <div class="login-card">
    <div class="login-top">
      <img 
        src="https://cdn.discordapp.com/icons/1398423987817807934/a_6f62815e5aee24b4964bd4113626e3fe.webp?size=128"
        class="login-avatar"
        alt="<%= panelName %>"
      />
      <div>
        <div class="login-title"><%= panelName %></div>
        <div class="login-sub">Enter your Luarmor key to access the panel</div>
      </div>
    </div>

    <% if (error) { %>
    <div class="alert alert-danger mb-3">
      <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="flex-shrink:0">
        <circle cx="12" cy="12" r="10" stroke-width="2"/>
        <path stroke-linecap="round" stroke-width="2" d="M12 8v4m0 4h.01"/>
      </svg>
      <span><%= error %></span>
    </div>
    <% } %>

    <form action="/login" method="POST" id="loginForm">
      <div class="form-group">
        <label class="label">Your Luarmor Key</label>
        <input
          type="text"
          name="key"
          class="input mono"
          placeholder="Paste your key here…"
          required minlength="6" maxlength="128"
          autocomplete="off" spellcheck="false" autocorrect="off"
        />
        <div class="t-xs dimmed mt-1">Your key can be found in your executor or wherever you purchased access.</div>
      </div>

      <button type="submit" class="btn btn-primary btn-full btn-lg mt-2" id="loginBtn">
        <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-width="2" d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4M10 17l5-5-5-5M15 12H3"/>
        </svg>
        Sign In
      </button>
    </form>

    <div class="divider"></div>

    <div class="t-xs dimmed" style="text-align:center;line-height:1.7;">
      Your key is verified directly against Luarmor's API and never stored.<br>Sessions expire after 7 days.
    </div>
  </div>
</div>

<script>
document.getElementById('loginForm').addEventListener('submit', function() {
  const btn = document.getElementById('loginBtn');
  btn.disabled = true;
  btn.innerHTML = '<div class="spinner"></div> Verifying…';
});
</script>
</body>
</html>
