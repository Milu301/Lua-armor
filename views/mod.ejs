<%- include('partials/head', { title: 'Mod Panel — ' + panelName }) %>

<div class="layout">
  <%- include('partials/sidebar', { page: 'mod' }) %>

  <div class="main">
    <div class="topbar">
      <div class="topbar-left">
        <div class="pulse-dot" style="background:var(--yellow);box-shadow:0 0 0 2px rgba(245,158,11,0.2);"></div>
        <div class="topbar-title">Mod Panel</div>
        <span class="badge" style="background:rgba(245,158,11,0.12);border:1px solid rgba(245,158,11,0.25);color:#fbbf24;font-size:0.65rem;">
          <%= user && user.role === 'admin' ? 'ADMIN' : 'MOD' %>
        </span>
      </div>
      <div class="topbar-right">
        <span class="t-xs dimmed"><%= users.length %> users</span>
      </div>
    </div>

    <div class="content">



      <div class="stat-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:1.5rem; animation: slideUp 0.6s ease;">
        <div class="stat" style="border-top:2px solid var(--accent); background: var(--bg-raised); transition: transform 0.3s; box-shadow: 0 4px 20px rgba(0,0,0,0.2);" onmouseover="this.style.transform='translateY(-5px)';" onmouseout="this.style.transform='translateY(0)';">
          <div class="stat-label">Total Users</div>
          <div class="stat-val c-purple" style="text-shadow: 0 0 10px rgba(139,92,246,0.3);"><%= users.length %></div>
        </div>
        <div class="stat" style="border-top:2px solid var(--green); background: var(--bg-raised); transition: transform 0.3s; box-shadow: 0 4px 20px rgba(0,0,0,0.2);" onmouseover="this.style.transform='translateY(-5px)';" onmouseout="this.style.transform='translateY(0)';">
          <div class="stat-label">Active Users</div>
          <div class="stat-val c-green" style="text-shadow: 0 0 10px rgba(34,197,94,0.3);"><%= users.filter(u=>u.is_active).length %></div>
        </div>
        <div class="stat" style="border-top:2px solid var(--red); background: var(--bg-raised); transition: transform 0.3s; box-shadow: 0 4px 20px rgba(0,0,0,0.2);" onmouseover="this.style.transform='translateY(-5px)';" onmouseout="this.style.transform='translateY(0)';">
          <div class="stat-label">Blacklisted</div>
          <div class="stat-val" style="color:var(--red); text-shadow: 0 0 10px rgba(239,68,68,0.3);"><%= users.filter(u=>!u.is_active).length %></div>
        </div>
      </div>

      <div class="alert" style="background:rgba(245,158,11,0.08);border:1px solid rgba(245,158,11,0.18);color:#fbbf24;margin-bottom:1.5rem;gap:0.625rem;animation: slideUp 0.8s ease;">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="flex-shrink:0"><path stroke-linecap="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
        <span>Mod actions are logged. Use responsibly — blacklisting prevents login immediately.</span>
      </div>

      <!-- Search -->
      <div style="margin-bottom:1rem;">
        <div class="input-wrap">
          <svg class="input-icon" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" stroke-width="2"/><path stroke-linecap="round" stroke-width="2" d="M21 21l-4.35-4.35"/></svg>
          <input type="text" class="input input-icon-pad" id="searchInput" placeholder="Search by username…" oninput="filterUsers(this.value)" />
        </div>
      </div>

      <!-- Users table -->
      <div class="card" style="padding:0;overflow:hidden;">
        <div style="padding:0.875rem 1.125rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;">
          <div class="card-title" style="font-size:0.82rem;">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/></svg>
            Members
          </div>
        </div>
        <div style="overflow-x:auto;">
          <table class="data-table" id="usersTable">
            <thead>
              <tr>
                <th>User</th>
                <th>Project</th>
                <th>Status</th>
                <th>Resets</th>
                <th style="text-align:right;">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(function(u) { %>
              <tr class="mod-user-row" data-username="<%= u.username.toLowerCase() %>" data-id="<%= u.id %>">
                <td>
                  <div style="display:flex;align-items:center;gap:0.6rem;">
                    <div class="mod-avatar <%= u.role === 'admin' ? 'mod-av-admin' : u.role === 'mod' ? 'mod-av-mod' : '' %>">
                      <%= u.username.charAt(0).toUpperCase() %>
                    </div>
                    <div>
                      <div style="font-weight:600;font-size:0.81rem;"><%= u.username %></div>
                      <% if (u.role === 'admin') { %>
                      <span class="cp-tag cp-tag-admin">ADMIN</span>
                      <% } else if (u.role === 'mod') { %>
                      <span class="cp-tag cp-tag-mod">MOD</span>
                      <% } %>
                    </div>
                  </div>
                </td>
                <td class="t-sm dimmed"><%= u.project_icon || '' %> <%= u.project_name || '—' %></td>
                <td>
                  <% if (!u.is_active) { %>
                  <span class="badge" style="background:var(--red-dim);border:1px solid var(--red-border);color:var(--red);">Blacklisted</span>
                  <% } else { %>
                  <span class="badge badge-green">Active</span>
                  <% } %>
                </td>
                <td class="t-sm dimmed"><%= u.total_resets %></td>
                <td>
                    <div style="display:flex;gap:0.4rem;justify-content:flex-end;flex-wrap:wrap;">
                      <button class="btn btn-sm btn-secondary" onclick="openModUserModal(<%= u.id %>)" title="View Details">
                        <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                        View
                      </button>
                    <% if (u.role !== 'admin') { %>
                    <button class="btn btn-sm btn-ghost" onclick="resetHwid(<%= u.id %>, '<%= u.username %>', this)" title="Reset HWID">
                      <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                      Reset HWID
                    </button>
                    <% if (u.is_active) { %>
                    <button class="btn btn-sm" style="background:var(--red-dim);border:1px solid var(--red-border);color:var(--red);" onclick="blacklist(<%= u.id %>, '<%= u.username %>', this)" title="Blacklist">
                      <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
                      Blacklist
                    </button>
                    <% } else { %>
                    <button class="btn btn-sm" style="background:var(--green-dim);border:1px solid var(--green-border);color:var(--green);" onclick="unblacklist(<%= u.id %>, '<%= u.username %>', this)" title="Reinstate">
                      <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                      Reinstate
                    </button>
                    <% } %>
                    <% } else { %>
                    <span class="t-xs dimmed" style="margin-left:0.5rem;align-self:center;">Protected</span>
                    <% } %>
                  </div>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

  <div class="modal-overlay" id="mod-user-modal">
    <div class="modal-box" style="padding:0; overflow:hidden;">
      <div style="padding:1.5rem 1.75rem 0; border-bottom:1px solid var(--border-md);">
        <button class="modal-close" onclick="closeModal('mod-user-modal')" style="margin-top:2px;">×</button>
        <h2>User Details — <span id="mum-name" style="color:var(--accent);"></span></h2>
      </div>

      <div style="padding:1.5rem 1.75rem; max-height: 60vh; overflow-y: auto;">
        <div id="mum-result"></div>

        <div class="field-grid">
          <div class="form-row">
            <label class="label">Project</label>
            <div class="input" style="background:var(--bg-raised);" id="mum-project">—</div>
          </div>
          <div class="form-row">
            <label class="label">Discord ID</label>
            <div class="input mono" style="background:var(--bg-raised);" id="mum-discord">—</div>
          </div>
        </div>

        <div class="form-row">
          <label class="label">Total Resets</label>
          <div class="input" style="background:var(--bg-raised);" id="mum-resets">0</div>
        </div>

        <div class="form-row">
          <label class="label">Admin / Mod Note</label>
          <input type="text" class="input" id="mum-note" placeholder="Custom note" maxlength="100"/>
        </div>
      </div>

      <div style="padding:1.25rem 1.75rem; border-top:1px solid var(--border-md); background:var(--bg-card); display:flex; gap:0.5rem; flex-wrap:wrap; align-items:center;">
        <input type="hidden" id="mum-id" />
        <button class="btn btn-primary" onclick="saveModNote()">Save Note</button>
        <button class="btn btn-ghost" onclick="closeModal('mod-user-modal')">Close</button>
      </div>
    </div>
  </div>

<script>
function openModal(id)  { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

async function openModUserModal(id) {
  document.getElementById('mum-id').value = id;
  document.getElementById('mum-name').textContent = '...';
  document.getElementById('mum-project').textContent = '...';
  document.getElementById('mum-discord').textContent = '...';
  document.getElementById('mum-resets').textContent = '...';
  document.getElementById('mum-note').value = '';
  document.getElementById('mum-result').innerHTML = '<div class="alert alert-info" style="margin-bottom:.5rem;font-size:.75rem;">Loading…</div>';
  
  openModal('mod-user-modal');

  try {
    const res = await fetch('/api/mod/user/' + id);
    const d = await res.json();
    if (!d.success) {
      document.getElementById('mum-result').innerHTML = '<div class="alert alert-danger" style="font-size:.75rem;">Failed to load.</div>';
      return;
    }
    const u = d.user;
    document.getElementById('mum-name').textContent = u.username;
    document.getElementById('mum-project').textContent = u.project_name || 'None';
    document.getElementById('mum-discord').textContent = u.discord_id || '—';
    document.getElementById('mum-resets').textContent = u.total_resets || 0;
    document.getElementById('mum-note').value = u.note || '';
    document.getElementById('mum-result').innerHTML = '';
  } catch(e) {
    document.getElementById('mum-result').innerHTML = '<div class="alert alert-danger" style="font-size:.75rem;">Network error.</div>';
  }
}

async function saveModNote() {
  const id = document.getElementById('mum-id').value;
  const note = document.getElementById('mum-note').value.trim();
  
  try {
    const res = await fetch('/api/mod/user/' + id + '/note', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ note })
    });
    const d = await res.json();
    if (d.success) {
      toast('Note saved!', 'success');
      closeModal('mod-user-modal');
    } else {
      toast(d.message, 'error');
    }
  } catch(e) {
    toast('Failed to save note.', 'error');
  }
}

function filterUsers(q) {
  const val = q.toLowerCase();
  document.querySelectorAll('.mod-user-row').forEach(row => {
    row.style.display = row.dataset.username.includes(val) ? '' : 'none';
  });
}

async function modAction(url, label, btn) {
  if (!confirm(label)) return;
  const orig = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<div class="spinner" style="width:12px;height:12px;border-width:2px;"></div>';
  const res = await fetch(url, { method:'POST' });
  const json = await res.json();
  if (json.success) {
    toast(json.message, 'success');
    setTimeout(() => location.reload(), 800);
  } else {
    toast(json.message, 'error');
    btn.disabled = false;
    btn.innerHTML = orig;
  }
}

function resetHwid(id, name, btn) {
  modAction('/api/mod/user/' + id + '/reset-hwid', `Reset HWID for ${name}?`, btn);
}
function blacklist(id, name, btn) {
  modAction('/api/mod/user/' + id + '/blacklist', `Blacklist ${name}? They won't be able to log in.`, btn);
}
function unblacklist(id, name, btn) {
  modAction('/api/mod/user/' + id + '/unblacklist', `Reinstate ${name}?`, btn);
}

function toast(msg, type) {
  const t = document.createElement('div');
  const col = type === 'success' ? 'var(--green)' : type === 'error' ? 'var(--red)' : 'var(--accent)';
  t.style.cssText = `position:fixed;bottom:1.5rem;right:1.5rem;background:var(--bg-card);border:1px solid ${col};color:var(--text);padding:0.65rem 1rem;border-radius:10px;font-size:0.8rem;z-index:9999;box-shadow:var(--shadow);animation:fadeIn 0.2s ease;max-width:320px;`;
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 3500);
}
</script>
<style>
  .modal-overlay { display:none; position:fixed; inset:0; z-index:1000; background:rgba(0,0,0,0.75); backdrop-filter:blur(8px); align-items:center; justify-content:center; padding:1.5rem; }
  .modal-overlay.open { display:flex; animation:fadeIn 0.2s ease; }
  .modal-box { background:var(--bg-card); border:1px solid var(--border-acc); border-radius:var(--rl); width:100%; max-width:520px; box-shadow:var(--shadow-lg); animation:slideUp 0.2s ease; max-height:90vh; overflow-y:auto; }
  .modal-box h2 { font-size:1rem; font-weight:700; margin-bottom:1.25rem; }
  .modal-close { float:right; background:none; border:none; cursor:pointer; color:var(--text-3); font-size:1.4rem; line-height:1; padding:2px 6px; border-radius:6px; margin-top:-4px; transition:background 0.12s,color 0.12s; }
  .modal-close:hover { background:var(--bg-raised); color:var(--text); }
  .field-grid { display:grid; grid-template-columns:1fr 1fr; gap:0.75rem; }
  .form-row { margin-bottom:0.75rem; }
</style>
</body>
</html>
