<%- include('partials/head', { title: 'Mod Panel — ' + panelName }) %>

<div class="layout">
  <%- include('partials/sidebar', { page: 'mod' }) %>

  <div class="main">
    <div class="topbar">
      <div class="topbar-left">
        <div class="pulse-dot" style="background:var(--yellow);box-shadow:0 0 0 2px rgba(245,158,11,0.2);"></div>
        <div class="topbar-title">Mod Panel</div>
        <span class="badge" style="background:rgba(245,158,11,0.12);border:1px solid rgba(245,158,11,0.25);color:#fbbf24;font-size:0.65rem;">
          <%= user && user.role === 'admin' ? 'ADMIN' : 'MOD' %>
        </span>
      </div>
      <div class="topbar-right">
        <span class="t-xs dimmed"><%= users.length %> users</span>
      </div>
    </div>

    <div class="content">



      <div class="alert" style="background:rgba(245,158,11,0.08);border:1px solid rgba(245,158,11,0.18);color:#fbbf24;margin-bottom:1.5rem;gap:0.625rem;">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="flex-shrink:0"><path stroke-linecap="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
        <span>Mod actions are logged. Use responsibly — blacklisting prevents login immediately.</span>
      </div>

      <!-- Search -->
      <div style="margin-bottom:1rem;">
        <div class="input-wrap">
          <svg class="input-icon" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" stroke-width="2"/><path stroke-linecap="round" stroke-width="2" d="M21 21l-4.35-4.35"/></svg>
          <input type="text" class="input input-icon-pad" id="searchInput" placeholder="Search by username…" oninput="filterUsers(this.value)" />
        </div>
      </div>

      <!-- Users table -->
      <div class="card" style="padding:0;overflow:hidden;">
        <div style="padding:0.875rem 1.125rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;">
          <div class="card-title" style="font-size:0.82rem;">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/></svg>
            Members
          </div>
        </div>
        <div style="overflow-x:auto;">
          <table class="data-table" id="usersTable">
            <thead>
              <tr>
                <th>User</th>
                <th>Project</th>
                <th>Status</th>
                <th>Resets</th>
                <th style="text-align:right;">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(function(u) { %>
              <tr class="mod-user-row" data-username="<%= u.username.toLowerCase() %>" data-id="<%= u.id %>">
                <td>
                  <div style="display:flex;align-items:center;gap:0.6rem;">
                    <div class="mod-avatar <%= u.role === 'admin' ? 'mod-av-admin' : u.role === 'mod' ? 'mod-av-mod' : '' %>">
                      <%= u.username.charAt(0).toUpperCase() %>
                    </div>
                    <div>
                      <div style="font-weight:600;font-size:0.81rem;"><%= u.username %></div>
                      <% if (u.role === 'admin') { %>
                      <span class="cp-tag cp-tag-admin">ADMIN</span>
                      <% } else if (u.role === 'mod') { %>
                      <span class="cp-tag cp-tag-mod">MOD</span>
                      <% } %>
                    </div>
                  </div>
                </td>
                <td class="t-sm dimmed"><%= u.project_icon || '' %> <%= u.project_name || '—' %></td>
                <td>
                  <% if (!u.is_active) { %>
                  <span class="badge" style="background:var(--red-dim);border:1px solid var(--red-border);color:var(--red);">Blacklisted</span>
                  <% } else { %>
                  <span class="badge badge-green">Active</span>
                  <% } %>
                </td>
                <td class="t-sm dimmed"><%= u.total_resets %></td>
                <td>
                  <div style="display:flex;gap:0.4rem;justify-content:flex-end;flex-wrap:wrap;">
                    <% if (u.role !== 'admin') { %>
                    <button class="btn btn-sm btn-ghost" onclick="resetHwid(<%= u.id %>, '<%= u.username %>', this)" title="Reset HWID">
                      <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                      Reset HWID
                    </button>
                    <% if (u.is_active) { %>
                    <button class="btn btn-sm" style="background:var(--red-dim);border:1px solid var(--red-border);color:var(--red);" onclick="blacklist(<%= u.id %>, '<%= u.username %>', this)" title="Blacklist">
                      <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
                      Blacklist
                    </button>
                    <% } else { %>
                    <button class="btn btn-sm" style="background:var(--green-dim);border:1px solid var(--green-border);color:var(--green);" onclick="unblacklist(<%= u.id %>, '<%= u.username %>', this)" title="Reinstate">
                      <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                      Reinstate
                    </button>
                    <% } %>
                    <% } else { %>
                    <span class="t-xs dimmed">Protected</span>
                    <% } %>
                  </div>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function filterUsers(q) {
  const val = q.toLowerCase();
  document.querySelectorAll('.mod-user-row').forEach(row => {
    row.style.display = row.dataset.username.includes(val) ? '' : 'none';
  });
}

async function modAction(url, label, btn) {
  if (!confirm(label)) return;
  const orig = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<div class="spinner" style="width:12px;height:12px;border-width:2px;"></div>';
  const res = await fetch(url, { method:'POST' });
  const json = await res.json();
  if (json.success) {
    toast(json.message, 'success');
    setTimeout(() => location.reload(), 800);
  } else {
    toast(json.message, 'error');
    btn.disabled = false;
    btn.innerHTML = orig;
  }
}

function resetHwid(id, name, btn) {
  modAction('/api/mod/user/' + id + '/reset-hwid', `Reset HWID for ${name}?`, btn);
}
function blacklist(id, name, btn) {
  modAction('/api/mod/user/' + id + '/blacklist', `Blacklist ${name}? They won't be able to log in.`, btn);
}
function unblacklist(id, name, btn) {
  modAction('/api/mod/user/' + id + '/unblacklist', `Reinstate ${name}?`, btn);
}

function toast(msg, type) {
  const t = document.createElement('div');
  const col = type === 'success' ? 'var(--green)' : type === 'error' ? 'var(--red)' : 'var(--accent)';
  t.style.cssText = `position:fixed;bottom:1.5rem;right:1.5rem;background:var(--bg-card);border:1px solid ${col};color:var(--text);padding:0.65rem 1rem;border-radius:10px;font-size:0.8rem;z-index:9999;box-shadow:var(--shadow);animation:fadeIn 0.2s ease;max-width:320px;`;
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 3500);
}
</script>
</body>
</html>
