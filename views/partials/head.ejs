<!DOCTYPE html>
<html lang="<%= typeof user !== 'undefined' && user && user.language ? user.language : 'en' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#07070f" />
  <title><%= title || panelName %></title>
  <meta name="robots" content="noindex, nofollow, noarchive, nosnippet" />
  <meta name="googlebot" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400&family=JetBrains+Mono:wght@400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700;800&display=swap" />
  <script src="https://unpkg.com/@phosphor-icons/web"></script>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🔑</text></svg>" />
  <% if (typeof disableAds === 'undefined' || !disableAds) { %>
  <script src="https://publisher.linkvertise.com/cdn/linkvertise.js"></script>
  <script>linkvertise(601111, {whitelist: [], blacklist: [""]});</script>
  <% } %>
  <script>window.currentLanguage = "<%= typeof user !== 'undefined' && user ? user.language : 'en' %>";</script>
  <script src="/js/i18n.js"></script>
</head>
<body>

<div class="ambient-bg"></div>
<div class="noise-overlay"></div>
<div class="scroll-progress" id="scrollProgress"></div>

<script src="/socket.io/socket.io.js"></script>

<script>
/* ═══ SOURCE PROTECTION ═══ */
(function() {
  document.addEventListener('contextmenu', e => e.preventDefault());
  document.addEventListener('keydown', e => {
    if (e.key === 'F12') { e.preventDefault(); return false; }
    if (e.ctrlKey && e.shiftKey && ['I','i','J','j','C','c'].includes(e.key)) { e.preventDefault(); return false; }
    if (e.ctrlKey && (e.key === 'U' || e.key === 'u')) { e.preventDefault(); return false; }
    if (e.ctrlKey && (e.key === 'S' || e.key === 's')) { e.preventDefault(); return false; }
  });
})();

/* ═══ SCROLL PROGRESS ═══ */
window.addEventListener('scroll', () => {
  const el = document.getElementById('scrollProgress');
  if (!el) return;
  const pct = (window.scrollY / (document.body.scrollHeight - window.innerHeight)) * 100;
  el.style.width = Math.min(100, pct) + '%';
}, { passive: true });

/* ═══ RIPPLE ═══ */
document.addEventListener('click', e => {
  const btn = e.target.closest('.btn, .hwid-btn, .btn-kick, .chat-send-btn');
  if (!btn || btn.disabled) return;
  const rect = btn.getBoundingClientRect();
  const size = Math.max(rect.width, rect.height) * 2;
  const x = e.clientX - rect.left - size / 2;
  const y = e.clientY - rect.top  - size / 2;
  const wave = document.createElement('span');
  wave.className = 'ripple-wave';
  wave.style.cssText = `width:${size}px;height:${size}px;left:${x}px;top:${y}px;`;
  btn.appendChild(wave);
  setTimeout(() => wave.remove(), 700);
});

/* ═══ SCROLL REVEAL ═══ */
(function initReveal() {
  if (!window.IntersectionObserver) return;
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) { entry.target.classList.add('revealed'); observer.unobserve(entry.target); }
    });
  }, { threshold: 0.04, rootMargin: '0px 0px -20px 0px' });
  function observeAll() {
    const els = document.querySelectorAll('.card, .stat, .welcome-banner, .hwid-card, .announce-item, .account-card, .auth-card, .login-card, .settings-card');
    els.forEach((el, i) => {
      el.classList.add('reveal-hidden');
      el.style.transitionDelay = Math.min(i * 0.05, 0.3) + 's';
      observer.observe(el);
    });
    setTimeout(() => { els.forEach(el => el.classList.add('revealed')); }, 900);
  }
  if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', observeAll); }
  else { requestAnimationFrame(() => requestAnimationFrame(observeAll)); }
})();

/* ═══ COUNT-UP ═══ */
function countUp(el, target, duration) {
  duration = duration || 1200;
  const start = performance.now();
  const from  = parseInt((el.textContent || '').replace(/,/g, '')) || 0;
  function step(now) {
    const progress = Math.min((now - start) / duration, 1);
    const ease = 1 - Math.pow(1 - progress, 3);
    el.textContent = Math.round(from + (target - from) * ease).toLocaleString();
    if (progress < 1) requestAnimationFrame(step);
    else el.classList.add('bump');
  }
  requestAnimationFrame(step);
}
window.countUp = countUp;

/* ═══ CLOCK ═══ */
function updateClock() {
  const el = document.getElementById('topbar-clock');
  if (!el) return;
  const now = new Date();
  const h = String(now.getUTCHours()).padStart(2,'0');
  const m = String(now.getUTCMinutes()).padStart(2,'0');
  const s = String(now.getUTCSeconds()).padStart(2,'0');
  el.textContent = h + ':' + m + ':' + s + ' UTC';
}
setInterval(updateClock, 1000);
updateClock();

/* ═══ TOAST ═══ */
function toast(msg, type) {
  type = type || 'ok';
  const wrap = document.getElementById('toast-wrap') || (function() {
    const w = document.createElement('div');
    w.id = 'toast-wrap'; w.className = 'toast-wrap';
    document.body.appendChild(w); return w;
  })();
  const t = document.createElement('div');
  t.className = 'toast ' + type;
  const icons = { ok: '✓', err: '✕', warn: '⚠' };
  t.innerHTML = '<span class="toast-icon">' + (icons[type]||'ℹ') + '</span><span>' + msg + '</span>';
  wrap.appendChild(t);
  setTimeout(() => {
    t.style.animation = 'toastOut 0.3s ease forwards';
    setTimeout(() => t.remove(), 310);
  }, 3500);
}
window.toast = toast;

/* ═══ MOBILE SIDEBAR ═══ */
document.addEventListener('DOMContentLoaded', () => {
  const sidebar  = document.querySelector('.sidebar');
  const topbarLeft = document.querySelector('.topbar-left');
  if (!sidebar || !topbarLeft) return;

  /* Hamburger button */
  const btn = document.createElement('button');
  btn.className = 'mobile-menu-btn';
  btn.id = 'mobile-menu-btn';
  btn.setAttribute('aria-label', 'Open menu');
  btn.innerHTML = `<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>`;
  topbarLeft.insertBefore(btn, topbarLeft.firstChild);

  /* Overlay */
  const overlay = document.createElement('div');
  overlay.className = 'sidebar-overlay';
  overlay.id = 'sidebar-overlay';
  document.body.appendChild(overlay);

  function openSidebar()  { sidebar.classList.add('open'); overlay.classList.add('open'); document.body.style.overflow = 'hidden'; }
  function closeSidebar() { sidebar.classList.remove('open'); overlay.classList.remove('open'); document.body.style.overflow = ''; }

  btn.addEventListener('click', () => sidebar.classList.contains('open') ? closeSidebar() : openSidebar());
  overlay.addEventListener('click', closeSidebar);

  /* Close on nav link click (mobile) */
  sidebar.querySelectorAll('.sb-link').forEach(link => {
    link.addEventListener('click', () => { if (window.innerWidth < 1024) closeSidebar(); });
  });
});
</script>

<style>
@keyframes callPulse { 0%,100%{opacity:1;box-shadow:0 0 6px #10b981;} 50%{opacity:0.6;box-shadow:0 0 14px #10b981;} }
@keyframes callBarIn  { from{transform:translateX(-50%) translateY(30px);opacity:0;} to{transform:translateX(-50%) translateY(0);opacity:1;} }
@keyframes callBarOut { to{transform:translateX(-50%) translateY(30px);opacity:0;} }
#float-call-bar { position:fixed;bottom:1.25rem;left:50%;transform:translateX(-50%);z-index:9999;background:rgba(10,10,20,0.93);backdrop-filter:blur(20px);border:1px solid rgba(16,185,129,0.25);border-radius:16px;padding:0.75rem 1rem;display:flex;align-items:center;gap:0.75rem;box-shadow:0 8px 32px rgba(0,0,0,0.5);min-width:280px;max-width:380px;animation:callBarIn 0.4s cubic-bezier(0.16,1,0.3,1); }
#float-call-bar .fcb-return { background:rgba(16,185,129,0.15);border:1px solid rgba(16,185,129,0.3);color:#10b981;padding:0.35rem 0.75rem;border-radius:8px;font-weight:600;font-size:0.78rem;text-decoration:none;white-space:nowrap;transition:background 0.2s; }
#float-call-bar .fcb-return:hover { background:rgba(16,185,129,0.28); }
#float-call-bar .fcb-hang { background:rgba(239,68,68,0.15);border:1px solid rgba(239,68,68,0.3);color:#ef4444;width:32px;height:32px;border-radius:8px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:background 0.2s; }
#float-call-bar .fcb-hang:hover { background:rgba(239,68,68,0.28); }
</style>

<script>
/* ═══ PERSISTENT VOICE CALL (iframe + BroadcastChannel) ═══ */
(function() {
  const CALL_KEY = 'activeVoiceCall';
  let _bc = null;

  window.voicePersist = {
    save: function(groupId, groupName) {
      sessionStorage.setItem(CALL_KEY, JSON.stringify({ groupId: groupId, groupName: groupName }));
      /* Inject hidden iframe if not already there */
      if (!document.getElementById('voice-iframe')) {
        const fr = document.createElement('iframe');
        fr.id = 'voice-iframe';
        fr.src = '/voice-frame/' + groupId;
        fr.style.cssText = 'position:fixed;width:0;height:0;border:0;opacity:0;pointer-events:none;';
        fr.allow = 'microphone; display-capture';
        document.body.appendChild(fr);
        /* Start voice in iframe once loaded */
        fr.addEventListener('load', function() {
          _bc = new BroadcastChannel('vc_' + groupId);
          _bc.postMessage({ type: 'start' });
          _bc.onmessage = function(e) { window._vcHandleMsg && window._vcHandleMsg(e.data); };
        });
      } else {
        /* iframe already exists, just ensure BC is open */
        if (!_bc) {
          _bc = new BroadcastChannel('vc_' + groupId);
          _bc.onmessage = function(e) { window._vcHandleMsg && window._vcHandleMsg(e.data); };
        }
      }
    },
    clear: function() {
      sessionStorage.removeItem(CALL_KEY);
      if (_bc) { _bc.postMessage({ type: 'hangup' }); _bc.close(); _bc = null; }
      const fr = document.getElementById('voice-iframe');
      if (fr) fr.remove();
      const bar = document.getElementById('float-call-bar');
      if (bar) bar.remove();
    },
    get: function() {
      try { return JSON.parse(sessionStorage.getItem(CALL_KEY)); } catch(e) { return null; }
    },
    sendCmd: function(cmd) { if (_bc) _bc.postMessage({ type: cmd }); },
    getBC: function() { return _bc; }
  };

  /* ── Floating call bar ── */
  function renderCallBar() {
    const state = window.voicePersist.get();
    if (!state) return;
    if (window.location.pathname === '/groups/' + state.groupId) return;
    if (document.getElementById('float-call-bar')) return;

    const bar = document.createElement('div');
    bar.id = 'float-call-bar';
    bar.innerHTML =
      '<div style="display:flex;align-items:center;gap:0.75rem;flex:1;min-width:0;">' +
        '<div style="width:8px;height:8px;border-radius:50%;background:#10b981;box-shadow:0 0 8px #10b981;flex-shrink:0;animation:callPulse 1.5s infinite;"></div>' +
        '<div style="min-width:0;"><div style="font-weight:700;font-size:0.82rem;color:#10b981;">In Voice Call</div>' +
        '<div style="font-size:0.72rem;color:rgba(255,255,255,0.5);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + (state.groupName || 'Group') + '</div></div>' +
      '</div>' +
      '<a href="/groups/' + state.groupId + '" class="fcb-return">↩ Return</a>' +
      '<button class="fcb-hang" id="float-call-hang" title="Hang Up">' +
        '<svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>' +
      '</button>';

    document.body.appendChild(bar);

    document.getElementById('float-call-hang').addEventListener('click', function() {
      window.voicePersist.clear();
    });

    /* Restore iframe if navigated away */
    if (!document.getElementById('voice-iframe')) {
      const fr = document.createElement('iframe');
      fr.id = 'voice-iframe';
      fr.src = '/voice-frame/' + state.groupId;
      fr.style.cssText = 'position:fixed;width:0;height:0;border:0;opacity:0;pointer-events:none;';
      fr.allow = 'microphone; display-capture';
      document.body.appendChild(fr);
      fr.addEventListener('load', function() {
        _bc = new BroadcastChannel('vc_' + state.groupId);
        _bc.onmessage = function(e) { window._vcHandleMsg && window._vcHandleMsg(e.data); };
        /* Don't auto-start on restore — user needs to re-join from the group page */
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', renderCallBar);
  } else {
    renderCallBar();
  }
})();
</script>

