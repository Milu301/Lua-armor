<aside class="sidebar">
  <div class="sidebar-logo">
    <div class="logo-text">
      <div class="logo-icon">🔑</div>
      <%= panelName %>
    </div>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-section-label">Principal</div>
    <a href="/dashboard" class="nav-link <%= page === 'dashboard' ? 'active' : '' %>">
      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <rect x="3" y="3" width="7" height="7" rx="1" stroke-width="2"/>
        <rect x="14" y="3" width="7" height="7" rx="1" stroke-width="2"/>
        <rect x="3" y="14" width="7" height="7" rx="1" stroke-width="2"/>
        <rect x="14" y="14" width="7" height="7" rx="1" stroke-width="2"/>
      </svg>
      Dashboard
    </a>
    <a href="/dashboard#hwid" class="nav-link">
      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-width="2" d="M9 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V9l-6-6z"/>
        <path stroke-width="2" d="M9 3v6h6"/>
      </svg>
      Reset HWID
    </a>
    <a href="/dashboard#keyinfo" class="nav-link">
      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="8" stroke-width="2"/>
        <path stroke-linecap="round" stroke-width="2" d="m21 21-4.35-4.35"/>
      </svg>
      Info de Key
    </a>
    <a href="/dashboard#discord" class="nav-link">
      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-width="2" d="M18 9a5 5 0 00-5-5H6a5 5 0 00-5 5v6l4-2h8a5 5 0 005-5z"/>
      </svg>
      Discord Link
    </a>
  </nav>

  <div class="sidebar-user">
    <div class="user-avatar">🔑</div>
    <div class="user-meta">
      <div class="user-name font-mono" style="font-size:0.7rem;">
        <%= user ? user.key.slice(0,12) + '…' : '—' %>
      </div>
      <div class="user-sub">Key vinculada</div>
    </div>
    <form action="/logout" method="POST" style="display:inline;">
      <button type="submit" class="btn-logout" title="Cerrar sesión">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
        </svg>
      </button>
    </form>
  </div>
</aside>
