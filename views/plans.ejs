<%- include('partials/head', { title: 'Plans & Pricing — ' + panelName }) %>

<style>
/* Remove inline Google Fonts imports since they are in head.ejs */

:root {
  --bg: #07070f;
  --surface: rgba(18, 18, 26, 0.6);
  --primary: #8b5cf6;
  --primary-light: #a78bfa;
  --border: rgba(255, 255, 255, 0.12);
  --text: #f8fafc;
  --text-dim: #94a3b8;
}

body {
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  overflow-x: hidden;
  background-color: var(--bg);
  font-family: 'Inter', sans-serif;
  color: var(--text);
  padding: 4rem 1rem;
}

/* Ambient Background */
.ambient-bg {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -2;
  background: 
    radial-gradient(circle at 10% 20%, rgba(139, 92, 246, 0.15) 0%, transparent 50%),
    radial-gradient(circle at 90% 80%, rgba(14, 165, 233, 0.1) 0%, transparent 50%);
  filter: blur(80px);
}

.pricing-container {
  width: 100%;
  max-width: 1200px;
  position: relative;
  z-index: 10;
  animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

.pricing-header {
  text-align: center;
  margin-bottom: 4rem;
}

.pricing-header h1 {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 3.5rem;
  font-weight: 800;
  line-height: 1.1;
  margin-bottom: 1rem;
  background: linear-gradient(135deg, #fff, #a78bfa);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.pricing-header p {
  font-size: 1.1rem;
  color: var(--text-dim);
  max-width: 500px;
  margin: 0 auto;
  line-height: 1.6;
}

.plans-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 2rem;
  align-items: stretch;
  justify-content: center;
}

.plan-card {
  background: var(--surface);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1px solid var(--border);
  border-radius: 24px;
  padding: 3rem 2.5rem;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s;
}

.plan-card:hover {
  transform: translateY(-10px);
}

/* Featured glow */
.plan-card.featured {
  border-color: rgba(139, 92, 246, 0.5);
  box-shadow: 0 30px 60px rgba(0,0,0,0.6), inset 0 0 0 1px rgba(139, 92, 246, 0.2);
  background: linear-gradient(180deg, rgba(30, 27, 75, 0.8) 0%, rgba(15, 23, 42, 0.8) 100%);
}
.plan-card.featured:hover {
  box-shadow: 0 40px 80px rgba(139, 92, 246, 0.25), inset 0 0 0 1px rgba(139, 92, 246, 0.4);
}

.plan-badge {
  position: absolute;
  top: 1.5rem;
  right: 1.5rem;
  background: rgba(139, 92, 246, 0.2);
  color: #c4b5fd;
  padding: 0.4rem 1rem;
  border-radius: 20px;
  font-size: 0.8rem;
  font-weight: 700;
  border: 1px solid rgba(139, 92, 246, 0.4);
}

.plan-icon {
  width: 64px;
  height: 64px;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
  margin-bottom: 2rem;
}

.plan-title {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 1.8rem;
  font-weight: 800;
  margin: 0 0 0.5rem;
}

.plan-desc {
  color: var(--text-dim);
  font-size: 0.95rem;
  margin-bottom: 2rem;
  min-height: 40px;
}

.plan-price {
  font-size: 3rem;
  font-weight: 900;
  font-family: 'Space Grotesk', sans-serif;
  margin-bottom: 2rem;
  display: flex;
  align-items: baseline;
  gap: 0.5rem;
}

.plan-price span {
  font-size: 1rem;
  color: var(--text-dim);
  font-weight: 500;
}

.plan-features {
  list-style: none;
  padding: 0;
  margin: 0 0 2.5rem;
  flex-grow: 1;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.plan-features li {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  font-size: 1rem;
  color: #e2e8f0;
}

.plan-features li i {
  margin-top: 3px;
}

.btn-buy {
  width: 100%;
  padding: 1.2rem;
  border-radius: 14px;
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 700;
  font-size: 1.1rem;
  cursor: pointer;
  transition: 0.3s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  text-decoration: none;
  border: none;
}

.btn-buy-primary {
  background: linear-gradient(135deg, var(--primary), #6366f1);
  color: #fff;
  box-shadow: 0 8px 20px rgba(139, 92, 246, 0.3);
}
.btn-buy-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 25px rgba(139, 92, 246, 0.5);
}

.btn-buy-secondary {
  background: rgba(255,255,255,0.05);
  color: #fff;
  border: 1px solid var(--border);
}
.btn-buy-secondary:hover {
  background: rgba(255,255,255,0.1);
  border-color: rgba(255,255,255,0.2);
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(40px); }
  to { opacity: 1; transform: translateY(0); }
}

@media (max-width: 768px) {
  .pricing-header h1 { font-size: 2.5rem; }
  .plan-card { padding: 2rem 1.5rem; }
}
</style>

<script src="https://unpkg.com/@phosphor-icons/web"></script>

<div class="ambient-bg"></div>

<div class="pricing-container">
  
  <div class="pricing-header">
    <div style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(139,92,246,0.1);border:1px solid rgba(139,92,246,0.25);border-radius:20px;padding:0.4rem 1.2rem;margin-bottom:1.5rem;">
      <i class="ph-fill ph-sparkle" style="color: var(--primary-light);"></i>
      <span style="font-size:0.8rem;font-weight:700;color:var(--primary-light);letter-spacing:1px;text-transform:uppercase;">Premium Access</span>
    </div>
    <h1>Upgrade Your Arsenal</h1>
    <p>Get instant access to our powerful script hub, no waits, no ads, just uninterrupted domination.</p>
  </div>

  <div class="plans-grid">

    <% if (plans && plans.length > 0) { %>
      <% plans.forEach((p, idx) => { %>
        <!-- Dynamic Plans from DB -->
        <div class="plan-card <%= idx === 0 ? 'featured' : '' %>" <%= (user && user.projectId === p.project_id) ? 'style="border-color: rgba(16, 185, 129, 0.5);"' : '' %>>
          <% if (user && user.projectId === p.project_id) { %>
            <div class="plan-badge" style="background: rgba(16, 185, 129, 0.2); color: #34d399; border-color: rgba(16, 185, 129, 0.4);">CURRENT PLAN</div>
          <% } else if (idx === 0) { %>
            <div class="plan-badge">RECOMMENDED</div>
          <% } %>
          
          <div class="plan-icon" style="background: <%= p.gradient || 'rgba(139,92,246,0.15)' %>; color: <%= p.color || '#a78bfa' %>; border: 1px solid <%= p.color ? p.color+'40' : 'rgba(139,92,246,0.3)' %>;">
            <%- p.icon || '<i class="ph-fill ph-crown"></i>' %>
          </div>
          
          <h3 class="plan-title"><%= p.name %></h3>
          <p class="plan-desc"><%= p.description || 'Premium access for your account.' %></p>
          
          <div class="plan-price">
            $<%= Number(p.price_usd).toFixed(2) %> <span>USD</span>
          </div>
          
          <ul class="plan-features">
            <li><i class="ph-fill ph-check-circle" style="color: #10b981;"></i> <%= p.duration_days %> days of full access</li>
            <li><i class="ph-fill ph-check-circle" style="color: #10b981;"></i> Instant key delivery</li>
            <li><i class="ph-fill ph-check-circle" style="color: #10b981;"></i> No ads or waits</li>
            <li><i class="ph-fill ph-check-circle" style="color: #10b981;"></i> Priority support</li>
          </ul>
          
          <% if (user) { %>
            <div style="display: flex; flex-direction: column; gap: 0.5rem; margin-top: auto;">
              <% if (user.projectId === p.project_id) { %>
                <button class="btn-buy btn-buy-secondary" style="border-color: rgba(16, 185, 129, 0.4); color: #34d399;" onclick="startCheckout(<%= p.id %>, '<%= p.name %>', this)">
                  <i class="ph-bold ph-arrows-clockwise"></i> Renew / Extend
                </button>
              <% } else { %>
                <button class="btn-buy <%= idx === 0 ? 'btn-buy-primary' : 'btn-buy-secondary' %>" onclick="startCheckout(<%= p.id %>, '<%= p.name %>', this)">
                  <i class="ph-bold ph-credit-card"></i> Pay Securely with Bold
                </button>
              <% } %>
            </div>
          <% } else { %>
            <div style="display: flex; flex-direction: column; gap: 0.5rem; margin-top: auto;">
              <a href="/login" class="btn-buy <%= idx === 0 ? 'btn-buy-primary' : 'btn-buy-secondary' %>">
                <i class="ph-bold ph-sign-in"></i> Login to Purchase
              </a>
            </div>
          <% } %>
        </div>
      <% }) %>
    <% } else { %>
      <!-- Fallback / Default Layout if no plans in DB -->
      <div class="plan-card">
        <div class="plan-icon" style="background: rgba(59, 130, 246, 0.15); color: #60a5fa; border: 1px solid rgba(59, 130, 246, 0.3);">
          <i class="ph-fill ph-shield-check"></i>
        </div>
        <h3 class="plan-title">Monthly</h3>
        <p class="plan-desc">Perfect for testing the waters and dominating for a month.</p>
        <div class="plan-price">$4.99 <span>USD</span></div>
        <ul class="plan-features">
          <li><i class="ph-fill ph-check-circle" style="color: #10b981;"></i> 30 days of full access</li>
          <li><i class="ph-fill ph-check-circle" style="color: #10b981;"></i> Bypass all wait times</li>
          <li><i class="ph-fill ph-check-circle" style="color: #10b981;"></i> Universal script execution</li>
        </ul>
        <a href="<%= typeof discordUrl !== 'undefined' ? discordUrl : '#' %>" target="_blank" class="btn-buy btn-buy-secondary">
          <i class="ph-bold ph-discord-logo"></i> Purchase via Discord
        </a>
      </div>

      <div class="plan-card featured">
        <div class="plan-badge">BEST VALUE</div>
        <div class="plan-icon" style="background: rgba(139, 92, 246, 0.15); color: #c4b5fd; border: 1px solid rgba(139, 92, 246, 0.3);">
          <i class="ph-fill ph-crown"></i>
        </div>
        <h3 class="plan-title">Lifetime</h3>
        <p class="plan-desc">The ultimate commitment to superiority. Never pay again.</p>
        <div class="plan-price">$19.99 <span>USD</span></div>
        <ul class="plan-features">
          <li><i class="ph-fill ph-check-circle" style="color: #10b981;"></i> Lifetime full access</li>
          <li><i class="ph-fill ph-check-circle" style="color: #10b981;"></i> All future updates included</li>
          <li><i class="ph-fill ph-check-circle" style="color: #10b981;"></i> Exclusive Goldfarm scripts</li>
          <li><i class="ph-fill ph-check-circle" style="color: #10b981;"></i> Priority 1-on-1 support</li>
        </ul>
        <a href="<%= typeof discordUrl !== 'undefined' ? discordUrl : '#' %>" target="_blank" class="btn-buy btn-buy-primary">
          <i class="ph-bold ph-discord-logo"></i> Purchase via Discord
        </a>
      </div>
    <% } %>

  </div>

  <% if (user) { %>
    <div style="margin: 3rem auto 2.5rem; max-width: 400px; text-align: center; animation: slideUp 0.8s ease 0.2s backwards;">
      <div style="background: var(--surface); padding: 1.5rem; border-radius: 16px; border: 1px solid var(--border); box-shadow: 0 10px 30px rgba(0,0,0,0.2);">
        <label style="display: block; font-family: 'Space Grotesk', sans-serif; font-weight: 700; margin-bottom: 0.8rem; color: #fff; display: flex; align-items: center; justify-content: center; gap: 0.5rem;"><i class="ph-fill ph-tag" style="color: var(--primary-light);"></i> Have a Promo Code?</label>
        <div style="display: flex; gap: 0.5rem;">
          <input type="text" id="promo-code-input" placeholder="ENTER CODE..." style="flex: 1; padding: 0.8rem 1rem; border-radius: 12px; border: 1px solid var(--border); background: rgba(0,0,0,0.4); color: #fff; font-size: 1rem; text-transform: uppercase; text-align: center; font-weight: 600; letter-spacing: 1px;">
        </div>
        <div style="font-size: 0.8rem; color: var(--text-dim); margin-top: 0.8rem;">Discount will be calculated and securely applied before payment.</div>
      </div>
    </div>
  <% } else { %>
    <div style="height: 3rem;"></div>
  <% } %>

    <div style="display:flex;align-items:center;justify-content:center;gap:1.5rem;flex-wrap:wrap;margin-bottom:2rem;">
      <div style="display:flex;align-items:center;gap:0.4rem;font-size:0.8rem;color:var(--text-dim);">
        <i class="ph-fill ph-shield-check" style="color:var(--primary-light);"></i>
        Secured by Bold
      </div>
      <div style="display:flex;align-items:center;gap:0.4rem;font-size:0.8rem;color:var(--text-dim);">
        <i class="ph-fill ph-credit-card" style="color:var(--primary-light);"></i>
        Visa · Mastercard · Amex · PSE · Nequi
      </div>
      <div style="display:flex;align-items:center;gap:0.4rem;font-size:0.8rem;color:var(--text-dim);">
        <i class="ph-fill ph-lightning" style="color:var(--primary-light);"></i>
        Instant Key Delivery
      </div>
    </div>

    <p style="color: var(--text-dim); font-size: 0.95rem; margin-bottom: 1.5rem;">Need a custom plan or have questions? Contact us on our Discord server.</p>
    <% if (user) { %>
    <a href="/dashboard" style="color: #fff; text-decoration: none; font-weight: 600; font-size: 0.9rem;">← Back to Dashboard</a>
    <% } else { %>
    <a href="/home" style="color: #fff; text-decoration: none; font-weight: 600; font-size: 0.9rem;">← Back to Home</a>
    <% } %>
  </div>

</div>

<!-- Bold Checkout JS Library -->
<script src="https://checkout.bold.co/library/boldPaymentButton.js"></script>

<script>
async function startCheckout(planId, planName, btn) {
  const orig = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<i class="ph-bold ph-spinner ph-spin"></i> Preparing...';

  const promoInput = document.getElementById('promo-code-input');
  const promoCode = promoInput ? promoInput.value.trim() : '';

  try {
    const res  = await fetch('/api/payment/create-order', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ plan_id: planId, promo_code: promoCode })
    });
    const data = await res.json();

    if (!data.success) {
      alert(data.message || 'Error creating order');
      btn.disabled = false;
      btn.innerHTML = orig;
      return;
    }

    /* Open Bold Widget */
    const checkout = new BoldCheckout({
      orderId: data.order_ref,
      currency: "COP",
      amount: data.amount_cop.toString(),
      apiKey: data.identity_key,
      integritySignature: data.integrity,
      description: `${planName} — AuroraHub`,
      redirectionUrl: window.location.origin + '/payment/success?ref=' + data.order_ref
    });
    checkout.open();

    btn.disabled = false;
    btn.innerHTML = orig;

  } catch (err) {
    alert('Network error. Please try again.');
    btn.disabled = false;
    btn.innerHTML = orig;
  }
}

async function claimGamepass(planId, planName, btn) {
  const orig = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<i class="ph-bold ph-spinner ph-spin"></i> Verifying...';

  try {
    const res = await fetch('/api/payment/claim-gamepass', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ plan_id: planId })
    });
    const data = await res.json();
    
    if (data.success) {
      alert('Gamepass verified successfully! Your new plan and key have been added to your dashboard.');
      window.location.href = '/dashboard';
    } else {
      alert(data.message || 'Verification failed.');
      btn.disabled = false;
      btn.innerHTML = orig;
    }
  } catch (err) {
    alert('Network error during verification. Please try again.');
    btn.disabled = false;
    btn.innerHTML = orig;
  }
}
</script>

</body>
</html>
