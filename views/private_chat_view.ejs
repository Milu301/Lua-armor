<%- include('partials/head', { title: 'Private Chat' }) %>

<div class="layout">
  <%- include('partials/sidebar', { page: 'private_chats' }) %>

  <div class="main">
    <div class="topbar">
      <div class="topbar-left">
        <div class="pulse-dot" style="background:var(--green);"></div>
        <div class="topbar-title">Chat with <%= otherUserName %></div>
      </div>
      <div class="topbar-right">
        <a href="/private-chats" class="btn btn-sm btn-ghost">
          <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Back
        </a>
      </div>
    </div>

    <div class="content" style="display:flex; flex-direction:column; height: calc(100vh - 60px); padding-bottom:1rem;">
      <div class="card" style="flex:1; display:flex; flex-direction:column; margin-bottom:0; overflow:hidden;">
        
        <div id="chat-messages" style="flex:1; overflow-y:auto; padding:1.5rem; display:flex; flex-direction:column; gap:1rem;">
          <% if (messages && messages.length > 0) { %>
            <% messages.forEach(m => { %>
              <div style="display:flex; flex-direction:column; <%= m.sender_id === user.id ? 'align-items:flex-end;' : 'align-items:flex-start;' %>">
                <div style="font-size:0.75rem; color:var(--text-3); margin-bottom:0.25rem; display:flex; gap:0.5rem; align-items:center;">
                  <% if (m.sender_id !== user.id) { %><strong><%= m.username %></strong><% } %>
                  <span><%= new Date(m.created_at).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'}) %></span>
                  <% if (m.sender_id === user.id) { %><strong>You</strong><% } %>
                </div>
                <div style="max-width:75%; padding:0.75rem 1rem; border-radius:1rem; <%= m.sender_id === user.id ? 'background:var(--accent); color:#fff; border-bottom-right-radius:0.25rem;' : 'background:var(--bg-raised); color:var(--text); border:1px solid var(--border); border-bottom-left-radius:0.25rem;' %>">
                  <div style="white-space:pre-wrap; word-break:break-word; line-height:1.4;"><%= m.content %></div>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; color:var(--text-3);">
              <svg width="48" height="48" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="margin-bottom:1rem; opacity:0.5;">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
              <div>Start the conversation with <%= otherUserName %></div>
            </div>
          <% } %>
        </div>

        <div style="padding:1rem; border-top:1px solid var(--border); background:var(--bg-card);">
          <form id="chat-form" style="display:flex; gap:0.5rem;" onsubmit="sendMessage(event)">
            <textarea id="chat-input" class="input" rows="1" placeholder="Type a message..." style="flex:1; resize:none; padding-top:0.6rem;" onkeydown="if(event.key==='Enter' && !event.shiftKey){event.preventDefault(); sendMessage(event);}" required></textarea>
            <button type="submit" id="send-btn" class="btn btn-primary" style="padding-inline:1.5rem;">Send</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function scrollBottom() {
  const el = document.getElementById('chat-messages');
  el.scrollTop = el.scrollHeight;
}
scrollBottom();

async function sendMessage(e) {
  if (e) e.preventDefault();
  const input = document.getElementById('chat-input');
  const content = input.value.trim();
  if (!content) return;
  
  const btn = document.getElementById('send-btn');
  btn.disabled = true;
  input.value = '';
  
  try {
    const res = await fetch('/api/private-chat/<%= chat.id %>/message', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ content })
    });
    const data = await res.json();
    if (data.success) {
      window.location.reload();
    } else {
      alert(data.message || 'Error sending message');
    }
  } catch(err) {
    alert('Network error');
  }
  btn.disabled = false;
}
</script>
</body>
</html>
