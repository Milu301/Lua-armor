<%- include('partials/head', { title: 'Register — ' + panelName }) %>

<div class="auth-page">
  <div class="auth-bg">
    <div class="auth-orb auth-orb-1"></div>
    <div class="auth-orb auth-orb-2"></div>
    <div class="auth-orb auth-orb-3"></div>
    <div class="auth-grid"></div>
  </div>

  <div class="auth-card auth-card-wide">
    <div class="auth-card-shine"></div>

    <!-- Brand -->
    <div class="auth-brand">
      <div class="auth-logo">
        <img src="<%= panelLogo %>" alt="<%= panelName %>" style="width:40px;height:40px;border-radius:10px;object-fit:cover;" />
      </div>
      <div class="auth-brand-text">
        <div class="auth-brand-name"><%= panelName %></div>
        <div class="auth-brand-sub">Member Dashboard</div>
      </div>
    </div>

    <div class="auth-divider"></div>

    <h1 class="auth-heading">Create your account</h1>
    <p class="auth-sub">You need a valid Luarmor key to register. Your key determines your project tier automatically.</p>

    <% if (error) { %>
    <div class="alert alert-danger" style="margin-bottom:1.25rem;">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="flex-shrink:0">
        <circle cx="12" cy="12" r="10" stroke-width="2"/>
        <path stroke-linecap="round" stroke-width="2" d="M12 8v4m0 4h.01"/>
      </svg>
      <span><%= error %></span>
    </div>
    <% } %>

    <form action="/register" method="POST" id="regForm" autocomplete="off">
      <!-- Row 1: username + key -->
      <div class="reg-grid">
        <div class="form-group" style="margin-bottom:0;">
          <label class="label">Username</label>
          <div class="input-wrap">
            <svg class="input-icon" width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            <input type="text" name="username" class="input input-icon-pad" placeholder="your_username"
              required minlength="3" maxlength="20" autocomplete="off" spellcheck="false"
              pattern="[a-z0-9_]{3,20}" title="3-20 chars: letters, numbers, underscore" />
          </div>
          <div class="input-hint">3-20 chars · letters, numbers, underscore</div>
        </div>

        <div class="form-group" style="margin-bottom:0;">
          <label class="label">Luarmor Key</label>
          <div class="input-wrap">
            <svg class="input-icon" width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
            </svg>
            <input type="text" name="key" id="keyField" class="input input-icon-pad mono"
              placeholder="Paste your Luarmor key…" required minlength="6" maxlength="256"
              autocomplete="off" spellcheck="false" autocorrect="off" autocapitalize="off" />
          </div>
          <div class="input-hint">Purchased from our Discord or shop</div>
        </div>
      </div>

      <!-- Row 2: passwords -->
      <div class="reg-grid" style="margin-top:1rem;">
        <div class="form-group" style="margin-bottom:0;">
          <label class="label">Password</label>
          <div class="input-wrap">
            <svg class="input-icon" width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <rect x="3" y="11" width="18" height="11" rx="2" stroke-width="2"/>
              <path stroke-linecap="round" stroke-width="2" d="M7 11V7a5 5 0 0110 0v4"/>
            </svg>
            <input type="password" name="password" id="pw1" class="input input-icon-pad"
              placeholder="Min. 8 characters" required minlength="8" autocomplete="new-password" />
          </div>
        </div>

        <div class="form-group" style="margin-bottom:0;">
          <label class="label">Confirm Password</label>
          <div class="input-wrap">
            <svg class="input-icon" width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <input type="password" name="confirm" id="pw2" class="input input-icon-pad"
              placeholder="Repeat password" required minlength="8" autocomplete="new-password" />
          </div>
        </div>
      </div>

      <!-- Strength bar -->
      <div style="margin-top:0.625rem;" id="pw-strength-wrap" style="display:none;">
        <div style="display:flex;gap:4px;margin-bottom:4px;" id="pw-bars">
          <div class="pw-bar" id="pb1"></div>
          <div class="pw-bar" id="pb2"></div>
          <div class="pw-bar" id="pb3"></div>
          <div class="pw-bar" id="pb4"></div>
        </div>
        <div class="t-xs dimmed" id="pw-label"></div>
      </div>

      <!-- Key preview / project detection -->
      <div id="key-preview" class="key-preview-box" style="display:none;margin-top:1rem;"></div>

      <button type="submit" class="btn btn-primary btn-full btn-lg" id="regBtn" style="margin-top:1.25rem;">
        <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
        </svg>
        Create Account
      </button>
    </form>

    <div class="auth-footer-links">
      <span class="dimmed t-sm">Already have an account?</span>
      <a href="/login" class="auth-link">
        Sign in
        <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <% if (projects && projects.length > 0) { %>
    <!-- Available tiers -->
    <div class="reg-tiers">
      <div class="reg-tiers-label">Available Project Tiers</div>
      <div class="reg-tiers-grid">
        <% projects.forEach(p => { %>
        <div class="reg-tier-card">
          <div class="reg-tier-icon" style="background:<%= p.gradient %>;">
            <%= p.icon %>
          </div>
          <div class="reg-tier-info">
            <div class="reg-tier-name"><%= p.name %></div>
            <div class="reg-tier-resets"><%= p.daily_reset_limit %> resets/day</div>
          </div>
          <% if (p.description) { %>
          <div class="reg-tier-desc"><%= p.description %></div>
          <% } %>
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <div class="auth-discord-strip">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="#5865f2">
        <path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/>
      </svg>
      <span class="t-xs">Buy or request a key in our Discord server.</span>
      <a href="<%= discordUrl %>" target="_blank" rel="noopener" class="btn btn-sm" style="background:rgba(88,101,242,0.15);border:1px solid rgba(88,101,242,0.30);color:#818cf8;margin-left:auto;">
        Join Discord
      </a>
    </div>
  </div>

  <div class="auth-version">v3.0 · Secured by Luarmor</div>
</div>

<script>
/* Password strength */
const pw1 = document.getElementById('pw1');
const pw2 = document.getElementById('pw2');
const strengthWrap = document.getElementById('pw-strength-wrap');
const bars = [1,2,3,4].map(i => document.getElementById('pb' + i));
const label = document.getElementById('pw-label');

const strengthColors = ['#ef4444','#f59e0b','#3b82f6','#22c55e'];
const strengthLabels = ['Too weak','Could be stronger','Good','Strong'];

pw1.addEventListener('input', function() {
  const v = this.value;
  if (!v) { strengthWrap.style.display = 'none'; return; }
  strengthWrap.style.display = '';

  let score = 0;
  if (v.length >= 8)  score++;
  if (v.length >= 12) score++;
  if (/[A-Z]/.test(v) && /[a-z]/.test(v)) score++;
  if (/[0-9]/.test(v) || /[^a-zA-Z0-9]/.test(v)) score++;
  score = Math.max(1, Math.min(4, score));

  bars.forEach((b, i) => {
    b.style.background = i < score ? strengthColors[score - 1] : 'var(--bg-raised)';
  });
  label.textContent = strengthLabels[score - 1];
  label.style.color = strengthColors[score - 1];
});

/* Password match indicator */
pw2.addEventListener('input', function() {
  if (this.value && pw1.value) {
    this.style.borderColor = this.value === pw1.value ? 'var(--green-border)' : 'var(--red-border)';
  } else {
    this.style.borderColor = '';
  }
});

/* Key preview */
const keyField = document.getElementById('keyField');
const keyPreview = document.getElementById('key-preview');
let keyTimer = null;

keyField.addEventListener('input', function() {
  clearTimeout(keyTimer);
  const val = this.value.trim();
  if (val.length < 6) { keyPreview.style.display = 'none'; return; }
  keyPreview.style.display = '';
  keyPreview.innerHTML = '<div class="key-preview-inner"><div class="spinner" style="width:14px;height:14px;border-width:2px;flex-shrink:0;"></div><span class="dimmed t-sm">Key looks good — will be verified on submit</span></div>';
});

/* Submit */
document.getElementById('regForm').addEventListener('submit', function(e) {
  const p1 = document.getElementById('pw1').value;
  const p2 = document.getElementById('pw2').value;
  if (p1 !== p2) {
    e.preventDefault();
    document.getElementById('pw2').style.borderColor = 'var(--red-border)';
    return;
  }
  const btn = document.getElementById('regBtn');
  btn.disabled = true;
  btn.innerHTML = '<div class="spinner"></div> Verifying key with Luarmor…';
});

/* ─── Auth Particle Canvas ─── */
(function() {
  const canvas = document.createElement('canvas');
  canvas.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0;opacity:0.45;';
  document.querySelector('.auth-bg').appendChild(canvas);
  const ctx = canvas.getContext('2d');
  let W, H;
  function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
  resize();
  window.addEventListener('resize', resize, { passive: true });
  const COLS = ['rgba(147,51,234,', 'rgba(99,102,241,', 'rgba(255,255,255,', 'rgba(6,182,212,'];
  const pts = Array.from({ length: 65 }, () => ({
    x: Math.random() * 1920, y: Math.random() * 1080,
    r: 0.4 + Math.random() * 1.5,
    vx: (Math.random() - 0.5) * 0.3, vy: -0.08 - Math.random() * 0.2,
    a: 0.08 + Math.random() * 0.3, c: COLS[Math.floor(Math.random() * COLS.length)]
  }));
  (function loop() {
    ctx.clearRect(0, 0, W, H);
    pts.forEach(p => {
      p.x += p.vx; p.y += p.vy;
      if (p.y < -4 || p.x < -4 || p.x > W + 4) { p.x = Math.random() * W; p.y = H + 4; }
      ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = p.c + p.a + ')'; ctx.fill();
    });
    requestAnimationFrame(loop);
  })();
})();
</script>
</body>
</html>
