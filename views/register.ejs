<%- include('partials/head', { title: 'Create Account — ' + panelName }) %>

<style>
/* Remove inline Google Fonts imports since they are in head.ejs */

:root {
  --bg: #07070f;
  --surface: rgba(18, 18, 26, 0.6);
  --primary: #8b5cf6;
  --primary-light: #a78bfa;
  --border: rgba(255, 255, 255, 0.12);
  --text: #f8fafc;
  --text-dim: #94a3b8;
}

body {
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  overflow: hidden;
  background-color: var(--bg);
}

.auth-container {
  display: flex;
  width: 100%;
  max-width: 1200px;
  height: 100vh;
  position: relative;
  z-index: 10;
}

/* Left Panel (Branding) */
.auth-left {
  flex: 1;
  display: none; /* hidden on mobile */
  flex-direction: column;
  justify-content: center;
  padding: 4rem;
  position: relative;
}

@media (min-width: 1024px) {
  .auth-left {
    display: flex;
  }
}

.auth-left h1 {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 3.5rem;
  font-weight: 800;
  line-height: 1.1;
  margin-bottom: 1.5rem;
  background: linear-gradient(135deg, #fff, #a78bfa);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.auth-left p {
  font-size: 1.1rem;
  color: var(--text-dim);
  max-width: 400px;
  line-height: 1.6;
  margin-bottom: 3rem;
}

.info-box {
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.05), rgba(14, 165, 233, 0.05));
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 1.5rem;
  max-width: 440px;
}
.info-box-title {
  font-family: 'Space Grotesk', sans-serif; font-weight: 700; color: var(--primary-light);
  display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px;
}
.info-step { display: flex; gap: 1rem; margin-bottom: 1.5rem; align-items: flex-start; }
.info-step:last-child { margin-bottom: 0; }
.info-icon {
  width: 36px; height: 36px; border-radius: 10px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center; font-size: 1.2rem;
}
.info-text h4 { margin: 0 0 0.3rem; font-family: 'Space Grotesk', sans-serif; font-size: 1rem; color: #fff; }
.info-text p { margin: 0; font-size: 0.85rem; color: var(--text-dim); line-height: 1.5; }

/* Right Panel (Form) */
.auth-right {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
  overflow-y: auto; /* allows scrolling for register form if it's too tall */
}

/* Auth Card */
.auth-card {
  width: 100%;
  max-width: 440px;
  background: var(--surface);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1px solid var(--border);
  border-radius: 24px;
  padding: 2.5rem;
  box-shadow: 0 30px 80px rgba(0,0,0,0.8), inset 0 1px 1px rgba(255,255,255,0.05);
  position: relative;
  overflow: hidden;
  animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  margin: auto 0;
}

.auth-card::before {
  content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 2px;
  background: linear-gradient(90deg, transparent, var(--primary-light), transparent);
  opacity: 0.5;
}

.brand-header-mobile {
  display: flex; align-items: center; justify-content: center; flex-direction: column;
  margin-bottom: 2.5rem;
}
@media (min-width: 1024px) {
  .brand-header-mobile { display: none; }
}

.brand-header-mobile img {
  width: 56px; height: 56px; border-radius: 16px; margin-bottom: 1rem;
  box-shadow: 0 0 20px rgba(139, 92, 246, 0.4); border: 1px solid var(--border);
}
.brand-header-mobile h2 {
  font-family: 'Space Grotesk', sans-serif; font-size: 1.8rem; font-weight: 800; margin: 0 0 0.5rem; letter-spacing: -0.5px;
}

.form-title {
  display: none;
}
@media (min-width: 1024px) {
  .form-title {
    display: block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }
  .form-subtitle {
    color: var(--text-dim);
    margin-bottom: 2rem;
  }
}

.form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
@media (max-width: 600px) { .form-grid { grid-template-columns: 1fr; } }

.form-group { margin-bottom: 1.5rem; }
.form-label {
  display: flex; justify-content: space-between; align-items: center;
  font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 0.9rem;
  color: var(--text-dim); margin-bottom: 0.6rem;
}

.input-wrapper { position: relative; display: flex; align-items: center; }
.input-wrapper i.left-icon {
  position: absolute; left: 1rem; color: var(--text-dim); font-size: 1.2rem;
  transition: 0.3s;
}
.form-input {
  width: 100%; background: rgba(0, 0, 0, 0.5); border: 1px solid var(--border);
  border-radius: 12px; padding: 0.8rem 1rem 0.8rem 2.8rem;
  color: #fff; font-size: 1rem; font-family: 'Inter', sans-serif; transition: 0.3s;
}
.form-input:focus {
  outline: none; border-color: var(--primary); background: rgba(0,0,0,0.7);
  box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.15);
}
.form-input:focus + i.left-icon { color: var(--primary-light); }
.input-hint { font-size: 0.75rem; color: var(--text-dim); margin-top: 0.4rem; }

.badge {
  font-size: 0.7rem; padding: 0.2rem 0.6rem; border-radius: 12px; font-weight: 700; text-transform: uppercase;
}
.badge-free { background: rgba(16, 185, 129, 0.1); color: #34d399; border: 1px solid rgba(16, 185, 129, 0.2); }
.badge-premium { background: rgba(245, 158, 11, 0.1); color: #fbbf24; border: 1px solid rgba(245, 158, 11, 0.2); }

.pw-bars { display: flex; gap: 4px; margin-top: 0.5rem; }
.pw-bar { height: 4px; flex-grow: 1; background: rgba(255,255,255,0.1); border-radius: 2px; transition: 0.3s; }
.pw-label { font-size: 0.75rem; margin-top: 0.3rem; text-align: right; }

.btn-submit {
  width: 100%; background: linear-gradient(135deg, var(--primary), #6366f1);
  color: #fff; border: none; padding: 1rem; border-radius: 12px;
  font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 1.1rem;
  cursor: pointer; transition: 0.3s; display: flex; align-items: center; justify-content: center; gap: 0.5rem;
  box-shadow: 0 8px 20px rgba(139, 92, 246, 0.3); margin-top: 1rem;
}
.btn-submit:hover { transform: translateY(-2px); box-shadow: 0 12px 25px rgba(139, 92, 246, 0.5); }
.btn-submit:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }

.auth-footer { margin-top: 2rem; text-align: center; color: var(--text-dim); font-size: 0.95rem; }
.auth-footer a { color: #fff; font-weight: 600; text-decoration: none; position: relative; }
.auth-footer a::after { content: ''; position: absolute; bottom: -2px; left: 0; width: 0%; height: 1px; background: #fff; transition: 0.3s; }
.auth-footer a:hover::after { width: 100%; }

.discord-strip {
  margin-top: 2rem; background: rgba(88, 101, 242, 0.1); border: 1px solid rgba(88, 101, 242, 0.2);
  border-radius: 12px; padding: 1rem; display: flex; align-items: center; gap: 1rem;
}
.discord-strip i { color: #5865f2; font-size: 1.5rem; }
.discord-text { flex-grow: 1; font-size: 0.85rem; color: #cbd5e1; }
.btn-discord { background: rgba(88, 101, 242, 0.2); color: #818cf8; text-decoration: none; font-size: 0.8rem; font-weight: 600; padding: 0.4rem 0.8rem; border-radius: 8px; transition: 0.3s; }
.btn-discord:hover { background: rgba(88, 101, 242, 0.4); color: #fff; }

@keyframes slideUp { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }
.spinner { width: 18px; height: 18px; border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff; border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

/* Fix right column scroll on small heights */
@media (max-height: 850px) {
  body { align-items: flex-start; overflow-y: auto; }
  .auth-container { height: auto; min-height: 100vh; }
}
</style>

<div class="auth-container">
  <!-- Left Panel -->
  <div class="auth-left">
    <h1>Join the<br>Community</h1>
    <p>Unlock powerful scripting tools and manage your HWID with our secure authentication platform.</p>
    
    <div class="info-box">
      <div class="info-box-title"><i class="ph-bold ph-info"></i> How Registration Works</div>
      
      <div class="info-step">
        <div class="info-icon" style="background: rgba(245, 158, 11, 0.15); color: #fbbf24; border: 1px solid rgba(245, 158, 11, 0.3);"><i class="ph-fill ph-crown"></i></div>
        <div class="info-text">
          <h4>Premium Access</h4>
          <p>Paste your <strong>Luarmor key</strong> below. Keys are provided upon purchase and unlock instant generation and resets.</p>
        </div>
      </div>
      
      <div class="info-step">
        <div class="info-icon" style="background: rgba(16, 185, 129, 0.15); color: #34d399; border: 1px solid rgba(16, 185, 129, 0.3);"><i class="ph-fill ph-user"></i></div>
        <div class="info-text">
          <h4>Free Access</h4>
          <p>Leave the key field <strong>blank</strong> to register a standard free account.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Right Panel -->
  <div class="auth-right">
    <div class="auth-card">
      <div class="brand-header-mobile">
        <img src="<%= typeof panelLogo !== 'undefined' ? panelLogo : '/logo.png' %>" alt="Logo" onerror="this.src='https://ui-avatars.com/api/?name=AH&background=8b5cf6&color=fff'">
        <h2>Create Account</h2>
      </div>

      <div class="form-title">Create Account</div>
      <div class="form-subtitle">Register a new account to get started</div>

      <% if (error) { %>
      <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3); color: #fca5a5; padding: 0.8rem 1rem; border-radius: 10px; font-size: 0.9rem; display: flex; align-items: center; gap: 0.8rem; margin-bottom: 1.5rem;">
        <i class="ph-fill ph-warning-circle" style="font-size: 1.2rem;"></i>
        <span><%= error %></span>
      </div>
      <% } %>

      <form action="/register" method="POST" id="regForm" autocomplete="off">
        
        <div class="form-group">
          <div class="form-label">Username</div>
          <div class="input-wrapper">
            <input type="text" name="username" class="form-input" placeholder="your_username" required minlength="3" maxlength="20" autocomplete="off" spellcheck="false" pattern="[a-zA-Z0-9_]{3,20}">
            <i class="ph ph-user left-icon"></i>
          </div>
          <div class="input-hint">3-20 chars: letters, numbers, underscore</div>
        </div>

        <div class="form-group">
          <div class="form-label">
            Luarmor Key
            <span id="key-badge" class="badge badge-free">Optional - Free</span>
          </div>
          <div class="input-wrapper">
            <input type="text" name="key" id="keyField" class="form-input" style="font-family: monospace;" placeholder="Paste key or leave blank..." minlength="6" maxlength="256" autocomplete="off" spellcheck="false">
            <i class="ph ph-key left-icon"></i>
          </div>
          <div class="input-hint" id="key-hint">Leave blank to register as a Free User</div>
        </div>

        <div class="form-grid">
          <div class="form-group" style="margin-bottom:0;">
            <div class="form-label">Password</div>
            <div class="input-wrapper">
              <input type="password" name="password" id="pw1" class="form-input" placeholder="Min. 8 chars" required minlength="8" autocomplete="new-password">
              <i class="ph ph-lock-key left-icon"></i>
            </div>
          </div>

          <div class="form-group" style="margin-bottom:0;">
            <div class="form-label">Confirm Password</div>
            <div class="input-wrapper">
              <input type="password" name="confirm" id="pw2" class="form-input" placeholder="Repeat" required minlength="8" autocomplete="new-password">
              <i class="ph ph-check-circle left-icon" id="pw-match-icon"></i>
            </div>
          </div>
        </div>

        <div id="pw-strength-wrap" style="display:none; margin-bottom: 1.5rem;">
          <div class="pw-bars">
            <div class="pw-bar" id="pb1"></div><div class="pw-bar" id="pb2"></div><div class="pw-bar" id="pb3"></div><div class="pw-bar" id="pb4"></div>
          </div>
          <div class="pw-label" id="pw-label"></div>
        </div>

        <button type="submit" class="btn-submit" id="regBtn">
          Create Account <i class="ph-bold ph-arrow-right"></i>
        </button>
      </form>

      <div class="auth-footer">
        Already have an account? <a href="/login">Sign in</a><br>
        <a href="/home" style="color: var(--text-dim); font-size: 0.85rem; font-weight: 400; margin-top: 0.8rem; display: inline-block;">← Back to Home</a>
      </div>

      <div class="discord-strip">
        <i class="ph-fill ph-discord-logo"></i>
        <div class="discord-text">Buy or request a key in our server.</div>
        <a href="<%= typeof discordUrl !== 'undefined' ? discordUrl : '#' %>" target="_blank" class="btn-discord">Join Discord</a>
      </div>
    </div>
  </div>
</div>

<script>
/* Password Strength & Matching */
const pw1 = document.getElementById('pw1');
const pw2 = document.getElementById('pw2');
const strengthWrap = document.getElementById('pw-strength-wrap');
const bars = [1,2,3,4].map(i => document.getElementById('pb' + i));
const label = document.getElementById('pw-label');
const matchIcon = document.getElementById('pw-match-icon');

const strengthColors = ['#ef4444','#f59e0b','#3b82f6','#10b981'];
const strengthLabels = ['Weak','Fair','Good','Strong'];

pw1.addEventListener('input', function() {
  const v = this.value;
  if (!v) { strengthWrap.style.display = 'none'; return; }
  strengthWrap.style.display = 'block';

  let score = 0;
  if (v.length >= 8) score++;
  if (v.length >= 12) score++;
  if (/[A-Z]/.test(v) && /[a-z]/.test(v)) score++;
  if (/[0-9]/.test(v) || /[^a-zA-Z0-9]/.test(v)) score++;
  score = Math.max(1, Math.min(4, score));

  bars.forEach((b, i) => {
    b.style.background = i < score ? strengthColors[score - 1] : 'rgba(255,255,255,0.1)';
  });
  label.textContent = strengthLabels[score - 1];
  label.style.color = strengthColors[score - 1];
  checkMatch();
});

pw2.addEventListener('input', checkMatch);

function checkMatch() {
  if(pw2.value && pw1.value) {
    if(pw2.value === pw1.value) {
      pw2.style.borderColor = '#10b981';
      matchIcon.style.color = '#10b981';
    } else {
      pw2.style.borderColor = '#ef4444';
      matchIcon.style.color = '#ef4444';
    }
  } else {
    pw2.style.borderColor = '';
    matchIcon.style.color = '';
  }
}

/* Key Field Logic */
const keyField = document.getElementById('keyField');
const keyBadge = document.getElementById('key-badge');
const keyHint = document.getElementById('key-hint');

keyField.addEventListener('input', function() {
  const val = this.value.trim();
  if (!val) {
    keyBadge.className = 'badge badge-free';
    keyBadge.innerHTML = 'Optional - Free';
    keyHint.textContent = 'Leave blank to register as a Free User';
  } else {
    keyBadge.className = 'badge badge-premium';
    keyBadge.innerHTML = '<i class="ph-fill ph-crown"></i> Premium Key';
    keyHint.textContent = 'Key will be verified via Luarmor API upon submit';
  }
});

/* Submit Logic */
document.getElementById('regForm').addEventListener('submit', function(e) {
  if (pw1.value !== pw2.value) {
    e.preventDefault();
    pw2.style.borderColor = '#ef4444';
    return;
  }
  const btn = document.getElementById('regBtn');
  btn.disabled = true;
  const isPremium = keyField.value.trim().length > 0;
  btn.innerHTML = `<div class="spinner"></div> ${isPremium ? 'Verifying Key...' : 'Creating Free Account...'}`;
});
</script>
</body>
</html>
