<%- include('partials/head', { title: 'Create Account — ' + panelName }) %>

<div class="auth-page">
  <div class="auth-card auth-card-wide">
    <div class="auth-card-shine"></div>

    <!-- Brand -->
    <div class="auth-brand">
      <div class="auth-logo">
        <img src="<%= typeof panelLogo !== 'undefined' ? panelLogo : '/logo.png' %>" alt="Logo" style="width:100%;height:100%;object-fit:cover;border-radius:inherit;" onerror="this.parentElement.innerHTML='🔑'" />
      </div>
      <div>
        <div class="auth-brand-name"><%= panelName %></div>
        <div class="auth-brand-sub">Create Account</div>
      </div>
    </div>

    <div class="auth-divider"></div>

    <!-- Heading -->
    <h1 class="auth-heading">Join the community</h1>
    <p class="auth-sub">Register to unlock powerful scripting tools and manage your HWID securely.</p>

    <!-- Error -->
    <% if (error) { %>
    <div class="alert alert-danger mb-3">
      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
      <span><%= error %></span>
    </div>
    <% } %>

    <!-- Info box -->
    <div class="card mb-3" style="background:linear-gradient(135deg, rgba(124,58,233,0.06), rgba(6,182,212,0.04));border-color:var(--accent-border);">
      <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:1rem;">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:var(--accent-light);"><path stroke-linecap="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span style="font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--accent-light);">How Registration Works</span>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div style="display:flex;gap:0.75rem;align-items:flex-start;">
          <div style="width:32px;height:32px;border-radius:8px;background:var(--warning-dim);border:1px solid var(--warning-border);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" style="color:var(--warning-light);"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
          <div>
            <div style="font-size:0.82rem;font-weight:600;margin-bottom:2px;">Premium Access</div>
            <div style="font-size:0.72rem;color:var(--text-2);">Paste your <strong>AuroraSafe key</strong> to unlock instant generation and resets.</div>
          </div>
        </div>
        <div style="display:flex;gap:0.75rem;align-items:flex-start;">
          <div style="width:32px;height:32px;border-radius:8px;background:var(--success-dim);border:1px solid var(--success-border);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:var(--success-light);"><path stroke-linecap="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <div>
            <div style="font-size:0.82rem;font-weight:600;margin-bottom:2px;">Free Access</div>
            <div style="font-size:0.72rem;color:var(--text-2);">Leave the key field <strong>blank</strong> to register a standard free account.</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Form -->
    <form action="/register" method="POST" id="regForm" autocomplete="off">
      <div class="form-group">
        <label class="label">Username</label>
        <div class="input-wrap">
          <svg class="input-icon" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          <input type="text" name="username" class="input input-icon-pad" placeholder="your_username" required minlength="3" maxlength="20" autocomplete="off" spellcheck="false" pattern="[a-zA-Z0-9_]{3,20}" />
        </div>
        <div style="font-size:0.7rem;color:var(--text-3);margin-top:0.3rem;">3-20 chars: letters, numbers, underscore</div>
      </div>

      <div class="form-group">
        <label class="label">
          Key
          <span id="key-badge" class="badge badge-green">Optional — Free</span>
        </label>
        <div class="input-wrap">
          <svg class="input-icon" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0v6m-4 0h1M7 9a2 2 0 012-2h6a2 2 0 012 2v6a2 2 0 01-2 2H9a2 2 0 01-2-2V9z"/></svg>
          <input type="text" name="key" id="keyField" class="input input-icon-pad mono" placeholder="Paste key or leave blank..." minlength="6" maxlength="256" autocomplete="off" spellcheck="false" />
        </div>
        <div style="font-size:0.7rem;color:var(--text-3);margin-top:0.3rem;" id="key-hint">Leave blank to register as a Free User</div>
      </div>

      <div class="reg-grid">
        <div class="form-group">
          <label class="label">Password</label>
          <div class="input-wrap">
            <svg class="input-icon" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            <input type="password" name="password" id="pw1" class="input input-icon-pad" placeholder="Min. 8 chars" required minlength="8" autocomplete="new-password" />
          </div>
        </div>

        <div class="form-group">
          <label class="label">Confirm Password</label>
          <div class="input-wrap">
            <svg class="input-icon" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="pw-match-icon"><path stroke-linecap="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <input type="password" name="confirm" id="pw2" class="input input-icon-pad" placeholder="Repeat" required minlength="8" autocomplete="new-password" />
          </div>
        </div>
      </div>

      <div id="pw-strength-wrap" style="display:none;margin-bottom:1.5rem;">
        <div class="pw-strength">
          <div class="pw-bar" id="pb1"></div><div class="pw-bar" id="pb2"></div><div class="pw-bar" id="pb3"></div><div class="pw-bar" id="pb4"></div>
        </div>
        <div style="font-size:0.72rem;margin-top:0.3rem;text-align:right;" id="pw-label"></div>
      </div>

      <button type="submit" class="btn btn-primary btn-lg btn-full" id="regBtn">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
        Create Account
      </button>
    </form>

    <!-- Footer -->
    <div class="auth-footer-links">
      <a href="/login" class="auth-link">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
        Sign in
      </a>
      <a href="/home" class="auth-link" style="color:var(--text-3);">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Back to home
      </a>
    </div>

    <!-- Discord strip -->
    <div class="auth-discord-strip">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="color:#5865f2;flex-shrink:0;"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/></svg>
      <div style="flex:1;font-size:0.8rem;color:var(--text-2);">Buy or request a key in our server.</div>
      <a href="<%= typeof discordUrl !== 'undefined' ? discordUrl : '#' %>" target="_blank" class="btn btn-sm btn-ghost" style="color:#818cf8;border-color:rgba(88,101,242,0.2);">Join Discord</a>
    </div>

    <div class="auth-version">v5.0.0 — © <%= new Date().getFullYear() %> <%= panelName %></div>
  </div>
</div>

<script>
/* Password Strength & Matching */
const pw1 = document.getElementById('pw1');
const pw2 = document.getElementById('pw2');
const strengthWrap = document.getElementById('pw-strength-wrap');
const bars = [1,2,3,4].map(i => document.getElementById('pb' + i));
const label = document.getElementById('pw-label');
const matchIcon = document.getElementById('pw-match-icon');

const strengthColors = ['#ef4444','#f59e0b','#3b82f6','#10b981'];
const strengthLabels = ['Weak','Fair','Good','Strong'];

pw1.addEventListener('input', function() {
  const v = this.value;
  if (!v) { strengthWrap.style.display = 'none'; return; }
  strengthWrap.style.display = 'block';

  let score = 0;
  if (v.length >= 8) score++;
  if (v.length >= 12) score++;
  if (/[A-Z]/.test(v) && /[a-z]/.test(v)) score++;
  if (/[0-9]/.test(v) || /[^a-zA-Z0-9]/.test(v)) score++;
  score = Math.max(1, Math.min(4, score));

  bars.forEach((b, i) => {
    b.style.background = i < score ? strengthColors[score - 1] : 'rgba(255,255,255,0.06)';
  });
  label.textContent = strengthLabels[score - 1];
  label.style.color = strengthColors[score - 1];
  checkMatch();
});

pw2.addEventListener('input', checkMatch);

function checkMatch() {
  if(pw2.value && pw1.value) {
    if(pw2.value === pw1.value) {
      pw2.style.borderColor = 'var(--success-border)';
      matchIcon.innerHTML = '<path stroke-linecap="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>';
      matchIcon.style.color = 'var(--success-light)';
    } else {
      pw2.style.borderColor = 'var(--danger-border)';
      matchIcon.innerHTML = '<path stroke-linecap="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-6 6l4-4m0 0l4 4m-6-6a9 9 0 1118 0 9 9 0 01-18 0z"/>';
      matchIcon.style.color = 'var(--danger-light)';
    }
  } else {
    pw2.style.borderColor = '';
    matchIcon.innerHTML = '<path stroke-linecap="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>';
    matchIcon.style.color = '';
  }
}

/* Key Field Logic */
const keyField = document.getElementById('keyField');
const keyBadge = document.getElementById('key-badge');
const keyHint = document.getElementById('key-hint');

keyField.addEventListener('input', function() {
  const val = this.value.trim();
  if (!val) {
    keyBadge.className = 'badge badge-green';
    keyBadge.textContent = 'Optional — Free';
    keyHint.textContent = 'Leave blank to register as a Free User';
  } else {
    keyBadge.className = 'badge badge-purple';
    keyBadge.innerHTML = '<svg width="12" height="12" fill="currentColor" viewBox="0 0 24 24" style="display:inline;vertical-align:middle;margin-right:2px;"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg> Premium Key';
    keyHint.textContent = 'Key will be verified via AuroraSafe API upon submit';
  }
});

/* Submit Logic */
document.getElementById('regForm').addEventListener('submit', function(e) {
  if (pw1.value !== pw2.value) {
    e.preventDefault();
    pw2.style.borderColor = 'var(--danger-border)';
    return;
  }
  const btn = document.getElementById('regBtn');
  btn.disabled = true;
  const isPremium = keyField.value.trim().length > 0;
  btn.innerHTML = '<span class="spinner"></span> ' + (isPremium ? 'Verifying Key...' : 'Creating Account...');
});
</script>
</body>
</html>
