<%- include('partials/head', { title: 'Settings — ' + panelName }) %>

<style>
.st-wrap { max-width: 860px; padding: 1.25rem; display: flex; flex-direction: column; gap: 1rem; }
.st-card { background: var(--bg-card); border: 1px solid var(--border-md); border-radius: 20px; overflow: hidden; }
.st-card-head { padding: 1rem 1.5rem; border-bottom: 1px solid var(--border-md); display: flex; align-items: center; gap: 0.85rem; background: rgba(255,255,255,0.015); }
.st-card-icon { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1rem; flex-shrink: 0; }
.st-card-title { font-weight: 800; font-size: 0.95rem; }
.st-card-desc { font-size: 0.78rem; color: var(--text-3); margin-top: 2px; }
.st-body { padding: 1.25rem 1.5rem; display: flex; flex-direction: column; gap: 1.25rem; }
.st-row { display: flex; flex-direction: column; gap: 0.4rem; }
.st-label { font-size: 0.82rem; font-weight: 700; color: var(--text-2); display: flex; align-items: center; gap: 0.4rem; }
.st-hint { font-size: 0.75rem; color: var(--text-3); }
.st-input { width: 100%; box-sizing: border-box; background: var(--bg-body); border: 1px solid var(--border-md); border-radius: 12px; padding: 0.65rem 1rem; color: var(--text); font-family: inherit; font-size: 0.9rem; transition: border-color 0.2s, box-shadow 0.2s; }
.st-input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(139,92,246,0.12); }
.st-select-wrap { position: relative; }
.st-select-wrap svg { position: absolute; right: 0.85rem; top: 50%; transform: translateY(-50%); pointer-events: none; color: var(--text-3); }
.st-input[type=range] { padding: 0; height: 6px; accent-color: var(--accent); background: var(--bg-raised); border: none; border-radius: 10px; cursor: pointer; }
/* Toggle switch */
.st-toggle-row { display: flex; align-items: center; justify-content: space-between; padding: 0.65rem 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
.st-toggle-row:last-child { border-bottom: none; }
.st-toggle-label { font-size: 0.87rem; font-weight: 600; }
.st-toggle-hint { font-size: 0.74rem; color: var(--text-3); margin-top: 2px; }
.st-toggle { position: relative; width: 42px; height: 24px; flex-shrink: 0; }
.st-toggle input { opacity: 0; width: 0; height: 0; }
.st-toggle-slider { position: absolute; inset: 0; background: var(--bg-raised); border: 1px solid var(--border-md); border-radius: 24px; cursor: pointer; transition: all 0.25s; }
.st-toggle-slider::before { content: ''; position: absolute; width: 16px; height: 16px; left: 3px; top: 3px; border-radius: 50%; background: var(--text-3); transition: all 0.25s; }
.st-toggle input:checked + .st-toggle-slider { background: rgba(139,92,246,0.2); border-color: var(--accent); }
.st-toggle input:checked + .st-toggle-slider::before { transform: translateX(18px); background: var(--accent); }
/* Avatar */
.st-avatar-ring { width: 72px; height: 72px; border-radius: 50%; overflow: hidden; border: 2px solid var(--border-md); flex-shrink: 0; transition: border-color 0.3s, box-shadow 0.3s; }
.st-avatar-ring img { width: 100%; height: 100%; object-fit: cover; }
/* Save footer */
.st-footer { display: flex; justify-content: flex-end; gap: 0.75rem; padding-top: 1rem; border-top: 1px solid var(--border-md); margin-top: 0.25rem; }
/* Status dots */
.st-status-preview { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.35rem 0.85rem; border-radius: 20px; font-size: 0.8rem; font-weight: 600; background: var(--bg-raised); border: 1px solid var(--border-md); }
</style>

<div class="layout">
  <%- include('partials/sidebar', { page: 'settings' }) %>
  <div class="main">
    <div class="topbar">
      <div class="topbar-left">
        <div class="pulse-dot"></div>
        <div class="topbar-title" data-i18n="Settings">Settings</div>
      </div>
    </div>

    <div class="content st-wrap">

      <!-- ── 1. Profile ── -->
      <div class="st-card">
        <div class="st-card-head">
          <div class="st-card-icon" style="background:rgba(139,92,246,0.12);">⚙️</div>
          <div>
            <div class="st-card-title" data-i18n="Profile Settings">Profile Settings</div>
            <div class="st-card-desc" data-i18n="Manage your account preferences and integrations.">Manage your account preferences and integrations.</div>
          </div>
        </div>
        <div class="st-body">

          <!-- Avatar -->
          <div class="st-row">
            <label class="st-label" data-i18n="Avatar URL (Image/GIF)">Avatar URL (Image/GIF)</label>
            <div style="display:flex;gap:1rem;align-items:flex-start;">
              <div class="st-avatar-ring" id="avatarRing">
                <% if (dbUser && dbUser.avatar_url) { %>
                  <img src="<%= dbUser.avatar_url %>" id="avatarImg" />
                <% } else { %>
                  <div id="avatarIni" style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:1.8rem;font-weight:800;background:linear-gradient(135deg,var(--bg-card),var(--bg-raised));color:var(--text-2);">
                    <%= user.username.charAt(0).toUpperCase() %>
                  </div>
                <% } %>
              </div>
              <div style="flex:1;display:flex;flex-direction:column;gap:0.4rem;">
                <input type="text" class="st-input" id="set-avatar" placeholder="https://example.com/avatar.gif" value="<%= dbUser ? dbUser.avatar_url || '' : '' %>" oninput="previewAvatar(this.value)">
                <div class="st-hint" data-i18n="Link to any direct image or GIF URL to use as your profile picture.">Link to any direct image or GIF URL to use as your profile picture.</div>
              </div>
            </div>
          </div>

          <!-- Banner URL -->
          <div class="st-row">
            <label class="st-label">🖼️ Banner URL (Profile cover image)</label>
            <div style="display:flex;flex-direction:column;gap:.6rem;">
              <div id="bannerPreviewBox" style="width:100%;height:90px;border-radius:12px;overflow:hidden;border:1px solid var(--border-md);background:var(--bg-raised);background-size:cover;background-position:center;transition:.3s;"
                <% if (dbUser && dbUser.banner_url) { %>style="background-image:url('<%= dbUser.banner_url %>')"<% } %>></div>
              <input type="text" class="st-input" id="set-banner" placeholder="https://example.com/banner.png"
                value="<%= dbUser ? dbUser.banner_url || '' : '' %>" oninput="previewBanner(this.value)">
              <div class="st-hint">Wide image (e.g. your Discord banner). Recommended: 1200×400px.</div>
            </div>
          </div>

          <!-- Bio -->
          <div class="st-row">
            <label class="st-label">📝 Bio <span style="color:var(--text-3);font-weight:400;font-size:.75rem;" id="bio-count">(<%= dbUser && dbUser.bio ? dbUser.bio.length : 0 %>/160)</span></label>
            <textarea class="st-input" id="set-bio" rows="3" maxlength="160" placeholder="Tell the community about yourself…" oninput="document.getElementById('bio-count').textContent='('+this.value.length+'/160)'" style="resize:vertical;min-height:72px;"><%= dbUser ? dbUser.bio || '' : '' %></textarea>
          </div>

          <!-- Profile Color -->
          <div class="st-row">
            <label class="st-label">🎨 Profile Accent Color</label>
            <div style="display:flex;align-items:center;gap:.8rem;">
              <input type="color" id="set-profile-color" value="<%= dbUser && dbUser.profile_color ? dbUser.profile_color : '#8b5cf6' %>" style="width:44px;height:44px;border-radius:10px;border:1px solid var(--border-md);background:none;cursor:pointer;padding:2px;">
              <input type="text" class="st-input" id="set-profile-color-text" value="<%= dbUser && dbUser.profile_color ? dbUser.profile_color : '#8b5cf6' %>" placeholder="#8b5cf6" style="max-width:160px;" oninput="syncColorPicker(this.value)">
              <div id="color-swatch" style="width:44px;height:44px;border-radius:10px;background:<%= dbUser && dbUser.profile_color ? dbUser.profile_color : '#8b5cf6' %>;flex-shrink:0;"></div>
            </div>
            <div class="st-hint">Used on your public profile: avatar border, stats color, banners.</div>
          </div>

          <!-- Discord ID -->
          <div class="st-row">
            <label class="st-label">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="#5865f2"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/></svg>
              <span data-i18n="Discord Integration">Discord Integration</span>
            </label>
            <div style="display: flex; gap: 1rem;">
              <input type="text" class="st-input" id="set-discord" placeholder="Not connected" value="<%= dbUser ? dbUser.discord_id || '' : '' %>" readonly style="opacity: 0.7;">
              <a href="/auth/discord" style="background: #5865f2; color: #fff; text-decoration: none; border-radius: 12px; padding: 0.65rem 1rem; font-weight: 600; font-size: 0.9rem; white-space: nowrap; display: flex; align-items: center; justify-content: center; gap: 0.5rem; transition: 0.2s;">
                Connect Discord
              </a>
            </div>
            <div class="st-hint">Connecting Discord will automatically sync your Avatar and allow login via Discord.</div>
          </div>

          <!-- Language -->
          <div class="st-row">
            <label class="st-label" data-i18n="Language">Language</label>
            <div class="st-select-wrap">
              <select class="st-input" id="set-language" onchange="onLangChange(this.value)" style="appearance:none;padding-right:2.5rem;cursor:pointer;">
                <option value="en"  <%= dbUser && dbUser.language === 'en'  ? 'selected' : '' %>>🇺🇸 English</option>
                <option value="es"  <%= dbUser && dbUser.language === 'es'  ? 'selected' : '' %>>🇪🇸 Español</option>
                <option value="pt"  <%= dbUser && dbUser.language === 'pt'  ? 'selected' : '' %>>🇧🇷 Português</option>
                <option value="fr"  <%= dbUser && dbUser.language === 'fr'  ? 'selected' : '' %>>🇫🇷 Français</option>
                <option value="de"  <%= dbUser && dbUser.language === 'de'  ? 'selected' : '' %>>🇩🇪 Deutsch</option>
                <option value="ru"  <%= dbUser && dbUser.language === 'ru'  ? 'selected' : '' %>>🇷🇺 Русский</option>
                <option value="zh"  <%= dbUser && dbUser.language === 'zh'  ? 'selected' : '' %>>🇨🇳 中文</option>
                <option value="ar"  <%= dbUser && dbUser.language === 'ar'  ? 'selected' : '' %>>🇸🇦 العربية</option>
                <option value="it"  <%= dbUser && dbUser.language === 'it'  ? 'selected' : '' %>>🇮🇹 Italiano</option>
                <option value="tr"  <%= dbUser && dbUser.language === 'tr'  ? 'selected' : '' %>>🇹🇷 Türkçe</option>
                <option value="pl"  <%= dbUser && dbUser.language === 'pl'  ? 'selected' : '' %>>🇵🇱 Polski</option>
                <option value="hi"  <%= dbUser && dbUser.language === 'hi'  ? 'selected' : '' %>>🇮🇳 हिन्दी</option>
              </select>
              <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </div>
          </div>

          <!-- Online Status -->
          <div class="st-row">
            <label class="st-label" data-i18n="Online Status">Online Status</label>
            <div class="st-select-wrap">
              <select class="st-input" id="set-status" style="appearance:none;padding-right:2.5rem;cursor:pointer;" onchange="previewStatus(this.value)">
                <option value="online"  <%= (dbUser && dbUser.online_status === 'online') || !dbUser?.online_status ? 'selected' : '' %>>🟢 Online</option>
                <option value="idle"    <%= dbUser && dbUser.online_status === 'idle'    ? 'selected' : '' %>>🌙 Idle</option>
                <option value="dnd"     <%= dbUser && dbUser.online_status === 'dnd'     ? 'selected' : '' %>>⛔ Do Not Disturb</option>
                <option value="offline" <%= dbUser && dbUser.online_status === 'offline' ? 'selected' : '' %>>⚪ Invisible</option>
              </select>
              <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </div>
            <div id="statusPreviewRow" style="margin-top:0.4rem;"></div>
            <div class="st-hint" data-i18n="How you appear to others in the Global Chat and Friends list.">How you appear to others in the Global Chat and Friends list.</div>
          </div>

          <div class="st-footer">
            <button class="btn btn-primary" id="save-profile-btn" onclick="saveSettings(this)">
              <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span data-i18n="Save Changes">Save Changes</span>
            </button>
          </div>
        </div>
      </div>

      <!-- ── 2. Appearance & Chat ── -->
      <div class="st-card">
        <div class="st-card-head">
          <div class="st-card-icon" style="background:rgba(59,130,246,0.12);">🎨</div>
          <div>
            <div class="st-card-title" data-i18n="Appearance">Appearance</div>
            <div class="st-card-desc" data-i18n="Chat Settings">Chat Settings</div>
          </div>
        </div>
        <div class="st-body">

          <!-- Mic Sensitivity -->
          <div class="st-row">
            <label class="st-label" data-i18n="Microphone Sensitivity (Voice Calls)">Microphone Sensitivity (Voice Calls)</label>
            <div style="display:flex;align-items:center;gap:1rem;">
              <input type="range" class="st-input" id="set-mic-sens" min="0" max="100" value="50" oninput="document.getElementById('mic-val').textContent=this.value+'%'">
              <span id="mic-val" style="width:38px;font-weight:700;font-size:0.88rem;text-align:right;color:var(--accent);">50%</span>
            </div>
            <div class="st-hint" data-i18n="Determines how loud you need to speak for your mic to activate in group calls. Saved locally.">Determines how loud you need to speak for your mic to activate. Saved locally.</div>
          </div>

          <!-- Toggles -->
          <div>
            <div class="st-toggle-row">
              <div>
                <div class="st-toggle-label">Animate GIF Avatars</div>
                <div class="st-toggle-hint">GIF profile pictures play animated in chat</div>
              </div>
              <label class="st-toggle">
                <input type="checkbox" id="tog-gif" checked>
                <span class="st-toggle-slider"></span>
              </label>
            </div>
            <div class="st-toggle-row">
              <div>
                <div class="st-toggle-label" data-i18n="Compact message layout">Compact message layout</div>
                <div class="st-toggle-hint">Show messages with less vertical spacing</div>
              </div>
              <label class="st-toggle">
                <input type="checkbox" id="tog-compact">
                <span class="st-toggle-slider"></span>
              </label>
            </div>
            <div class="st-toggle-row">
              <div>
                <div class="st-toggle-label" data-i18n="Show timestamps on messages">Show timestamps on messages</div>
                <div class="st-toggle-hint">Display time next to every message</div>
              </div>
              <label class="st-toggle">
                <input type="checkbox" id="tog-timestamps" checked>
                <span class="st-toggle-slider"></span>
              </label>
            </div>
            <div class="st-toggle-row">
              <div>
                <div class="st-toggle-label" data-i18n="Play sound on new message">Play sound on new message</div>
                <div class="st-toggle-hint">Soft notification chime in global chat</div>
              </div>
              <label class="st-toggle">
                <input type="checkbox" id="tog-sound" checked>
                <span class="st-toggle-slider"></span>
              </label>
            </div>
            <div class="st-toggle-row">
              <div>
                <div class="st-toggle-label" data-i18n="Desktop notifications">Desktop notifications</div>
                <div class="st-toggle-hint">Browser pop-ups for new messages (requires permission)</div>
              </div>
              <label class="st-toggle">
                <input type="checkbox" id="tog-notif">
                <span class="st-toggle-slider"></span>
              </label>
            </div>
            <div class="st-toggle-row">
              <div>
                <div class="st-toggle-label" data-i18n="Only show online friends">Only show online friends</div>
                <div class="st-toggle-hint">Hide offline/invisible friends in Social hub</div>
              </div>
              <label class="st-toggle">
                <input type="checkbox" id="tog-online-only">
                <span class="st-toggle-slider"></span>
              </label>
            </div>
          </div>

          <div class="st-footer">
            <button class="btn btn-secondary" onclick="savePrefs()">
              <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Save Preferences
            </button>
          </div>
        </div>
      </div>

      <!-- ── 3. Security ── -->
      <div class="st-card">
        <div class="st-card-head">
          <div class="st-card-icon" style="background:rgba(16,185,129,0.12);">🔒</div>
          <div>
            <div class="st-card-title" data-i18n="Password">Password</div>
            <div class="st-card-desc">Change your account password</div>
          </div>
        </div>
        <div class="st-body">
          <div class="st-row">
            <label class="st-label" data-i18n="New Password">New Password</label>
            <input type="password" class="st-input" id="new-pw" placeholder="Min. 8 characters" minlength="8" autocomplete="new-password">
          </div>
          <div class="st-row">
            <label class="st-label" data-i18n="Confirm New Password">Confirm New Password</label>
            <input type="password" class="st-input" id="new-pw2" placeholder="Repeat new password" minlength="8" autocomplete="new-password">
          </div>
          <div class="st-footer">
            <button class="btn btn-secondary" onclick="changePassword(this)">
              <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
              <span data-i18n="Change Password">Change Password</span>
            </button>
          </div>
        </div>
      </div>

    </div><!-- /st-wrap -->
  </div>
</div>

<script>
/* ── Avatar preview (supports GIF) ── */
function previewAvatar(url) {
  const ring = document.getElementById('avatarRing');
  if (!url) { ring.style.boxShadow=''; return; }
  let img = document.getElementById('avatarImg');
  if (!img) {
    ring.innerHTML = '';
    img = document.createElement('img');
    img.id = 'avatarImg';
    img.style = 'width:100%;height:100%;object-fit:cover;';
    ring.appendChild(img);
  }
  img.src = url; // browsers animate GIFs natively via <img>
  ring.style.boxShadow = '0 0 0 3px rgba(139,92,246,0.4)';
  ring.style.borderColor = 'var(--accent)';
}

/* ── Status preview ── */
const STATUS_COLORS = { online:'#22c55e', idle:'#f59e0b', dnd:'#ef4444', offline:'#6b7280' };
const STATUS_LABELS = { online:'🟢 Online', idle:'🌙 Idle', dnd:'⛔ Do Not Disturb', offline:'⚪ Invisible' };
function previewStatus(val) {
  const c = STATUS_COLORS[val] || '#22c55e';
  const row = document.getElementById('statusPreviewRow');
  row.innerHTML = `<span class="st-status-preview"><span style="width:10px;height:10px;border-radius:50%;background:${c};display:inline-block;box-shadow:0 0 6px ${c}99;"></span>${STATUS_LABELS[val]||'Online'}</span>`;
}

/* ── Language change ── */
function onLangChange(lang) { window.currentLanguage = lang; window.applyTranslations(lang); }

/* ── Save profile to server ── */
function previewBanner(url) {
  const box = document.getElementById('bannerPreviewBox');
  if (url && url.startsWith('http')) {
    box.style.backgroundImage = `url('${url}')`;
    box.style.backgroundSize = 'cover';
  } else {
    box.style.backgroundImage = 'none';
  }
}

function syncColorPicker(val) {
  const picker = document.getElementById('set-profile-color');
  const swatch = document.getElementById('color-swatch');
  if (/^#[0-9a-fA-F]{6}$/.test(val)) { picker.value = val; swatch.style.background = val; }
}

document.getElementById('set-profile-color')?.addEventListener('input', function() {
  document.getElementById('set-profile-color-text').value = this.value;
  document.getElementById('color-swatch').style.background = this.value;
});

async function saveSettings(btn) {
  const avatarUrl    = document.getElementById('set-avatar').value.trim();
  const bannerUrl    = document.getElementById('set-banner').value.trim();
  const bio          = document.getElementById('set-bio').value.trim();
  const profileColor = document.getElementById('set-profile-color').value.trim();
  const discordId    = document.getElementById('set-discord').value.trim();
  const language     = document.getElementById('set-language').value;
  const onlineStatus = document.getElementById('set-status').value;
  const micSens      = document.getElementById('set-mic-sens').value;
  localStorage.setItem('micSensitivity', micSens);

  const orig = btn.innerHTML; btn.disabled = true;
  btn.innerHTML = '<div class="spinner" style="width:13px;height:13px;border-width:2px;"></div> Saving…';
  try {
    const res  = await fetch('/api/settings', { method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ avatar_url: avatarUrl, banner_url: bannerUrl, bio, profile_color: profileColor, discord_id: discordId, language, online_status: onlineStatus }) });
    const data = await res.json();
    if (data.success) { toast('Saved! ✓', 'ok'); setTimeout(() => location.reload(), 800); }
    else { toast(data.message || 'Error', 'err'); btn.disabled=false; btn.innerHTML=orig; }
  } catch { toast('Network error', 'err'); btn.disabled=false; btn.innerHTML=orig; }
}

/* ── Save preferences (toggles) to localStorage ── */
function savePrefs() {
  const prefs = {
    gifAvatars:    document.getElementById('tog-gif').checked,
    compact:       document.getElementById('tog-compact').checked,
    timestamps:    document.getElementById('tog-timestamps').checked,
    sound:         document.getElementById('tog-sound').checked,
    desktopNotif:  document.getElementById('tog-notif').checked,
    onlineOnly:    document.getElementById('tog-online-only').checked,
  };
  localStorage.setItem('chatPrefs', JSON.stringify(prefs));
  toast('Preferences saved ✓', 'ok');

  /* Request desktop notification permission if enabled */
  if (prefs.desktopNotif && Notification.permission === 'default') {
    Notification.requestPermission();
  }
}

/* ── Change password ── */
async function changePassword(btn) {
  const pw1 = document.getElementById('new-pw').value;
  const pw2 = document.getElementById('new-pw2').value;
  if (!pw1 || pw1.length < 8) return toast('Password must be at least 8 characters.', 'err');
  if (pw1 !== pw2) return toast('Passwords do not match.', 'err');
  const orig = btn.innerHTML; btn.disabled = true;
  btn.innerHTML = '<div class="spinner" style="width:13px;height:13px;border-width:2px;"></div> Saving…';
  try {
    const res  = await fetch('/api/user/change-password', { method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ password: pw1 }) });
    const data = await res.json();
    if (data.success) { toast('Password changed! 🔒', 'ok'); document.getElementById('new-pw').value=''; document.getElementById('new-pw2').value=''; }
    else toast(data.message || 'Error', 'err');
  } catch { toast('Network error', 'err'); }
  btn.disabled=false; btn.innerHTML=orig;
}

/* ── Load saved values on page load ── */
document.addEventListener('DOMContentLoaded', () => {
  /* Language */
  const lang = document.getElementById('set-language').value;
  if (lang && lang !== 'en') { window.currentLanguage = lang; window.applyTranslations(lang); }

  /* Mic sensitivity */
  const savedMic = localStorage.getItem('micSensitivity');
  if (savedMic !== null) {
    document.getElementById('set-mic-sens').value = savedMic;
    document.getElementById('mic-val').textContent = savedMic + '%';
  }

  /* Toggles */
  const prefs = JSON.parse(localStorage.getItem('chatPrefs') || '{}');
  if (prefs.gifAvatars   !== undefined) document.getElementById('tog-gif').checked        = prefs.gifAvatars;
  if (prefs.compact      !== undefined) document.getElementById('tog-compact').checked     = prefs.compact;
  if (prefs.timestamps   !== undefined) document.getElementById('tog-timestamps').checked  = prefs.timestamps;
  if (prefs.sound        !== undefined) document.getElementById('tog-sound').checked        = prefs.sound;
  if (prefs.desktopNotif !== undefined) document.getElementById('tog-notif').checked       = prefs.desktopNotif;
  if (prefs.onlineOnly   !== undefined) document.getElementById('tog-online-only').checked = prefs.onlineOnly;

  /* Status preview */
  previewStatus(document.getElementById('set-status').value);
});
</script>
</body>
</html>
