<%- include('partials/head', { title: 'Settings — ' + panelName }) %>

<div class="layout">
  <%- include('partials/sidebar', { page: 'settings' }) %>

  <div class="main">
    <div class="topbar">
      <div class="topbar-left">
        <div class="pulse-dot"></div>
        <div class="topbar-title" data-i18n="Settings">Settings</div>
      </div>
    </div>

    <div class="content" style="max-width: 820px;">

      <!-- Profile Settings Card -->
      <div class="card settings-card" style="animation: slideUp 0.3s ease;">
        <div class="card-head">
          <div class="card-icon ci-purple">⚙️</div>
          <div>
            <div class="card-title" data-i18n="Profile Settings">Profile Settings</div>
            <div class="card-desc" data-i18n="Manage your account preferences and integrations.">Manage your account preferences and integrations.</div>
          </div>
        </div>

        <div style="padding: 1.5rem; display: flex; flex-direction: column; gap: 1.75rem;">

          <!-- Avatar -->
          <div class="form-group">
            <label class="label" data-i18n="Avatar URL (Image/GIF)">Avatar URL (Image/GIF)</label>
            <div style="display: flex; gap: 1rem; align-items: flex-start;">
              <div id="avatar-ring" style="
                width: 68px; height: 68px; border-radius: 50%;
                background: var(--bg-body); overflow: hidden;
                border: 2px solid var(--border-md); flex-shrink: 0;
                box-shadow: 0 0 0 0 var(--purple-glow,rgba(139,92,246,0));
                transition: box-shadow 0.3s;
              ">
                <% if (dbUser && dbUser.avatar_url) { %>
                  <img src="<%= dbUser.avatar_url %>" style="width:100%;height:100%;object-fit:cover;" id="avatar-preview"/>
                <% } else { %>
                  <div id="avatar-initials" style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:1.6rem;color:var(--text-3);font-weight:700;background:linear-gradient(135deg,var(--bg-card),var(--bg-raised));"><%= user.username.charAt(0).toUpperCase() %></div>
                <% } %>
              </div>
              <div style="flex:1;display:flex;flex-direction:column;gap:0.5rem;">
                <input type="text" class="input" id="set-avatar"
                  placeholder="https://example.com/image.png"
                  value="<%= dbUser ? dbUser.avatar_url : '' %>"
                  oninput="updateAvatarPreview(this.value)"/>
                <div class="t-xs muted" data-i18n="Link to any direct image or GIF URL to use as your profile picture.">Link to any direct image or GIF URL to use as your profile picture.</div>
              </div>
            </div>
          </div>

          <!-- Discord ID -->
          <div class="form-group">
            <label class="label" style="display:flex;align-items:center;gap:0.4rem;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#5865f2" style="flex-shrink:0"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/></svg>
              <span data-i18n="Discord ID">Discord ID</span>
            </label>
            <input type="text" class="input" id="set-discord" placeholder="e.g. 123456789012345678" value="<%= dbUser ? dbUser.discord_id : '' %>"/>
            <div class="t-xs muted" style="margin-top:0.5rem;" data-i18n="Connect your Discord account to sync roles or use Discord avatars in the future.">Connect your Discord account to sync roles or use Discord avatars in the future.</div>
          </div>

          <!-- Language -->
          <div class="form-group">
            <label class="label" data-i18n="Language">Language</label>
            <div style="position:relative;">
              <select class="input" id="set-language" onchange="onLangChange(this.value)" style="appearance:none;padding-right:2.5rem;cursor:pointer;">
                <option value="en"  <%= dbUser && dbUser.language === 'en'  ? 'selected' : '' %>>🇺🇸 English</option>
                <option value="es"  <%= dbUser && dbUser.language === 'es'  ? 'selected' : '' %>>🇪🇸 Español</option>
                <option value="pt"  <%= dbUser && dbUser.language === 'pt'  ? 'selected' : '' %>>🇧🇷 Português</option>
                <option value="fr"  <%= dbUser && dbUser.language === 'fr'  ? 'selected' : '' %>>🇫🇷 Français</option>
                <option value="de"  <%= dbUser && dbUser.language === 'de'  ? 'selected' : '' %>>🇩🇪 Deutsch</option>
                <option value="ru"  <%= dbUser && dbUser.language === 'ru'  ? 'selected' : '' %>>🇷🇺 Русский</option>
                <option value="zh"  <%= dbUser && dbUser.language === 'zh'  ? 'selected' : '' %>>🇨🇳 中文</option>
                <option value="ar"  <%= dbUser && dbUser.language === 'ar'  ? 'selected' : '' %>>🇸🇦 العربية</option>
              </select>
              <svg style="position:absolute;right:0.75rem;top:50%;transform:translateY(-50%);pointer-events:none;color:var(--text-3);" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </div>
            <div class="t-xs muted" style="margin-top:0.5rem;" id="lang-hint">Translates the entire interface instantly. Saved with your profile.</div>
          </div>

          <!-- Save -->
          <div style="border-top: 1px solid var(--border-md); padding-top: 1.25rem; display: flex; justify-content: flex-end; gap: 0.75rem;">
            <button class="btn btn-primary" id="save-btn" onclick="saveSettings(this)" data-i18n="Save Changes">
              <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Save Changes
            </button>
          </div>

        </div>
      </div>

      <!-- Security Card -->
      <div class="card settings-card" style="animation: slideUp 0.4s ease; margin-top: 1.25rem;">
        <div class="card-head">
          <div class="card-icon ci-green">🔒</div>
          <div>
            <div class="card-title">Password</div>
            <div class="card-desc">Change your account password.</div>
          </div>
        </div>
        <div style="padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem;">
          <div class="form-group">
            <label class="label">New Password</label>
            <div class="input-wrap">
              <svg class="input-icon" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" stroke-width="2"/><path stroke-linecap="round" stroke-width="2" d="M7 11V7a5 5 0 0110 0v4"/></svg>
              <input type="password" class="input input-icon-pad" id="new-pw" placeholder="Min. 8 characters" minlength="8" autocomplete="new-password"/>
            </div>
          </div>
          <div class="form-group">
            <label class="label">Confirm New Password</label>
            <div class="input-wrap">
              <svg class="input-icon" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <input type="password" class="input input-icon-pad" id="new-pw2" placeholder="Repeat new password" minlength="8" autocomplete="new-password"/>
            </div>
          </div>
          <div style="display:flex;justify-content:flex-end;">
            <button class="btn btn-secondary" onclick="changePassword(this)">
              <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
              Change Password
            </button>
          </div>
        </div>
      </div>

    </div><!-- /content -->
  </div>
</div>

<script>
/* ── Avatar preview ── */
function updateAvatarPreview(url) {
  const ring = document.getElementById('avatar-ring');
  let img = document.getElementById('avatar-preview');
  const ini = document.getElementById('avatar-initials');
  if (!img) {
    img = document.createElement('img');
    img.id = 'avatar-preview';
    img.style = 'width:100%;height:100%;object-fit:cover;';
    ring.innerHTML = '';
    ring.appendChild(img);
  }
  if (url) {
    img.src = url;
    if (ini) ini.style.display = 'none';
    ring.style.boxShadow = '0 0 0 3px var(--purple,#8b5cf6)44';
  } else {
    ring.style.boxShadow = '';
  }
}

/* ── Language change preview ── */
function onLangChange(lang) {
  window.currentLanguage = lang;
  window.applyTranslations(lang);
}

/* ── Save settings ── */
async function saveSettings(btn) {
  const avatarUrl = document.getElementById('set-avatar').value.trim();
  const discordId = document.getElementById('set-discord').value.trim();
  const language  = document.getElementById('set-language').value;

  const orig = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<div class="spinner" style="width:14px;height:14px;border-width:2px;"></div> Saving…';

  try {
    const res  = await fetch('/api/settings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ avatar_url: avatarUrl, discord_id: discordId, language })
    });
    const data = await res.json();
    if (data.success) {
      toast('Settings saved ✓', 'ok');
      setTimeout(() => window.location.reload(), 900);
    } else {
      toast(data.message || 'Error', 'err');
      btn.disabled = false;
      btn.innerHTML = orig;
    }
  } catch {
    toast('Network error', 'err');
    btn.disabled = false;
    btn.innerHTML = orig;
  }
}

/* ── Change password ── */
async function changePassword(btn) {
  const pw1 = document.getElementById('new-pw').value;
  const pw2 = document.getElementById('new-pw2').value;
  if (!pw1 || pw1.length < 8) return toast('Password must be at least 8 characters.', 'err');
  if (pw1 !== pw2) return toast('Passwords do not match.', 'err');

  const orig = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<div class="spinner" style="width:14px;height:14px;border-width:2px;"></div> Saving…';

  try {
    const res  = await fetch('/api/user/change-password', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ password: pw1 })
    });
    const data = await res.json();
    if (data.success) {
      toast('Password changed!', 'ok');
      document.getElementById('new-pw').value = '';
      document.getElementById('new-pw2').value = '';
    } else {
      toast(data.message || 'Error', 'err');
    }
  } catch {
    toast('Network error', 'err');
  }
  btn.disabled = false;
  btn.innerHTML = orig;
}

/* Apply saved language on load */
const currentLang = document.getElementById('set-language').value;
if (currentLang && currentLang !== 'en') {
  window.currentLanguage = currentLang;
  document.addEventListener('DOMContentLoaded', () => window.applyTranslations(currentLang));
}
</script>
</body>
</html>
