<%- include('partials/head', { title: 'Social — ' + panelName }) %>

<style>
/* ═══════════════════════════════════════════════
   SOCIAL HUB — Premium Redesign
═══════════════════════════════════════════════ */
.sh-wrap { display: flex; height: calc(100vh - 70px); padding: 1rem 1.25rem; gap: 1rem; overflow: hidden; }

/* ── Panel base ── */
.sh-panel {
  display: flex; flex-direction: column;
  background: var(--bg-card);
  border: 1px solid var(--border-md);
  border-radius: 20px;
  overflow: hidden;
  position: relative;
}
.sh-panel::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: linear-gradient(90deg, #ec4899, #8b5cf6, #3b82f6);
  z-index: 5;
}

/* ── Left: Friends ── */
.sh-friends { width: 320px; flex-shrink: 0; }

/* ── Right: Groups ── */
.sh-groups { flex: 1; }

/* ── Panel header ── */
.sh-head {
  padding: 1rem 1.25rem 0.85rem;
  border-bottom: 1px solid var(--border-md);
  display: flex; align-items: center; justify-content: space-between;
  flex-shrink: 0;
  background: rgba(255,255,255,0.015);
}
.sh-head-title {
  font-size: 0.82rem; font-weight: 800;
  text-transform: uppercase; letter-spacing: 0.08em;
  color: var(--text-2);
  display: flex; align-items: center; gap: 0.5rem;
}
.sh-head-title svg { color: var(--accent); }
.sh-count {
  font-size: 0.7rem; font-weight: 700;
  background: rgba(139,92,246,0.12);
  color: #a78bfa;
  border: 1px solid rgba(139,92,246,0.2);
  border-radius: 20px; padding: 2px 9px;
}

/* ── Add Friend bar ── */
.sh-add-bar {
  padding: 0.85rem 1rem;
  border-bottom: 1px solid var(--border-md);
  display: flex; gap: 0.5rem; flex-shrink: 0;
}
.sh-add-input {
  flex: 1;
  background: var(--bg-body);
  border: 1px solid var(--border-md);
  border-radius: 10px;
  padding: 0.55rem 0.85rem;
  color: var(--text);
  font-family: inherit; font-size: 0.88rem;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.sh-add-input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(139,92,246,0.12); }
.sh-add-btn {
  padding: 0.55rem 0.9rem;
  border-radius: 10px;
  background: linear-gradient(135deg, var(--accent), #6366f1);
  color: white; border: none;
  font-weight: 700; font-size: 0.82rem;
  cursor: pointer; white-space: nowrap;
  transition: transform 0.15s, box-shadow 0.15s;
  box-shadow: 0 3px 10px rgba(139,92,246,0.3);
}
.sh-add-btn:hover { transform: translateY(-1px); box-shadow: 0 5px 15px rgba(139,92,246,0.4); }
.sh-add-btn:active { transform: scale(0.97); }

/* ── Scroll body ── */
.sh-body { flex: 1; overflow-y: auto; padding: 0.75rem; display: flex; flex-direction: column; gap: 0.5rem; }
.sh-body::-webkit-scrollbar { width: 4px; }
.sh-body::-webkit-scrollbar-track { background: transparent; }
.sh-body::-webkit-scrollbar-thumb { background: var(--border-md); border-radius: 4px; }

/* ── Empty state ── */
.sh-empty {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 0.5rem; padding: 2.5rem 1rem; color: var(--text-3);
  text-align: center;
}
.sh-empty svg { opacity: 0.3; }
.sh-empty p { font-size: 0.85rem; font-weight: 500; }

/* ── Friend card ── */
.sh-friend-card {
  display: flex; align-items: center; gap: 0.75rem;
  padding: 0.7rem 0.85rem;
  border-radius: 14px;
  border: 1px solid transparent;
  transition: all 0.25s cubic-bezier(0.16,1,0.3,1);
  cursor: default;
  position: relative;
}
.sh-friend-card:hover {
  background: var(--bg-raised);
  border-color: var(--border-md);
  transform: translateX(3px);
}
.sh-fav-wrap { position: relative; flex-shrink: 0; }
.sh-fav {
  width: 40px; height: 40px; border-radius: 12px;
  background: linear-gradient(135deg, var(--border-md), var(--border));
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 1rem; color: var(--text);
  border: 1px solid var(--border-md);
  overflow: hidden;
}
.sh-fav-dot {
  width: 11px; height: 11px; border-radius: 50%;
  border: 2px solid var(--bg-card);
  position: absolute; bottom: -2px; right: -2px;
}
.sh-finfo { flex: 1; min-width: 0; }
.sh-fname { font-weight: 700; font-size: 0.9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.sh-fstatus { font-size: 0.76rem; color: var(--text-3); margin-top: 1px; }
.sh-fstatus.pending { color: #f59e0b; }
.sh-accept-btn {
  padding: 0.3rem 0.7rem;
  border-radius: 8px;
  background: rgba(16,185,129,0.15);
  border: 1px solid rgba(16,185,129,0.3);
  color: #10b981;
  font-size: 0.78rem; font-weight: 700;
  cursor: pointer; white-space: nowrap;
  transition: background 0.2s;
  flex-shrink: 0;
}
.sh-accept-btn:hover { background: rgba(16,185,129,0.28); }

/* ── Groups grid ── */
.sh-groups-grid {
  flex: 1; overflow-y: auto;
  padding: 1rem;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 0.85rem;
  align-content: start;
}
.sh-groups-grid::-webkit-scrollbar { width: 4px; }
.sh-groups-grid::-webkit-scrollbar-thumb { background: var(--border-md); border-radius: 4px; }

.sh-group-card {
  background: rgba(0,0,0,0.2);
  border: 1px solid var(--border-md);
  border-radius: 18px;
  padding: 1.25rem;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.16,1,0.3,1);
  display: flex; flex-direction: column; gap: 0.85rem;
  position: relative; overflow: hidden;
}
.sh-group-card::after {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(139,92,246,0.06), transparent);
  opacity: 0; transition: opacity 0.3s;
  pointer-events: none;
}
.sh-group-card:hover {
  transform: translateY(-4px);
  border-color: rgba(139,92,246,0.4);
  box-shadow: 0 12px 35px rgba(0,0,0,0.35);
}
.sh-group-card:hover::after { opacity: 1; }
.sh-group-icon {
  width: 52px; height: 52px; border-radius: 16px;
  background: linear-gradient(135deg, #ec4899, #8b5cf6);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.4rem; font-weight: 800; color: white;
  box-shadow: 0 6px 20px rgba(139,92,246,0.35);
}
.sh-group-name { font-weight: 800; font-size: 1rem; color: var(--text); }
.sh-group-date { font-size: 0.75rem; color: var(--text-3); }
.sh-group-arrow {
  width: 28px; height: 28px; border-radius: 8px;
  background: rgba(139,92,246,0.1); border: 1px solid rgba(139,92,246,0.2);
  display: flex; align-items: center; justify-content: center;
  color: var(--accent); align-self: flex-end;
  transition: transform 0.2s;
}
.sh-group-card:hover .sh-group-arrow { transform: translateX(3px); }

/* ── Create group button ── */
.sh-create-btn {
  display: flex; align-items: center; gap: 0.5rem;
  padding: 0.55rem 1rem;
  border-radius: 10px;
  background: linear-gradient(135deg, #ec4899, #8b5cf6);
  color: white; border: none;
  font-weight: 700; font-size: 0.82rem;
  cursor: pointer;
  transition: transform 0.15s, box-shadow 0.15s;
  box-shadow: 0 4px 15px rgba(139,92,246,0.3);
}
.sh-create-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(139,92,246,0.45); }

/* ── Modal ── */
.sh-modal-bg {
  display: none; position: fixed; inset: 0; z-index: 9998;
  background: rgba(0,0,0,0.6); backdrop-filter: blur(8px);
  align-items: center; justify-content: center;
}
.sh-modal-bg.open { display: flex; animation: fadeIn 0.2s ease; }
.sh-modal {
  background: var(--bg-card);
  border: 1px solid var(--border-md);
  border-radius: 20px;
  padding: 2rem;
  width: 100%; max-width: 380px;
  box-shadow: 0 30px 80px rgba(0,0,0,0.6);
  animation: slideUp 0.3s cubic-bezier(0.16,1,0.3,1);
}
.sh-modal h3 { font-size: 1.1rem; font-weight: 800; margin-bottom: 1.25rem; }
.sh-modal-input {
  width: 100%; box-sizing: border-box;
  background: var(--bg-body);
  border: 1px solid var(--border-md);
  border-radius: 12px;
  padding: 0.75rem 1rem;
  color: var(--text); font-family: inherit; font-size: 0.95rem;
  margin-bottom: 1rem;
  transition: border-color 0.2s;
}
.sh-modal-input:focus { outline: none; border-color: var(--accent); }
.sh-modal-actions { display: flex; gap: 0.75rem; justify-content: flex-end; }
.sh-modal-cancel {
  padding: 0.6rem 1rem; border-radius: 10px;
  background: var(--bg-raised); border: 1px solid var(--border-md);
  color: var(--text); cursor: pointer; font-weight: 600; font-size: 0.88rem;
  transition: background 0.2s;
}
.sh-modal-cancel:hover { background: var(--bg-hover); }
.sh-modal-ok {
  padding: 0.6rem 1.25rem; border-radius: 10px;
  background: linear-gradient(135deg, #ec4899, #8b5cf6);
  border: none; color: white; cursor: pointer;
  font-weight: 700; font-size: 0.88rem;
  box-shadow: 0 4px 15px rgba(139,92,246,0.3);
  transition: transform 0.15s;
}
.sh-modal-ok:hover { transform: translateY(-1px); }

@media (max-width: 700px) {
  .sh-wrap { flex-direction: column; }
  .sh-friends { width: 100%; height: 40vh; }
  .sh-groups { height: 50vh; }
  .sh-groups-grid { grid-template-columns: 1fr 1fr; }
}
</style>

<div class="layout">
  <%- include('partials/sidebar', { page: 'social' }) %>
  <div class="main">

    <!-- Top Bar -->
    <div class="topbar">
      <div class="topbar-left">
        <div class="pulse-dot" style="background:#ec4899;"></div>
        <div class="topbar-title">Social Hub</div>
      </div>
    </div>

    <!-- Main Layout -->
    <div class="sh-wrap">

      <!-- ── FRIENDS PANEL ── -->
      <div class="sh-panel sh-friends">
        <div class="sh-head">
          <div class="sh-head-title">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            Friends
          </div>
          <span class="sh-count"><%= friends.filter(f => f.status === 'accepted').length %> friends</span>
        </div>

        <!-- Add Friend -->
        <div class="sh-add-bar">
          <input type="text" id="friendUsername" class="sh-add-input" placeholder="Add by username…" autocomplete="off">
          <button class="sh-add-btn" onclick="addFriend()">+ Add</button>
        </div>

        <!-- Friends List -->
        <div class="sh-body">
          <% if (friends.length === 0) { %>
            <div class="sh-empty">
              <svg width="40" height="40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
              <p>No friends yet.<br>Search for someone above!</p>
            </div>
          <% } %>
          <% friends.forEach(f => { %>
            <%
              const isPending = f.status && f.status.startsWith('pending');
              const isAccepted = f.status === 'accepted';
              let sentByMe = false;
              if (f.status.startsWith('pending_')) {
                sentByMe = f.status === ('pending_' + user.id);
              } else if (f.status === 'pending') {
                sentByMe = (f.user1_id === user.id);
              }
              const canAccept = isPending && !sentByMe;
              const sc = f.online_status === 'idle' ? '#f59e0b' : f.online_status === 'dnd' ? '#ef4444' : f.online_status === 'offline' ? '#6b7280' : '#22c55e';
            %>
            <div class="sh-friend-card">
              <a href="/profile/<%= encodeURIComponent(f.username) %>" style="display:contents;">
                <div class="sh-fav-wrap">
                  <div class="sh-fav" style="<%= f.avatar_url ? 'background:url('+f.avatar_url+') center/cover;color:transparent;' : '' %>">
                    <%= f.avatar_url ? '' : f.username.charAt(0).toUpperCase() %>
                  </div>
                  <div class="sh-fav-dot" style="background:<%= sc %>;box-shadow:0 0 5px <%= sc %>99;"></div>
                </div>
                <div class="sh-finfo">
                  <div class="sh-fname"><%= f.username %></div>
                  <div class="sh-fstatus <%= isPending ? 'pending' : '' %>">
                    <%= isPending ? (sentByMe ? '⏳ Request Sent' : '⏳ Pending Request') : isAccepted ? '✓ Friends' : '' %>
                  </div>
                </div>
              </a>
              <% if (canAccept) { %>
                <button class="sh-accept-btn" onclick="acceptFriend(<%= f.user_id %>)">Accept</button>
              <% } %>
            </div>
          <% }) %>
        </div>
      </div>

      <!-- ── GROUPS PANEL ── -->
      <div class="sh-panel sh-groups">
        <div class="sh-head">
          <div class="sh-head-title">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/></svg>
            Private Groups
          </div>
          <button class="sh-create-btn" onclick="openCreateGroup()">
            <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
            New Group
          </button>
        </div>

        <!-- Groups Grid -->
        <% if (groups.length === 0) { %>
          <div class="sh-empty" style="flex:1;display:flex;">
            <svg width="40" height="40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/></svg>
            <p>No groups yet.<br>Create one and invite friends!</p>
          </div>
        <% } else { %>
        <div class="sh-groups-grid">
          <% groups.forEach(g => { %>
            <div class="sh-group-card" onclick="window.location.href='/groups/<%= g.id %>'">
              <div class="sh-group-icon"><%= g.name.charAt(0).toUpperCase() %></div>
              <div>
                <div class="sh-group-name"><%= g.name %></div>
                <div class="sh-group-date">Created <%= new Date(g.created_at).toLocaleDateString() %></div>
              </div>
              <div class="sh-group-arrow">
                <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
              </div>
            </div>
          <% }) %>
        </div>
        <% } %>
      </div>

    </div><!-- /.sh-wrap -->
  </div>
</div>

<!-- ── Create Group Modal ── -->
<div class="sh-modal-bg" id="createGroupModal">
  <div class="sh-modal">
    <h3>🏠 Create a Private Group</h3>
    <input type="text" id="newGroupName" class="sh-modal-input" placeholder="Group name…" maxlength="48" autocomplete="off">
    <div class="sh-modal-actions">
      <button class="sh-modal-cancel" onclick="closeCreateGroup()">Cancel</button>
      <button class="sh-modal-ok" onclick="doCreateGroup()">Create Group</button>
    </div>
  </div>
</div>

<script>
/* ── Add Friend ── */
async function addFriend() {
  const username = document.getElementById('friendUsername').value.trim();
  if (!username) return;
  const res  = await fetch('/api/friends/request', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ username })
  });
  const data = await res.json();
  toast(data.message, data.success ? 'ok' : 'err');
  if (data.success) setTimeout(() => location.reload(), 1000);
}

/* ── Accept Friend ── */
async function acceptFriend(friendId) {
  const res  = await fetch('/api/friends/accept', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ friendId })
  });
  const data = await res.json();
  if (data.success) { toast('Friend accepted! 🎉', 'ok'); setTimeout(() => location.reload(), 800); }
  else toast(data.message || 'Error', 'err');
}

/* ── Enter on add input ── */
document.getElementById('friendUsername').addEventListener('keydown', e => {
  if (e.key === 'Enter') addFriend();
});

/* ── Create Group Modal ── */
function openCreateGroup()  { document.getElementById('createGroupModal').classList.add('open'); setTimeout(() => document.getElementById('newGroupName').focus(), 50); }
function closeCreateGroup() { document.getElementById('createGroupModal').classList.remove('open'); }

document.getElementById('newGroupName').addEventListener('keydown', e => {
  if (e.key === 'Enter') doCreateGroup();
  if (e.key === 'Escape') closeCreateGroup();
});
document.getElementById('createGroupModal').addEventListener('click', e => {
  if (e.target === e.currentTarget) closeCreateGroup();
});

async function doCreateGroup() {
  const name = document.getElementById('newGroupName').value.trim();
  if (!name) return toast('Please enter a group name', 'warn');
  const res  = await fetch('/api/groups/create', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ name })
  });
  const data = await res.json();
  if (data.success) {
    toast('Group created! 🚀', 'ok');
    setTimeout(() => window.location.href = '/groups/' + data.groupId, 500);
  } else {
    toast(data.message || 'Error', 'err');
  }
}
</script>
</body>
</html>
