<%- include('partials/head', { title: (typeof panelName !== 'undefined' ? panelName : 'Aurora Hub') + ' — Tutorials' }) %>

<script src="https://unpkg.com/@phosphor-icons/web"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700;800;900&family=Inter:wght@400;500;600&display=swap');

:root {
  --bg: #07070f;
  --surface: #12121a;
  --surface-glass: rgba(18,18,26,0.65);
  --border: rgba(255,255,255,0.1);
  --primary: #8b5cf6;
  --primary-light: #a78bfa;
  --text: #f8fafc;
  --text-dim: #94a3b8;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Space Grotesk', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}

/* Scrollbar */
::-webkit-scrollbar { width: 8px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: rgba(139,92,246,0.4); border-radius: 4px; }

/* Ambient */
.ambient-bg {
  position: fixed; inset: 0; z-index: -2; pointer-events: none;
  background:
    radial-gradient(ellipse 60% 50% at 20% 20%, rgba(139,92,246,0.18) 0%, transparent 60%),
    radial-gradient(ellipse 50% 40% at 80% 80%, rgba(14,165,233,0.12) 0%, transparent 60%);
  filter: blur(40px);
  animation: pulse-bg 12s ease-in-out infinite alternate;
}
@keyframes pulse-bg { 0% { opacity: 0.7; } 100% { opacity: 1; } }

/* Navbar */
.nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 1rem 4rem;
  background: rgba(7,7,15,0.75); backdrop-filter: blur(24px);
  border-bottom: 1px solid var(--border);
}
.nav-brand { display: flex; align-items: center; gap: 0.8rem; text-decoration: none; }
.nav-brand img { width: 40px; height: 40px; border-radius: 10px; border: 1px solid var(--border); }
.nav-brand span { font-weight: 800; font-size: 1.3rem; color: #fff; }
.nav-links { display: flex; gap: 2rem; }
.nav-links a {
  color: var(--text-dim); text-decoration: none; font-weight: 600; font-size: 0.9rem;
  transition: color 0.2s; position: relative;
}
.nav-links a:hover, .nav-links a.active { color: #fff; }
.nav-links a.active::after {
  content: ''; position: absolute; bottom: -4px; left: 0; right: 0; height: 2px;
  background: var(--primary-light); border-radius: 2px;
}
.nav-actions { display: flex; gap: 0.8rem; }
.btn {
  display: inline-flex; align-items: center; gap: 0.4rem;
  padding: 0.6rem 1.4rem; border-radius: 10px; text-decoration: none;
  font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 0.9rem;
  border: none; cursor: pointer; transition: all 0.2s;
}
.btn-glass { background: rgba(255,255,255,0.05); color: #fff; border: 1px solid var(--border); }
.btn-glass:hover { background: rgba(255,255,255,0.1); }
.btn-glow { background: linear-gradient(135deg, var(--primary), #6366f1); color: #fff; }
.btn-glow:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(139,92,246,0.4); }

/* Page Hero */
.page-hero {
  padding: 9rem 2rem 4rem;
  text-align: center;
  animation: fadeIn 0.8s ease;
}
.page-hero .pill {
  display: inline-flex; align-items: center; gap: 0.5rem;
  background: rgba(139,92,246,0.12); border: 1px solid rgba(139,92,246,0.35);
  color: var(--primary-light); padding: 0.4rem 1.2rem; border-radius: 50px;
  font-size: 0.8rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
  margin-bottom: 1.5rem;
}
.page-hero h1 {
  font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 900; line-height: 1.05;
  letter-spacing: -2px;
  background: linear-gradient(135deg, #fff 30%, #a78bfa 70%, #38bdf8);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  margin-bottom: 1rem;
}
.page-hero p {
  font-family: 'Inter', sans-serif; color: var(--text-dim);
  font-size: 1.1rem; max-width: 550px; margin: 0 auto; line-height: 1.7;
}

/* Main Content */
.tutorials-wrap {
  max-width: 1300px; margin: 0 auto; padding: 2rem 2rem 6rem;
}

/* Empty State */
.empty-state {
  text-align: center; padding: 5rem 2rem; color: var(--text-dim);
}
.empty-state i { font-size: 4rem; opacity: 0.3; display: block; margin-bottom: 1rem; }
.empty-state h3 { font-size: 1.5rem; color: var(--text-dim); font-weight: 600; }

/* Video Grid */
.videos-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 2rem;
}

/* Video Card */
.video-card {
  background: var(--surface-glass);
  border: 1px solid var(--border);
  border-radius: 20px;
  overflow: hidden;
  transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
  cursor: pointer;
  animation: slideUp 0.6s ease backwards;
}
.video-card:hover {
  transform: translateY(-6px);
  border-color: rgba(139,92,246,0.5);
  box-shadow: 0 16px 40px rgba(0,0,0,0.4), 0 0 20px rgba(139,92,246,0.15);
}

/* Video Preview */
.video-thumb {
  position: relative; aspect-ratio: 16/9; background: #000; overflow: hidden;
}
.video-thumb video {
  width: 100%; height: 100%; object-fit: cover;
  pointer-events: none;
}
.video-play-overlay {
  position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
  background: rgba(0,0,0,0.35);
  transition: background 0.3s;
}
.video-card:hover .video-play-overlay { background: rgba(0,0,0,0.15); }
.play-btn-circle {
  width: 64px; height: 64px; border-radius: 50%;
  background: rgba(255,255,255,0.95);
  display: flex; align-items: center; justify-content: center;
  transition: transform 0.3s, box-shadow 0.3s;
  box-shadow: 0 4px 20px rgba(0,0,0,0.5);
}
.play-btn-circle i {
  color: var(--primary); font-size: 1.8rem;
  transform: translateX(2px); /* optical center for play icon */
}
.video-card:hover .play-btn-circle {
  transform: scale(1.1);
  box-shadow: 0 8px 30px rgba(139,92,246,0.5);
}

/* Card Info */
.video-info {
  padding: 1.4rem;
}
.video-info h3 {
  font-size: 1.05rem; font-weight: 700; margin-bottom: 0.5rem;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.video-info p {
  font-family: 'Inter', sans-serif; font-size: 0.85rem; color: var(--text-dim);
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}

/* Lightbox Modal */
.lightbox {
  display: none; position: fixed; inset: 0; z-index: 9999;
  background: rgba(0,0,0,0.95); backdrop-filter: blur(16px);
  align-items: center; justify-content: center;
}
.lightbox.open { display: flex; animation: fadeIn 0.2s ease; }
.lightbox-inner {
  width: 90vw; max-width: 1000px; position: relative;
  animation: scaleIn 0.25s cubic-bezier(0.16,1,0.3,1);
}
.lightbox-close {
  position: absolute; top: -3rem; right: 0;
  background: none; border: none; color: rgba(255,255,255,0.6);
  font-size: 2rem; cursor: pointer; transition: color 0.2s;
  display: flex; align-items: center; gap: 0.4rem; font-family: 'Space Grotesk', sans-serif;
  font-size: 0.9rem; font-weight: 600;
}
.lightbox-close:hover { color: #fff; }
.lightbox-video {
  width: 100%; aspect-ratio: 16/9; border-radius: 16px;
  background: #000; outline: none;
  box-shadow: 0 30px 80px rgba(0,0,0,0.8), 0 0 0 1px rgba(255,255,255,0.08);
}
.lightbox-title {
  margin-top: 1rem; font-size: 1.2rem; font-weight: 700; color: #fff;
}
.lightbox-desc {
  margin-top: 0.4rem; font-size: 0.9rem; color: var(--text-dim); font-family: 'Inter', sans-serif;
}

/* Animations */
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes scaleIn { from { transform: scale(0.92); opacity: 0; } to { transform: scale(1); opacity: 1; } }
@keyframes slideUp { from { transform: translateY(30px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

/* Responsive */
@media (max-width: 768px) {
  .nav { padding: 1rem; flex-wrap: wrap; gap: 0.6rem; }
  .nav-links { display: none; }
  .videos-grid { grid-template-columns: 1fr; }
}
</style>

<div class="ambient-bg"></div>

<!-- Nav -->
<nav class="nav">
  <a href="/" class="nav-brand">
    <img src="<%= typeof panelLogo !== 'undefined' ? panelLogo : '/logo.png' %>" onerror="this.src='https://ui-avatars.com/api/?name=AH&background=7c3aed&color=fff'" alt="Logo">
    <span><%= typeof panelName !== 'undefined' ? panelName : 'Aurora Hub' %></span>
  </a>
  <div class="nav-links">
    <a href="/">Home</a>
    <a href="/tutorials" class="active">Tutorials</a>
    <a href="#premium">Pricing</a>
  </div>
  <div class="nav-actions">
    <% if (user) { %>
      <a href="/dashboard" class="btn btn-glass"><i class="ph ph-squares-four"></i> Dashboard</a>
    <% } else { %>
      <a href="/login" class="btn btn-glass">Login</a>
      <a href="/register" class="btn btn-glow">Get Started</a>
    <% } %>
  </div>
</nav>

<!-- Hero -->
<div class="page-hero">
  <div class="pill"><i class="ph-fill ph-video"></i> Learn Everything</div>
  <h1>Tutorials &amp;<br>Guides</h1>
  <p>Step-by-step videos to help you get the most out of Aurora Hub. From setup to advanced farming.</p>
</div>

<!-- Videos -->
<div class="tutorials-wrap">
  <% if (!tutorials || tutorials.length === 0) { %>
    <div class="empty-state">
      <i class="ph ph-video-camera-slash"></i>
      <h3>No tutorials yet</h3>
      <p style="margin-top: 0.5rem; font-family: 'Inter', sans-serif; font-size: 0.9rem;">Check back soon — the admin is uploading videos!</p>
    </div>
  <% } else { %>
    <div class="videos-grid">
      <% tutorials.forEach((t, i) => { %>
        <div class="video-card" style="animation-delay: <%= i * 0.08 %>s" onclick="openLightbox('<%= t.video_url %>', '<%= t.title.replace(/'/g, "\\\\'"  ) %>', '<%= (t.description || '').replace(/'/g, "\\\\'") %>')">
          <div class="video-thumb">
            <video src="<%= t.video_url %>" preload="metadata" muted></video>
            <div class="video-play-overlay">
              <div class="play-btn-circle">
                <i class="ph-fill ph-play"></i>
              </div>
            </div>
          </div>
          <div class="video-info">
            <h3><%= t.title %></h3>
            <% if (t.description) { %>
              <p><%= t.description %></p>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<!-- Lightbox -->
<div class="lightbox" id="lightbox" onclick="closeLightboxOnBg(event)">
  <div class="lightbox-inner">
    <button class="lightbox-close" onclick="closeLightbox()">
      <i class="ph ph-x"></i> Close
    </button>
    <video id="lightbox-video" class="lightbox-video" controls autoplay></video>
    <div class="lightbox-title" id="lightbox-title"></div>
    <div class="lightbox-desc" id="lightbox-desc"></div>
  </div>
</div>

<script>
function openLightbox(url, title, desc) {
  const lb = document.getElementById('lightbox');
  const vid = document.getElementById('lightbox-video');
  vid.src = url;
  document.getElementById('lightbox-title').textContent = title;
  document.getElementById('lightbox-desc').textContent = desc;
  lb.classList.add('open');
  document.body.style.overflow = 'hidden';
  vid.play().catch(() => {});
}

function closeLightbox() {
  const lb = document.getElementById('lightbox');
  const vid = document.getElementById('lightbox-video');
  vid.pause();
  vid.src = '';
  lb.classList.remove('open');
  document.body.style.overflow = '';
}

function closeLightboxOnBg(e) {
  if (e.target === document.getElementById('lightbox')) closeLightbox();
}

document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });
</script>
</body>
</html>
